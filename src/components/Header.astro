---
/**
 * Site header variants for filter UI comparison.
 */
interface Props {
  variant?: "path" | "labeled" | "simple";
  homeHref?: string;
}

import DirectoryPathFilter from "./DirectoryPathFilter.astro";
import DirectoryLabeledPath from "./DirectoryLabeledPath.astro";

const { variant = "simple", homeHref = "/" } = Astro.props;
---

<header class="border-b border-black/10 bg-dm-offblack text-dm-offwhite">
  {
    variant === "path" && (
      <div class="mx-auto flex max-w-7xl flex-col gap-2 px-4 py-2.5 sm:flex-row sm:items-center sm:justify-between sm:gap-4 sm:px-6">
        <DirectoryPathFilter />
        <nav
          class="flex shrink-0 flex-wrap items-center gap-3 text-xs text-dm-offwhite/70 sm:justify-end"
          aria-label="Principal"
        >
          <a href="/directorio/" class="hover:text-dm-offwhite">
            Todo
          </a>
          <a href="/estado/" class="hover:text-dm-offwhite">
            Locación
          </a>
          <a href="/servicios/" class="hover:text-dm-offwhite">
            Servicios
          </a>
          <a href="/acerca-de/" class="hover:text-dm-offwhite">
            Acerca
          </a>
        </nav>
      </div>
    )
  }
  {
    variant === "labeled" && (
      <div class="mx-auto flex max-w-7xl flex-col gap-2 px-4 py-2.5 sm:flex-row sm:items-center sm:justify-between sm:gap-4 sm:px-6">
        <DirectoryLabeledPath />
        <nav
          class="flex shrink-0 flex-wrap items-center gap-3 text-xs text-dm-offwhite/70 sm:justify-end"
          aria-label="Principal"
        >
          <a href="/directorio/" class="hover:text-dm-offwhite">
            Todo
          </a>
          <a href="/estado/" class="hover:text-dm-offwhite">
            Locación
          </a>
          <a href="/servicios/" class="hover:text-dm-offwhite">
            Servicios
          </a>
          <a href="/acerca-de/" class="hover:text-dm-offwhite">
            Acerca
          </a>
        </nav>
      </div>
    )
  }
  {
    variant === "simple" && (
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
        <a href={homeHref} class="text-lg tracking-wide hover:opacity-80">
          DIMELA.mx
        </a>
        <nav
          class="hidden flex-wrap items-center gap-4 text-sm text-dm-offwhite/80 sm:flex"
          aria-label="Principal"
        >
          <a href="/directorio/" class="hover:text-dm-offwhite">
            Todo
          </a>
          <a href="/estado/" class="hover:text-dm-offwhite">
            Locación
          </a>
          <a href="/servicios/" class="hover:text-dm-offwhite">
            Servicios
          </a>
          <a href="/acerca-de/" class="hover:text-dm-offwhite">
            Acerca
          </a>
        </nav>
        <details class="relative sm:hidden">
          <summary
            class="cursor-pointer list-none rounded border border-white/25 px-2.5 py-1.5 text-sm text-dm-offwhite/90"
            aria-label="Menú"
          >
            Menú
          </summary>
          <div class="absolute top-full right-0 z-40 mt-1 min-w-[10rem] rounded border border-black/20 bg-white py-1 text-dm-offblack shadow-lg">
            <a href="/directorio/" class="block px-3 py-2 text-sm hover:bg-dm-offwhite">
              Todo
            </a>
            <a href="/estado/" class="block px-3 py-2 text-sm hover:bg-dm-offwhite">
              Locación
            </a>
            <a href="/servicios/" class="block px-3 py-2 text-sm hover:bg-dm-offwhite">
              Servicios
            </a>
            <a href="/acerca-de/" class="block px-3 py-2 text-sm hover:bg-dm-offwhite">
              Acerca
            </a>
          </div>
        </details>
      </div>
    )
  }
</header>
