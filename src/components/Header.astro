---
/**
 * Site header variants for filter UI comparison.
 * A (path) & B (simple): filter-focused — site nav lives in the footer.
 * Mobile: DIMELA + active-filter breadcrumb in the top bar.
 */
interface Props {
  variant?: "path" | "labeled" | "simple";
  homeHref?: string;
}

import DirectoryPathFilter from "./DirectoryPathFilter.astro";
import DirectoryLabeledPath from "./DirectoryLabeledPath.astro";

const { variant = "simple", homeHref = "/" } = Astro.props;
---

<header class="border-b border-black/10 bg-dm-offblack text-dm-offwhite">
  {
    variant === "path" && (
      <div class="mx-auto max-w-7xl px-4 py-2.5 sm:px-6">
        {/* Mobile: brand + filter breadcrumb */}
        <div class="mb-2 flex min-w-0 flex-wrap items-center gap-x-1.5 gap-y-1 md:hidden">
          <a
            href="/"
            data-filter-home
            class="shrink-0 text-lg tracking-wide text-dm-offwhite hover:opacity-80"
          >
            DIMELA.mx
          </a>
          <nav
            data-active-crumbs
            hidden
            class="flex min-w-0 flex-wrap items-center gap-x-1.5 gap-y-1 text-xs text-dm-offwhite/75"
            aria-label="Filtros activos"
          ></nav>
        </div>
        <DirectoryPathFilter />
      </div>
    )
  }
  {
    variant === "labeled" && (
      <div class="mx-auto flex max-w-7xl flex-col gap-2 px-4 py-2.5 sm:flex-row sm:items-center sm:justify-between sm:gap-4 sm:px-6">
        <DirectoryLabeledPath />
        <nav
          class="flex shrink-0 flex-wrap items-center gap-3 text-xs text-dm-offwhite/70 sm:justify-end"
          aria-label="Principal"
        >
          <a href="/directorio/" class="hover:text-dm-offwhite">
            Todo
          </a>
          <a href="/estado/" class="hover:text-dm-offwhite">
            Locación
          </a>
          <a href="/servicios/" class="hover:text-dm-offwhite">
            Servicios
          </a>
          <a href="/acerca-de/" class="hover:text-dm-offwhite">
            Acerca
          </a>
        </nav>
      </div>
    )
  }
  {
    variant === "simple" && (
      <div
        class="mx-auto flex w-full max-w-7xl items-center py-3"
        style="padding-left: var(--dm-page-px); padding-right: var(--dm-page-px)"
        data-header-inner
      >
        <div class="flex min-w-0 flex-wrap items-center gap-x-1.5 gap-y-1">
          <a
            href={homeHref}
            data-filter-home
            class="shrink-0 text-lg tracking-wide hover:opacity-80"
          >
            DIMELA.mx
          </a>
          <nav
            data-active-crumbs
            hidden
            class="flex min-w-0 flex-wrap items-center gap-x-1.5 gap-y-1 text-xs text-dm-offwhite/75 md:hidden"
            aria-label="Filtros activos"
          ></nav>
        </div>
      </div>
    )
  }
</header>

<style is:global>
  .active-crumb {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    max-width: 11rem;
    color: var(--color-dm-offwhite);
    font-weight: 500;
  }
  .active-crumb span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .active-crumb button {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 1.2rem;
    height: 1.2rem;
    border: 1px solid color-mix(in oklab, var(--color-dm-offwhite) 40%, transparent);
    border-radius: 9999px;
    line-height: 1;
    font-size: 0.65rem;
    opacity: 0.85;
  }
  .active-crumb button:hover {
    border-color: var(--color-dm-offwhite);
    opacity: 1;
  }
</style>
