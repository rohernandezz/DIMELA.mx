---
/**
 * Site header: path filter (logo › ubicación › servicio) + quiet nav.
 */
import DirectoryPathFilter from "./DirectoryPathFilter.astro";

const pathname = Astro.url.pathname;
---

<header class="border-b border-black/10 bg-dm-offblack text-dm-offwhite">
  <div
    class="mx-auto flex max-w-7xl flex-col gap-2 px-4 py-2.5 sm:flex-row sm:items-center sm:justify-between sm:gap-4 sm:px-6"
  >
    <DirectoryPathFilter />

    <nav
      class="flex shrink-0 flex-wrap items-center gap-3 text-xs text-dm-offwhite/70 sm:justify-end"
      aria-label="Principal"
    >
      <a
        href="/directorio/"
        class:list={["hover:text-dm-offwhite", pathname.startsWith("/directorio") && "text-dm-offwhite underline"]}
        aria-current={pathname.startsWith("/directorio") ? "page" : undefined}
      >
        Todo
      </a>
      <a
        href="/estado/"
        class:list={["hover:text-dm-offwhite", pathname.startsWith("/estado") && "text-dm-offwhite underline"]}
        aria-current={pathname.startsWith("/estado") ? "page" : undefined}
      >
        Locación
      </a>
      <a
        href="/servicios/"
        class:list={["hover:text-dm-offwhite", pathname.startsWith("/servicios") && "text-dm-offwhite underline"]}
        aria-current={pathname.startsWith("/servicios") ? "page" : undefined}
      >
        Servicios
      </a>
      <a
        href="/acerca-de/"
        class:list={["hover:text-dm-offwhite", pathname.startsWith("/acerca-de") && "text-dm-offwhite underline"]}
        aria-current={pathname.startsWith("/acerca-de") ? "page" : undefined}
      >
        Acerca
      </a>
    </nav>
  </div>
</header>
