---
/**
 * Site header variants for filter UI comparison.
 * A (path) & B (simple): filter-focused — site nav in hamburger + footer.
 * Mobile: DIMELA + active-filter breadcrumb in the top bar.
 */
interface Props {
  variant?: "path" | "labeled" | "simple";
  homeHref?: string;
  /** Tagline beside logo when no active header breadcrumbs (simple variant only). */
  showTagline?: boolean;
}

import DirectoryPathFilter from "./DirectoryPathFilter.astro";
import DirectoryLabeledPath from "./DirectoryLabeledPath.astro";

const { variant = "simple", homeHref = "/", showTagline = false } = Astro.props;

const navLinks = [
  { href: "/directorio/", label: "Todo" },
  { href: "/estado/", label: "Locación" },
  { href: "/servicios/", label: "Servicios" },
  { href: "/acerca-de/", label: "Acerca de…" },
] as const;

const betaLinks = [
  { href: "/brand/", label: "Brand" },
  { href: "/entrar/", label: "Entrar" },
] as const;
---

<header class="border-b border-black/10 bg-dm-offblack text-dm-offwhite">
  {
    variant === "path" && (
      <div class="mx-auto max-w-dm-page px-4 py-2.5 sm:px-6">
        <div class="mb-2 flex min-w-0 flex-wrap items-center gap-x-1.5 gap-y-1 md:hidden">
          <a
            href="/"
            data-filter-home
            class="shrink-0 text-lg tracking-wide text-dm-offwhite hover:opacity-80"
          >
            DIMELA.mx
          </a>
          <nav
            data-active-crumbs
            hidden
            class="flex min-w-0 flex-wrap items-center gap-x-1.5 gap-y-1 text-xs text-dm-offwhite/75"
            aria-label="Filtros activos"
          ></nav>
        </div>
        <DirectoryPathFilter />
      </div>
    )
  }
  {
    variant === "labeled" && (
      <div class="mx-auto flex max-w-dm-page flex-col gap-2 px-4 py-2.5 sm:flex-row sm:items-center sm:justify-between sm:gap-4 sm:px-6">
        <DirectoryLabeledPath />
        <nav
          class="flex shrink-0 flex-wrap items-center gap-3 text-xs text-dm-offwhite/70 sm:justify-end"
          aria-label="Principal"
        >
          {navLinks.map((link) => (
            <a href={link.href} class="hover:text-dm-offwhite">
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    )
  }
  {
    variant === "simple" && (
      <div
        class="mx-auto flex w-full max-w-dm-page items-center gap-3 py-3"
        style="padding-left: var(--dm-page-px); padding-right: var(--dm-page-px)"
        data-header-inner
      >
        <div class="flex min-w-0 flex-1 flex-wrap items-baseline gap-x-1.5 gap-y-1">
          <a
            href={homeHref}
            data-filter-home
            class="shrink-0 text-lg tracking-wide hover:opacity-80"
          >
            DIMELA.mx
          </a>
          {
            showTagline && (
              <span
                data-site-tagline
                class="min-w-0 text-sm font-normal tracking-normal text-dm-offwhite/50"
              >
                {"\u00a0|\u2003Directorio Mexicano de Letristas"}
              </span>
            )
          }
          <nav
            data-active-crumbs
            hidden
            class="flex min-w-0 flex-wrap items-center gap-x-1.5 gap-y-1 text-xs text-dm-offwhite/75 md:hidden"
            aria-label="Filtros activos"
          ></nav>
        </div>

        <div class="relative shrink-0" data-site-menu>
          <button
            type="button"
            data-site-menu-toggle
            class="site-menu-toggle flex h-9 w-9 items-center justify-center rounded text-dm-offwhite outline-none hover:bg-white/10 focus-visible:bg-white/10"
            aria-expanded="false"
            aria-controls="site-menu-panel"
            aria-label="Menú"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M4 7h16M4 12h16M4 17h16"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
              ></path>
            </svg>
          </button>
          <div
            id="site-menu-panel"
            data-site-menu-panel
            hidden
            class="absolute top-full right-0 z-50 mt-1 min-w-[11rem] rounded border border-black/15 bg-white py-1 text-dm-offblack shadow-lg"
            role="menu"
            aria-label="Principal"
          >
            {
              navLinks.map((link) => (
                <a
                  href={link.href}
                  class="block px-3 py-2 text-sm hover:bg-dm-offwhite"
                  role="menuitem"
                >
                  {link.label}
                </a>
              ))
            }
            <a
              href="/editar/"
              class="block border-t border-dm-offblack/10 px-3 py-2 text-sm hover:bg-dm-offwhite"
              role="menuitem"
            >
              Editor
            </a>
            <a
              href="/admin/"
              class="block px-3 py-2 text-sm hover:bg-dm-offwhite"
              role="menuitem"
            >
              Admin
            </a>
            <div
              class="mx-1.5 my-1.5 rounded border border-dm-offblack/10 bg-dm-offwhite py-1"
              role="group"
              aria-label="Beta"
            >
              <p class="px-3 pt-1.5 pb-0.5 text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase">
                Beta
              </p>
              {
                betaLinks.map((link) => (
                  <a
                    href={link.href}
                    class="block px-3 py-1.5 text-sm text-dm-offblack/80 hover:bg-dm-offblack/5"
                    role="menuitem"
                  >
                    {link.label}
                  </a>
                ))
              }
            </div>
            <a
              href="https://tortilla.studio"
              class="block border-t border-dm-offblack/10 px-3 py-2 text-sm hover:bg-dm-offwhite"
              role="menuitem"
              rel="noopener noreferrer"
            >
              Tortilla!
            </a>
          </div>
        </div>
      </div>
    )
  }
</header>

<style is:global>
  .active-crumb {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    max-width: 11rem;
    color: var(--color-dm-offwhite);
    font-weight: 500;
  }
  .active-crumb span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .active-crumb button {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 1.2rem;
    height: 1.2rem;
    border: 1px solid color-mix(in oklab, var(--color-dm-offwhite) 40%, transparent);
    border-radius: 9999px;
    line-height: 1;
    font-size: 0.65rem;
    opacity: 0.85;
  }
  .active-crumb button:hover {
    border-color: var(--color-dm-offwhite);
    opacity: 1;
  }

  /* Compact header chrome when grey bar is collapsed sticky on desktop */
  @media (min-width: 768px) {
    .directory-filter[data-collapsed] .site-menu-toggle {
      height: 1.5rem;
      width: 1.5rem;
    }
    .directory-filter[data-collapsed] .site-menu-toggle svg {
      height: 0.875rem;
      width: 0.875rem;
    }
    .directory-filter[data-collapsed] [data-site-tagline] {
      font-size: 0.75rem;
      line-height: 1rem;
    }
  }
  @media (prefers-reduced-motion: no-preference) {
    @media (min-width: 768px) {
      [data-site-tagline] {
        transition:
          font-size 0.2s ease,
          line-height 0.2s ease;
      }
    }
  }
</style>

<script>
  function initSiteMenu() {
    document.querySelectorAll<HTMLElement>("[data-site-menu]").forEach((wrap) => {
      if (wrap.dataset.menuReady) return;
      wrap.dataset.menuReady = "1";

      const toggle = wrap.querySelector<HTMLButtonElement>("[data-site-menu-toggle]");
      const panel = wrap.querySelector<HTMLElement>("[data-site-menu-panel]");
      if (!toggle || !panel) return;

      const setOpen = (open: boolean) => {
        panel.hidden = !open;
        toggle.setAttribute("aria-expanded", open ? "true" : "false");
      };

      toggle.addEventListener("click", (e) => {
        e.stopPropagation();
        setOpen(panel.hidden);
      });

      panel.addEventListener("click", (e) => e.stopPropagation());

      document.addEventListener("click", () => setOpen(false));
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") setOpen(false);
      });
    });
  }

  initSiteMenu();

  function hasVisibleHeaderCrumbs(): boolean {
    return [...document.querySelectorAll<HTMLElement>("[data-active-crumbs]")].some((host) => {
      if (host.hidden || host.childElementCount === 0) return false;
      return host.getClientRects().length > 0;
    });
  }

  function syncSiteTagline() {
    document.querySelectorAll<HTMLElement>("[data-site-tagline]").forEach((el) => {
      el.hidden = hasVisibleHeaderCrumbs();
    });
  }

  function initSiteTagline() {
    syncSiteTagline();
    if (document.documentElement.dataset.taglineSyncReady) return;
    document.documentElement.dataset.taglineSyncReady = "1";

    const observer = new MutationObserver(() => syncSiteTagline());
    document.querySelectorAll<HTMLElement>("[data-active-crumbs]").forEach((host) => {
      observer.observe(host, { attributes: true, childList: true, subtree: true });
    });

    window.addEventListener("resize", syncSiteTagline, { passive: true });
  }

  initSiteTagline();
  document.addEventListener("astro:page-load", () => {
    initSiteMenu();
    initSiteTagline();
  });
</script>
