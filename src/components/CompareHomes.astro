---
/**
 * Tiny strip on UI prototype pages only (not on canonical `/`).
 */
interface Props {
  current: "path" | "labeled" | "trail";
}

const { current } = Astro.props;
---

<p
  class="mt-10 flex flex-wrap items-center gap-x-3 gap-y-1 rounded border border-dashed border-dm-offblack/20 bg-white/70 px-3 py-2 text-xs text-dm-offblack/70"
>
  <span class="font-semibold tracking-wide uppercase">UI prototypes</span>
  <a href="/" class="underline-offset-2 hover:underline">B · Filter bar (live)</a>
  <a
    href="/path/"
    class:list={[
      "underline-offset-2 hover:underline",
      current === "path" && "font-bold text-dm-offblack underline",
    ]}
  >
    A · Path
  </a>
  <a
    href="/labeled/"
    class:list={[
      "underline-offset-2 hover:underline",
      current === "labeled" && "font-bold text-dm-offblack underline",
    ]}
  >
    C · Labeled
  </a>
  <a
    href="/trail/"
    class:list={[
      "underline-offset-2 hover:underline",
      current === "trail" && "font-bold text-dm-offblack underline",
    ]}
  >
    D · Trail
  </a>
</p>
