---
/**
 * Option A — path filters in the dark header.
 * Desktop: DIMELA.mx › Ubicación ▾ › Servicio ▾ [Buscar]
 * Mobile: brand + search + Filtros dropdown (same pattern as Option B).
 */
import { MEXICO_ESTADOS, SERVICIOS } from "../data/taxonomy";

const estados = [...MEXICO_ESTADOS];
const servicios = [...SERVICIOS];
---

<div class="directory-path min-w-0 flex-1" data-directory-filter aria-label="Filtrar directorio">
  {/* ── Desktop path row ─────────────────────────────────────────── */}
  <div class="hidden min-w-0 flex-wrap items-center gap-x-1 gap-y-2 text-sm md:flex">
    <a
      href="/"
      data-filter-home
      class="shrink-0 text-base tracking-wide text-dm-offwhite hover:opacity-80"
    >
      DIMELA.mx
    </a>

    <span class="text-dm-offwhite/35" aria-hidden="true">›</span>

    <div class="relative min-w-0 max-w-[min(100%,20rem)]" data-menu="estado" data-estado-desktop>
      <button
        type="button"
        data-menu-toggle
        class="flex w-full min-w-0 items-center gap-1 rounded px-1.5 py-0.5 text-dm-offwhite hover:bg-white/10"
        aria-expanded="false"
        aria-haspopup="listbox"
      >
        <span data-estado-label class="min-w-0 flex-1 truncate">Todo México</span>
        <span class="shrink-0 text-dm-offwhite/50" aria-hidden="true">▾</span>
      </button>
      <div
        data-menu-panel
        hidden
        class="absolute top-full left-0 z-40 mt-1 max-h-64 w-56 overflow-auto rounded border border-black/20 bg-white py-1 text-dm-offblack shadow-lg"
        role="listbox"
        aria-multiselectable="true"
      >
        {
          estados.map((estado) => (
            <label class="flex cursor-pointer items-center gap-2 px-2.5 py-1.5 text-xs hover:bg-dm-offwhite">
              <input
                type="checkbox"
                data-estado-option
                value={estado}
                class="rounded border-dm-offblack/30"
              />
              <span>{estado}</span>
            </label>
          ))
        }
      </div>
    </div>

    <span class="text-dm-offwhite/35" aria-hidden="true">›</span>

    <div class="relative" data-menu="servicio" data-servicio-desktop>
      <button
        type="button"
        data-menu-toggle
        class="flex max-w-[14rem] items-center gap-1 rounded px-1.5 py-0.5 text-dm-offwhite hover:bg-white/10"
        aria-expanded="false"
        aria-haspopup="listbox"
      >
        <span data-servicio-label class="truncate">Todos los servicios</span>
        <span class="text-dm-offwhite/50" aria-hidden="true">▾</span>
      </button>
      <div
        data-menu-panel
        hidden
        class="absolute top-full left-0 z-40 mt-1 w-[min(100vw-2rem,22rem)] rounded border border-black/20 bg-white p-3 text-dm-offblack shadow-lg"
        role="listbox"
        aria-multiselectable="true"
      >
        <div class="flex flex-wrap gap-2">
          {
            servicios.map((servicio) => (
              <button
                type="button"
                class="filter-chip dm-ui-chip bg-dm-offwhite"
                data-filter-chip
                data-value={servicio}
                aria-pressed="false"
              >
                {servicio}
              </button>
            ))
          }
        </div>
      </div>
    </div>

    <label class="relative ml-1 w-40 shrink-0 sm:ml-2">
      <span class="sr-only">Buscar</span>
      <input
        type="search"
        name="q"
        data-filter-q
        placeholder="Buscar…"
        autocomplete="off"
        class="w-full rounded border border-white/20 bg-white/10 px-2 py-1 text-sm text-dm-offwhite outline-none placeholder:text-dm-offwhite/40 focus:border-white/50 focus:bg-white/15"
      />
    </label>

    <p
      class="ml-1 flex shrink-0 items-baseline gap-1.5"
      data-filter-count
      aria-live="polite"
    >
      <span class="dm-ui-facet-label text-dm-offwhite/40"
        >Resultados</span
      >
      <span class="text-xs text-dm-offwhite/55 tabular-nums" data-filter-count-value></span>
    </p>

    <button
      type="button"
      data-filter-clear
      class="rounded border border-white/20 px-2 py-0.5 text-xs text-dm-offwhite/70 hover:bg-white/10 disabled:cursor-default disabled:opacity-30"
      disabled
    >
      Limpiar
    </button>
  </div>

  {/* ── Mobile chrome ────────────────────────────────────────────── */}
  <div class="md:hidden">
    <div class="flex items-center gap-2">
      <label class="relative min-w-0 flex-1">
        <span class="sr-only">Buscar</span>
        <input
          type="search"
          name="q"
          data-filter-q
          placeholder="Buscar…"
          autocomplete="off"
          class="w-full rounded border border-white/20 bg-white/10 px-2.5 py-2 text-sm text-dm-offwhite outline-none placeholder:text-dm-offwhite/40 focus:border-white/50 focus:bg-white/15"
        />
      </label>

      <p class="flex shrink-0 flex-col items-end leading-tight" data-filter-count aria-live="polite">
        <span class="text-[9px] font-semibold tracking-wide text-dm-offwhite/40 uppercase"
          >Resultados</span
        >
        <span class="text-xs text-dm-offwhite/55 tabular-nums" data-filter-count-value></span>
      </p>

      <button
        type="button"
        data-mobile-filters-toggle
        class="relative shrink-0 rounded border border-white/30 bg-white/10 px-3 py-2 text-sm text-dm-offwhite"
        aria-expanded="false"
        aria-controls="path-mobile-filters"
      >
        Filtros
        <span aria-hidden="true" class="ml-0.5 opacity-70">▾</span>
        <span
          data-sheet-badge
          hidden
          class="dm-ui-count-badge"
        ></span>
      </button>
    </div>

    <div
      id="path-mobile-filters"
      data-mobile-filters
      hidden
      class="mt-3 rounded border border-white/15 bg-white/5 px-3 py-3"
    >
      <div class="relative mb-4" data-menu="estado" data-estado-mobile>
        <p class="mb-1.5 dm-ui-facet-label text-dm-offwhite/45">
          Ubicación
        </p>
        <button
          type="button"
          data-menu-toggle
          class="flex w-full min-w-0 items-center justify-between gap-2 rounded border border-white/20 bg-white/10 px-3 py-2 text-left text-sm text-dm-offwhite"
          aria-expanded="false"
        >
          <span data-estado-label class="min-w-0 flex-1 truncate">Todo México</span>
          <span class="shrink-0 text-dm-offwhite/50" aria-hidden="true">▾</span>
        </button>
        <div
          data-menu-panel
          hidden
          class="mt-1 max-h-40 overflow-auto rounded border border-black/20 bg-white py-1 text-dm-offblack"
        >
          {
            estados.map((estado) => (
              <label class="flex cursor-pointer items-center gap-2 px-3 py-2 text-sm hover:bg-dm-offwhite">
                <input
                  type="checkbox"
                  data-estado-option
                  value={estado}
                  class="rounded border-dm-offblack/30"
                />
                <span>{estado}</span>
              </label>
            ))
          }
        </div>
      </div>

      <div class="mb-4">
        <p class="mb-1.5 dm-ui-facet-label text-dm-offwhite/45">
          Servicio
        </p>
        <div class="flex flex-wrap gap-2">
          {
            servicios.map((servicio) => (
              <button
                type="button"
                class="filter-chip dm-ui-chip border-white/25 bg-white/10 text-dm-offwhite"
                data-filter-chip
                data-value={servicio}
                aria-pressed="false"
              >
                {servicio}
              </button>
            ))
          }
        </div>
      </div>

      <button
        type="button"
        data-filter-clear
        class="w-full rounded border border-white/20 py-2 text-sm text-dm-offwhite/70 disabled:opacity-40"
        disabled
      >
        Limpiar filtros
      </button>
    </div>
  </div>
</div>

<script>
  type FilterState = {
    q: string;
    servicio: Set<string>;
    estado: Set<string>;
  };

  function parseList(param: string | null): string[] {
    if (!param) return [];
    return param
      .split(",")
      .map((s) => s.trim())
      .filter(Boolean);
  }

  function readUrl(): FilterState {
    const params = new URLSearchParams(window.location.search);
    return {
      q: (params.get("q") || "").trim(),
      servicio: new Set(parseList(params.get("servicio"))),
      estado: new Set(parseList(params.get("estado"))),
    };
  }

  function writeUrl(state: FilterState) {
    const params = new URLSearchParams();
    if (state.q) params.set("q", state.q);
    if (state.servicio.size) params.set("servicio", [...state.servicio].join(","));
    if (state.estado.size) params.set("estado", [...state.estado].join(","));
    const qs = params.toString();
    const path = window.location.pathname;
    const onDirectory =
      path === "/" ||
      path === "/path" ||
      path === "/path/" ||
      path === "/directorio" ||
      path === "/directorio/";
    const targetPath = onDirectory ? path : "/";
    const next = qs ? `${targetPath}?${qs}` : targetPath;
    if (!onDirectory && qs) {
      window.location.assign(next);
      return;
    }
    window.history.replaceState({}, "", next);
  }

  function hasFilters(state: FilterState) {
    return Boolean(state.q || state.servicio.size || state.estado.size);
  }

  function facetCount(state: FilterState) {
    return state.servicio.size + state.estado.size;
  }

  function listLabel(values: string[], empty: string) {
    if (!values.length) return empty;
    return values.join(", ");
  }

  /** Full list when it fits; otherwise show as many names as fit, then +N. */
  function fitLabel(label: HTMLElement, values: string[], empty: string) {
    const full = listLabel(values, empty);
    label.title = values.length ? full : "";
    label.textContent = full;
    if (values.length <= 1) return;
    if (label.scrollWidth <= label.clientWidth + 1) return;

    let lo = 1;
    let hi = values.length - 1;
    let best = 1;
    while (lo <= hi) {
      const mid = (lo + hi) >> 1;
      const remaining = values.length - mid;
      label.textContent = `${values.slice(0, mid).join(", ")} +${remaining}`;
      if (label.scrollWidth <= label.clientWidth + 1) {
        best = mid;
        lo = mid + 1;
      } else {
        hi = mid - 1;
      }
    }
    const remaining = values.length - best;
    label.textContent = `${values.slice(0, best).join(", ")} +${remaining}`;
  }

  function syncEstadoLabels(root: HTMLElement, state: FilterState) {
    const values = [...state.estado];
    root.querySelectorAll<HTMLElement>("[data-estado-label]").forEach((label) => {
      fitLabel(label, values, "Todo México");
    });
  }

  function crumbSep() {
    const sep = document.createElement("span");
    sep.className = "text-dm-offwhite/35";
    sep.setAttribute("aria-hidden", "true");
    sep.textContent = "›";
    return sep;
  }

  function crumbPipe() {
    const sep = document.createElement("span");
    sep.className = "text-dm-offwhite/40";
    sep.setAttribute("aria-hidden", "true");
    sep.textContent = "|";
    return sep;
  }

  function crumbPill(label: string, facet: "estado" | "servicio" | "q", value: string) {
    const wrap = document.createElement("span");
    wrap.className = "active-crumb";
    const text = document.createElement("span");
    text.textContent = label;
    text.title = label;
    const btn = document.createElement("button");
    btn.type = "button";
    btn.dataset.removeFacet = facet;
    btn.dataset.removeValue = value;
    btn.setAttribute("aria-label", `Quitar ${label}`);
    btn.textContent = "×";
    wrap.append(text, btn);
    return wrap;
  }

  function appendCrumbGroup(
    nodes: Node[],
    values: string[],
    facet: "estado" | "servicio",
  ) {
    if (!values.length) return;
    nodes.push(crumbSep());
    values.forEach((value, i) => {
      if (i > 0) nodes.push(crumbPipe());
      nodes.push(crumbPill(value, facet, value));
    });
  }

  function renderActiveCrumbs(state: FilterState) {
    const host = document.querySelector<HTMLElement>("[data-active-crumbs]");
    if (!host) return;
    if (!hasFilters(state)) {
      host.hidden = true;
      host.replaceChildren();
      return;
    }
    host.hidden = false;
    const nodes: Node[] = [];
    appendCrumbGroup(nodes, [...state.estado], "estado");
    appendCrumbGroup(nodes, [...state.servicio], "servicio");
    if (state.q) {
      nodes.push(crumbSep(), crumbPill(`“${state.q}”`, "q", state.q));
    }
    host.replaceChildren(...nodes);
  }

  function shortServicio(values: string[], empty: string) {
    if (!values.length) return empty;
    if (values.length === 1) return values[0];
    if (values.length === 2) return `${values[0]}, ${values[1]}`;
    return `${values[0]} +${values.length - 1}`;
  }

  function matches(card: HTMLElement, state: FilterState) {
    const name = (card.dataset.name || "").toLowerCase();
    const description = (card.dataset.description || "").toLowerCase();
    const estado = card.dataset.estado || "";
    let servicios: string[] = [];
    try {
      servicios = JSON.parse(card.dataset.servicios || "[]");
    } catch {
      servicios = [];
    }

    if (state.q) {
      const q = state.q.toLowerCase();
      if (!name.includes(q) && !description.includes(q)) return false;
    }
    if (state.servicio.size) {
      if (![...state.servicio].some((s) => servicios.includes(s))) return false;
    }
    if (state.estado.size && !state.estado.has(estado)) return false;
    return true;
  }

  function closeMenus(root: HTMLElement) {
    root.querySelectorAll<HTMLElement>("[data-menu-panel]").forEach((p) => {
      p.hidden = true;
    });
    root.querySelectorAll("[data-menu-toggle]").forEach((t) => {
      t.setAttribute("aria-expanded", "false");
    });
  }

  function setMobileFiltersOpen(root: HTMLElement, open: boolean) {
    const panel = root.querySelector<HTMLElement>("[data-mobile-filters]");
    const toggle = root.querySelector<HTMLButtonElement>("[data-mobile-filters-toggle]");
    if (!panel || !toggle) return;
    panel.hidden = !open;
    toggle.setAttribute("aria-expanded", open ? "true" : "false");
    if (!open) closeMenus(root);
  }

  function apply(root: HTMLElement, state: FilterState) {
    const cards = document.querySelectorAll<HTMLElement>("[data-profile-card]");
    let visible = 0;
    cards.forEach((card) => {
      const ok = matches(card, state);
      card.hidden = !ok;
      if (ok) visible += 1;
    });

    root.querySelectorAll<HTMLButtonElement>("[data-filter-chip]").forEach((chip) => {
      const value = chip.dataset.value || "";
      const active = state.servicio.has(value);
      chip.setAttribute("aria-pressed", active ? "true" : "false");
      chip.classList.toggle("dm-ui-chip-active", active);
      chip.classList.toggle("dm-ui-chip", !active);
    });

    root.querySelectorAll<HTMLInputElement>("[data-estado-option]").forEach((box) => {
      box.checked = state.estado.has(box.value);
    });

    syncEstadoLabels(root, state);
    requestAnimationFrame(() => syncEstadoLabels(root, state));
    renderActiveCrumbs(state);

    root.querySelectorAll<HTMLElement>("[data-servicio-label]").forEach((label) => {
      label.textContent = shortServicio([...state.servicio], "Todos los servicios");
    });

    root.querySelectorAll<HTMLInputElement>("[data-filter-q]").forEach((qInput) => {
      if (qInput.value !== state.q) qInput.value = state.q;
    });

    root.querySelectorAll<HTMLButtonElement>("[data-filter-clear]").forEach((btn) => {
      btn.disabled = !hasFilters(state);
    });

    const countText = !cards.length
      ? hasFilters(state)
        ? "—"
        : ""
      : hasFilters(state)
        ? `${visible} de ${cards.length}`
        : `${cards.length}`;
    root.querySelectorAll<HTMLElement>("[data-filter-count-value]").forEach((el) => {
      el.textContent = countText;
    });
    root.querySelectorAll<HTMLElement>("[data-filter-count]").forEach((el) => {
      el.title = cards.length
        ? hasFilters(state)
          ? `${visible} de ${cards.length} perfiles`
          : `${cards.length} perfiles`
        : "";
    });

    const badge = root.querySelector<HTMLElement>("[data-sheet-badge]");
    if (badge) {
      const n = facetCount(state);
      if (n > 0) {
        badge.hidden = false;
        badge.textContent = String(n);
      } else {
        badge.hidden = true;
      }
    }

    const empty = document.querySelector<HTMLElement>("[data-filter-empty]");
    if (empty && cards.length) {
      empty.classList.toggle("hidden", visible > 0);
    }
  }

  function init() {
    const root = document.querySelector<HTMLElement>(".directory-path[data-directory-filter]");
    if (!root) return;

    let state = readUrl();
    apply(root, state);
    closeMenus(root);
    setMobileFiltersOpen(root, false);

    let resizeTimer: number | undefined;
    window.addEventListener("resize", () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => syncEstadoLabels(root, state), 100);
    });

    root.querySelectorAll<HTMLButtonElement>("[data-menu-toggle]").forEach((toggle) => {
      toggle.addEventListener("click", (e) => {
        e.stopPropagation();
        const menu = toggle.closest("[data-menu]");
        const panel = menu?.querySelector<HTMLElement>("[data-menu-panel]");
        if (!panel) return;
        const willOpen = panel.hidden;
        closeMenus(root);
        panel.hidden = !willOpen;
        toggle.setAttribute("aria-expanded", willOpen ? "true" : "false");
      });
    });

    root.querySelectorAll<HTMLInputElement>("[data-filter-q]").forEach((qInput) => {
      let debounce: number | undefined;
      qInput.addEventListener("input", () => {
        window.clearTimeout(debounce);
        debounce = window.setTimeout(() => {
          state = { ...state, q: (qInput.value || "").trim() };
          root.querySelectorAll<HTMLInputElement>("[data-filter-q]").forEach((other) => {
            if (other !== qInput) other.value = qInput.value;
          });
          writeUrl(state);
          apply(root, state);
        }, 150);
      });
    });

    root.querySelectorAll<HTMLButtonElement>("[data-filter-chip]").forEach((chip) => {
      chip.addEventListener("click", (e) => {
        e.stopPropagation();
        const value = chip.dataset.value || "";
        const next = new Set(state.servicio);
        if (next.has(value)) next.delete(value);
        else next.add(value);
        state = { ...state, servicio: next };
        writeUrl(state);
        apply(root, state);
      });
    });

    root.querySelectorAll<HTMLInputElement>("[data-estado-option]").forEach((box) => {
      box.addEventListener("change", () => {
        const next = new Set(state.estado);
        if (box.checked) next.add(box.value);
        else next.delete(box.value);
        root.querySelectorAll<HTMLInputElement>("[data-estado-option]").forEach((other) => {
          if (other.value === box.value) other.checked = box.checked;
        });
        state = { ...state, estado: next };
        writeUrl(state);
        apply(root, state);
      });
    });

    const clear = () => {
      state = { q: "", servicio: new Set(), estado: new Set() };
      writeUrl(state);
      apply(root, state);
      closeMenus(root);
    };

    root.querySelectorAll<HTMLButtonElement>("[data-filter-clear]").forEach((btn) => {
      btn.addEventListener("click", clear);
    });

    document.querySelector<HTMLElement>("[data-active-crumbs]")?.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-remove-facet]");
      if (!btn) return;
      e.stopPropagation();
      const facet = btn.dataset.removeFacet as "estado" | "servicio" | "q";
      const value = btn.dataset.removeValue || "";
      if (facet === "q") {
        state = { ...state, q: "" };
      } else {
        const next = new Set(state[facet]);
        next.delete(value);
        state = { ...state, [facet]: next };
      }
      writeUrl(state);
      apply(root, state);
    });

    document.querySelectorAll<HTMLAnchorElement>("[data-filter-home]").forEach((home) => {
      home.addEventListener("click", (e) => {
        if (!hasFilters(state)) return;
        e.preventDefault();
        clear();
        if (window.location.pathname !== "/") window.location.assign("/");
      });
    });

    const mobileToggle = root.querySelector<HTMLButtonElement>("[data-mobile-filters-toggle]");
    mobileToggle?.addEventListener("click", (e) => {
      e.stopPropagation();
      const panel = root.querySelector<HTMLElement>("[data-mobile-filters]");
      const open = panel?.hidden ?? true;
      setMobileFiltersOpen(root, open);
    });

    document.addEventListener("click", (e) => {
      const target = e.target as Node;
      if (!root.contains(target)) {
        closeMenus(root);
        setMobileFiltersOpen(root, false);
      }
    });
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
