---
/**
 * Option B filter bar — desktop chips; mobile dropdown under search.
 * Taxonomy pages can lock a facet; grid is filled from /api/search (D1).
 */
import { MEXICO_ESTADOS, SERVICIOS } from "../data/taxonomy";

interface Props {
  /** Hide ubicación controls (e.g. on `/estado/[slug]/`). */
  hideEstado?: boolean;
  /** Hide servicio chips (e.g. on `/servicios/[slug]/`). */
  hideServicio?: boolean;
  /** Always include this estado in search (taxonomy lock). */
  lockEstado?: string;
  /** Always include this servicio in search (taxonomy lock). */
  lockServicio?: string;
}

const {
  hideEstado = false,
  hideServicio = false,
  lockEstado,
  lockServicio,
} = Astro.props;

const OUTSIDE_MEXICO = "Fuera de México";
const estadosMexico = MEXICO_ESTADOS.filter((estado) => estado !== OUTSIDE_MEXICO);
const servicios = [...SERVICIOS];
---

  {/* Sentinel: when this leaves the viewport, filter bar sticks under the site header */}
  <div data-filter-sentinel class="pointer-events-none h-px w-full" aria-hidden="true"></div>
<section
  class="directory-filter mb-6"
  data-directory-filter
  data-hide-estado={hideEstado ? "true" : undefined}
  data-hide-servicio={hideServicio ? "true" : undefined}
  data-lock-estado={lockEstado}
  data-lock-servicio={lockServicio}
  aria-label="Filtrar directorio"
>
  <div data-sticky-stack>
    <div class="filter-shell overflow-visible rounded border border-dm-offblack/15 bg-white">
      {/* Top row — always visible */}
      <div class="filter-top flex items-center gap-2 px-3 py-2.5 md:flex-nowrap">
        <label class="filter-search relative min-w-0 flex-1 md:max-w-xs md:flex-none md:w-56">
          <span class="sr-only">Buscar</span>
          <input
            type="search"
            name="q"
            data-filter-q
            placeholder="Buscar…"
            autocomplete="off"
            class="w-full rounded border border-dm-offblack/20 bg-dm-offwhite px-2.5 py-2 text-sm outline-none focus:border-dm-offblack/50 md:py-1.5"
          />
        </label>

      {/* Desktop ubicación — fills remaining width */}
      {
        !hideEstado && (
          <div class="relative hidden min-w-0 flex-1 md:block" data-estado-multi data-estado-desktop>
            <button
              type="button"
              data-estado-toggle
              class="flex w-full min-w-0 items-center gap-2 rounded border border-dm-offblack/20 bg-dm-blue/50 px-3 py-1.5 text-left text-sm text-dm-offblack"
              aria-expanded="false"
            >
              <span class="shrink-0 dm-ui-facet-label"
                >Ubicación</span
              >
              <span data-estado-label class="min-w-0 flex-1 truncate">Sólo México</span>
              <span class="shrink-0 text-dm-offblack/40" aria-hidden="true">▾</span>
            </button>
            <div
              data-estado-panel
              hidden
              class="absolute top-full left-0 z-30 mt-1 w-full min-w-56 rounded border border-dm-offblack/20 bg-white shadow-lg"
            >
              <div class="sticky top-0 border-b border-dm-offblack/10 bg-white p-1.5">
                <input
                  type="text"
                  data-estado-search
                  placeholder="Filtrar por estado…"
                  autocomplete="off"
                  class="w-full rounded border border-dm-offblack/20 bg-dm-offwhite px-2 py-1 text-xs outline-none focus:border-dm-offblack/50"
                />
              </div>
              <div class="max-h-56 overflow-auto py-1" data-estado-options>
                <label
                  data-estado-row
                  data-estado-scope-row
                  class="flex cursor-pointer items-center gap-2 px-2.5 py-1.5 text-xs font-medium hover:bg-dm-offwhite"
                >
                  <input type="checkbox" data-estado-scope value="todas" class="rounded" />
                  <span>Todas las ubicaciones</span>
                </label>
                <label
                  data-estado-row
                  data-estado-scope-row
                  class="flex cursor-pointer items-center gap-2 px-2.5 py-1.5 text-xs font-medium hover:bg-dm-offwhite"
                >
                  <input type="checkbox" data-estado-scope value="mexico" class="rounded" />
                  <span>Sólo México</span>
                </label>
                <div class="my-1 border-t border-dm-offblack/10" data-estado-separator></div>
                <label
                  data-estado-row
                  class="flex cursor-pointer items-center gap-2 px-2.5 py-1.5 text-xs hover:bg-dm-offwhite"
                >
                  <input type="checkbox" data-estado-option value={OUTSIDE_MEXICO} class="rounded" />
                  <span>{OUTSIDE_MEXICO}</span>
                </label>
                <div class="my-1 border-t border-dm-offblack/10" data-estado-separator></div>
                {estadosMexico.map((estado) => (
                  <label
                    data-estado-row
                    class="flex cursor-pointer items-center gap-2 px-2.5 py-1.5 text-xs hover:bg-dm-offwhite"
                  >
                    <input type="checkbox" data-estado-option value={estado} class="rounded" />
                    <span>{estado}</span>
                  </label>
                ))}
                <p
                  data-estado-noresults
                  hidden
                  class="px-2.5 py-2 text-xs text-dm-offblack/45"
                >
                  Sin coincidencias
                </p>
              </div>
            </div>
          </div>
        )
      }

      {/* Count: end of bar, before Limpiar / Filtros */}
      <p
        class="flex shrink-0 items-baseline gap-1.5 md:ml-1"
        data-filter-count
        aria-live="polite"
      >
        <span class="dm-ui-facet-label"
          >Resultados</span
        >
        <span class="text-xs text-dm-offblack/60 tabular-nums" data-filter-count-value></span>
      </p>

      <button
        type="button"
        data-filter-clear
        class="hidden shrink-0 rounded border border-dm-offblack bg-dm-pink px-2 py-1 text-xs text-dm-offblack transition hover:bg-dm-offblack hover:text-white disabled:cursor-not-allowed disabled:border-dm-offblack/20 disabled:bg-transparent disabled:text-dm-offblack/40 disabled:opacity-50 disabled:hover:bg-transparent disabled:hover:text-dm-offblack/40 md:inline"
        disabled
      >
        Limpiar
      </button>

      {/* Mobile: toggle dropdown under search */}
      <button
        type="button"
        data-mobile-filters-toggle
        class="relative shrink-0 rounded border border-dm-offblack/25 bg-dm-offblack px-3 py-2 text-sm text-dm-offwhite md:hidden"
        aria-expanded="false"
        aria-controls="mobile-filters-dropdown"
      >
        Filtros
        <span aria-hidden="true" class="ml-0.5 opacity-70">▾</span>
        <span
          data-sheet-badge
          hidden
          class="absolute -top-1.5 -right-1.5 flex h-5 min-w-5 items-center justify-center rounded-full bg-dm-pink px-1 text-[10px] font-bold text-dm-offblack"
        ></span>
      </button>
    </div>

    {/* Mobile dropdown — expands under the search row */}
    <div
      id="mobile-filters-dropdown"
      data-mobile-filters
      hidden
      class="border-t border-dm-offblack/10 px-3 py-3 md:hidden"
    >
      {
        !hideEstado && (
          <div class="relative mb-4" data-estado-multi data-estado-mobile>
            <p class="mb-1.5 text-xs font-semibold tracking-wide text-dm-offblack/50 uppercase">
              Ubicación
            </p>
            <button
              type="button"
              data-estado-toggle
              class="flex w-full items-center justify-between rounded border border-dm-offblack/20 bg-dm-blue/40 px-3 py-2 text-left text-sm"
              aria-expanded="false"
            >
              <span data-estado-label class="min-w-0 flex-1 truncate">Sólo México</span>
              <span class="text-dm-offblack/40" aria-hidden="true">▾</span>
            </button>
            <div
              data-estado-panel
              hidden
              class="mt-1 rounded border border-dm-offblack/20 bg-white"
            >
              <div class="sticky top-0 border-b border-dm-offblack/10 bg-white p-1.5">
                <input
                  type="text"
                  data-estado-search
                  placeholder="Filtrar por estado…"
                  autocomplete="off"
                  class="w-full rounded border border-dm-offblack/20 bg-dm-offwhite px-2.5 py-2 text-sm outline-none focus:border-dm-offblack/50"
                />
              </div>
              <div class="max-h-40 overflow-auto py-1" data-estado-options>
                <label
                  data-estado-row
                  data-estado-scope-row
                  class="flex cursor-pointer items-center gap-2 px-3 py-2 text-sm font-medium hover:bg-dm-offwhite"
                >
                  <input type="checkbox" data-estado-scope value="todas" class="rounded" />
                  <span>Todas las ubicaciones</span>
                </label>
                <label
                  data-estado-row
                  data-estado-scope-row
                  class="flex cursor-pointer items-center gap-2 px-3 py-2 text-sm font-medium hover:bg-dm-offwhite"
                >
                  <input type="checkbox" data-estado-scope value="mexico" class="rounded" />
                  <span>Sólo México</span>
                </label>
                <div class="my-1 border-t border-dm-offblack/10" data-estado-separator></div>
                <label
                  data-estado-row
                  class="flex cursor-pointer items-center gap-2 px-3 py-2 text-sm hover:bg-dm-offwhite"
                >
                  <input type="checkbox" data-estado-option value={OUTSIDE_MEXICO} class="rounded" />
                  <span>{OUTSIDE_MEXICO}</span>
                </label>
                <div class="my-1 border-t border-dm-offblack/10" data-estado-separator></div>
                {estadosMexico.map((estado) => (
                  <label
                    data-estado-row
                    class="flex cursor-pointer items-center gap-2 px-3 py-2 text-sm hover:bg-dm-offwhite"
                  >
                    <input type="checkbox" data-estado-option value={estado} class="rounded" />
                    <span>{estado}</span>
                  </label>
                ))}
                <p
                  data-estado-noresults
                  hidden
                  class="px-3 py-2 text-sm text-dm-offblack/45"
                >
                  Sin coincidencias
                </p>
              </div>
            </div>
          </div>
        )
      }

      {
        !hideServicio && (
          <div class="mb-4">
            <p class="mb-1.5 text-xs font-semibold tracking-wide text-dm-offblack/50 uppercase">
              Servicio
            </p>
            <div class="flex flex-wrap gap-2">
              {servicios.map((servicio) => (
                <button
                  type="button"
                  class="filter-chip rounded border border-dm-offblack/25 bg-white px-3 py-1.5 text-sm text-dm-offblack"
                  data-filter-chip
                  data-value={servicio}
                  aria-pressed="false"
                >
                  {servicio}
                </button>
              ))}
            </div>
          </div>
        )
      }

      <button
        type="button"
        data-filter-clear
        class="w-full rounded border border-dm-offblack bg-dm-pink py-2 text-sm text-dm-offblack transition hover:bg-dm-offblack hover:text-white disabled:cursor-not-allowed disabled:border-dm-offblack/20 disabled:bg-transparent disabled:text-dm-offblack/40 disabled:opacity-50 disabled:hover:bg-transparent disabled:hover:text-dm-offblack/40"
        disabled
      >
        Limpiar filtros
      </button>
    </div>

    {/* Desktop: servicio chips */}
    {
      !hideServicio && (
        <div class="hidden border-t border-dm-offblack/10 px-3 py-3 md:block">
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-xs font-semibold tracking-wide text-dm-offblack/50 uppercase"
              >Servicio</span
            >
            <div class="flex flex-wrap gap-1.5">
              {servicios.map((servicio) => (
                <button
                  type="button"
                  class="filter-chip rounded border border-dm-offblack/25 bg-white px-2.5 py-1 text-sm text-dm-offblack hover:border-dm-offblack"
                  data-filter-chip
                  data-value={servicio}
                  aria-pressed="false"
                >
                  {servicio}
                </button>
              ))}
            </div>
          </div>
        </div>
      )
    }
  </div>
  </div>
</section>

<style>
  .filter-chip[aria-pressed="true"] {
    background-color: var(--color-dm-offblack);
    color: var(--color-dm-offwhite);
    border-color: var(--color-dm-offblack);
  }

  :global(.active-crumb) {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    max-width: 11rem;
    font-weight: 500;
  }
  :global(.active-crumb span) {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  :global(.active-crumb button) {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 1.2rem;
    height: 1.2rem;
    border-radius: 9999px;
    line-height: 1;
    font-size: 0.65rem;
    opacity: 0.85;
  }

  /*
   * Collapsed (scroll): filter sticks flush under the always-sticky site header.
   * --dm-site-header-h is kept in sync via ResizeObserver (compact anim included).
   */
  .directory-filter[data-collapsed] {
    position: sticky;
    top: calc(var(--dm-site-header-h, 3.25rem) - 1px);
    z-index: 40;
    margin-left: calc(-1 * var(--dm-page-px));
    margin-right: calc(-1 * var(--dm-page-px));
    background-color: #fff;
  }
  .directory-filter[data-collapsed] [data-sticky-stack] {
    display: flex;
    flex-direction: column;
  }
  /* Desktop sticky: edge-to-edge; controls stay on page column */
  @media (min-width: 768px) {
    .directory-filter[data-collapsed] {
      width: 100vw;
      max-width: 100vw;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
    }
    .directory-filter[data-collapsed] .filter-top,
    .directory-filter[data-collapsed] .filter-shell > .border-t {
      max-width: var(--max-width-dm-page);
      margin-inline: auto;
      width: 100%;
    }
  }
  .filter-shell {
    transition: border-radius 0.2s ease;
  }
  .directory-filter[data-collapsed] .filter-shell {
    border-radius: 0;
    border-left: none;
    border-right: none;
    border-top: none;
    width: 100%;
    margin-inline: 0;
    background-color: #fff;
  }
  .directory-filter[data-collapsed] .filter-top,
  .directory-filter[data-collapsed] [data-mobile-filters],
  .directory-filter[data-collapsed] .filter-shell > .border-t {
    padding-left: var(--dm-page-px);
    padding-right: var(--dm-page-px);
  }
  .directory-filter[data-collapsed] .filter-search {
    flex: 1 1 auto;
    min-width: 0;
  }
  @media (max-width: 767px) {
    .directory-filter[data-collapsed] .filter-search {
      max-width: none;
    }
    .directory-filter[data-collapsed] [data-filter-count] {
      display: none;
    }
  }
</style>

<script>
  import { LOCATION_ALIASES } from "../data/locationAliases";
  import { MEXICO_ESTADOS } from "../data/taxonomy";
  import { filterProfiles, type SearchableProfile } from "../lib/search";
  import { renderProfileCardHtml } from "../lib/renderProfileCard";
  import { injectDirectoryThemes } from "../lib/profileTheme";

  const OUTSIDE_MEXICO = "Fuera de México";
  const ALL_LOCATIONS = "todas";
  const ALL_LOCATIONS_LABEL = "Todas las ubicaciones";
  const MEXICO_SCOPE = "mexico";
  const MEXICO_SCOPE_LABEL = "Sólo México";
  const MEXICO_ONLY_ESTADOS = MEXICO_ESTADOS.filter((estado) => estado !== OUTSIDE_MEXICO);

  type FilterState = {
    q: string;
    servicio: Set<string>;
    estado: Set<string>;
  };

  function isAllLocations(estado: Set<string>) {
    return estado.has(ALL_LOCATIONS);
  }

  function isMexicoScope(estado: Set<string>) {
    return estado.size === 0;
  }

  function selectedEstados(estado: Set<string>) {
    return [...estado].filter((value) => value !== ALL_LOCATIONS);
  }

  function parseList(param: string | null): string[] {
    if (!param) return [];
    return param
      .split(",")
      .map((s) => s.trim())
      .filter(Boolean);
  }

  function readUrl(): FilterState {
    const params = new URLSearchParams(window.location.search);
    const rawEstado = parseList(params.get("estado"));
    const estado = new Set<string>();
    if (rawEstado.includes(ALL_LOCATIONS) || rawEstado.includes(ALL_LOCATIONS_LABEL)) {
      estado.add(ALL_LOCATIONS);
    } else {
      rawEstado.forEach((value) => estado.add(value));
    }
    return {
      q: (params.get("q") || "").trim(),
      servicio: new Set(parseList(params.get("servicio"))),
      estado,
    };
  }

  function writeUrl(state: FilterState) {
    const params = new URLSearchParams();
    if (state.q) params.set("q", state.q);
    if (state.servicio.size) params.set("servicio", [...state.servicio].join(","));
    if (isAllLocations(state.estado)) params.set("estado", ALL_LOCATIONS);
    else if (state.estado.size) params.set("estado", [...state.estado].join(","));
    const qs = params.toString();
    window.history.replaceState(
      {},
      "",
      qs ? `${window.location.pathname}?${qs}` : window.location.pathname,
    );
  }

  function hasFilters(state: FilterState, root: HTMLElement) {
    const hideEstado = root.dataset.hideEstado === "true";
    const hideServicio = root.dataset.hideServicio === "true";
    if (state.q) return true;
    if (!hideServicio && state.servicio.size) return true;
    if (!hideEstado && state.estado.size) return true;
    return false;
  }

  /** True when results are narrowed below the default México view (not "all locations"). */
  function hasNarrowingFilters(state: FilterState, root: HTMLElement) {
    if (isAllLocations(state.estado)) return Boolean(state.q || state.servicio.size);
    return hasFilters(state, root);
  }

  function facetCount(state: FilterState, root: HTMLElement) {
    const hideEstado = root.dataset.hideEstado === "true";
    const hideServicio = root.dataset.hideServicio === "true";
    let n = 0;
    if (!hideServicio) n += state.servicio.size;
    if (!hideEstado) {
      if (isAllLocations(state.estado)) n += 1;
      else n += state.estado.size;
    }
    return n;
  }

  function estadoListLabel(values: string[], empty: string) {
    if (!values.length) return empty;
    if (values.includes(ALL_LOCATIONS)) return ALL_LOCATIONS_LABEL;
    return values.join(", ");
  }

  /** Full list when it fits; otherwise show as many names as fit, then +N. */
  function fitEstadoLabel(label: HTMLElement, values: string[], empty: string) {
    const full = estadoListLabel(values, empty);
    label.title = values.length ? full : "";
    label.textContent = full;
    if (values.length <= 1 || values.includes(ALL_LOCATIONS)) return;
    if (label.scrollWidth <= label.clientWidth + 1) return;

    let lo = 1;
    let hi = values.length - 1;
    let best = 1;
    while (lo <= hi) {
      const mid = (lo + hi) >> 1;
      const remaining = values.length - mid;
      label.textContent = `${values.slice(0, mid).join(", ")} +${remaining}`;
      if (label.scrollWidth <= label.clientWidth + 1) {
        best = mid;
        lo = mid + 1;
      } else {
        hi = mid - 1;
      }
    }
    const remaining = values.length - best;
    label.textContent = `${values.slice(0, best).join(", ")} +${remaining}`;
  }

  function syncEstadoLabels(root: HTMLElement, state: FilterState) {
    const values = [...state.estado];
    root.querySelectorAll<HTMLElement>("[data-estado-label]").forEach((label) => {
      fitEstadoLabel(label, values, "Sólo México");
    });
  }

  function crumbSep(light: boolean) {
    const sep = document.createElement("span");
    sep.className = light ? "text-dm-offblack/35" : "text-dm-offwhite/35";
    sep.setAttribute("aria-hidden", "true");
    sep.textContent = "›";
    return sep;
  }

  function crumbPipe(light: boolean) {
    const sep = document.createElement("span");
    sep.className = light ? "text-dm-offblack/40" : "text-dm-offwhite/40";
    sep.setAttribute("aria-hidden", "true");
    sep.textContent = "|";
    return sep;
  }

  function crumbPill(
    label: string,
    facet: "estado" | "servicio" | "q",
    value: string,
    light: boolean,
  ) {
    const wrap = document.createElement("span");
    wrap.className = light ? "active-crumb active-crumb--light" : "active-crumb";
    const text = document.createElement("span");
    text.textContent = label;
    text.title = label;
    const btn = document.createElement("button");
    btn.type = "button";
    btn.dataset.removeFacet = facet;
    btn.dataset.removeValue = value;
    btn.setAttribute("aria-label", `Quitar ${label}`);
    btn.textContent = "×";
    wrap.append(text, btn);
    return wrap;
  }

  function appendCrumbGroup(
    nodes: Node[],
    values: string[],
    facet: "estado" | "servicio",
    light: boolean,
  ) {
    if (!values.length) return;
    nodes.push(crumbSep(light));
    if (facet === "estado" && values.includes(ALL_LOCATIONS)) {
      nodes.push(crumbPill(ALL_LOCATIONS_LABEL, facet, ALL_LOCATIONS, light));
      return;
    }
    values.forEach((value, i) => {
      if (i > 0) nodes.push(crumbPipe(light));
      nodes.push(crumbPill(value, facet, value, light));
    });
  }

  function syncSiteTagline(show: boolean) {
    document.querySelectorAll<HTMLElement>("[data-site-tagline]").forEach((el) => {
      el.hidden = !show;
    });
  }

  /** True only when a header crumb trail is rendered and visible (mobile only; desktop uses md:hidden). */
  function hasVisibleHeaderCrumbs(): boolean {
    return [...document.querySelectorAll<HTMLElement>("[data-active-crumbs]")].some((host) => {
      if (host.hidden || host.childElementCount === 0) return false;
      return host.getClientRects().length > 0;
    });
  }

  function syncSiteTaglineFromCrumbs() {
    syncSiteTagline(!hasVisibleHeaderCrumbs());
  }

  function renderActiveCrumbs(state: FilterState, root: HTMLElement) {
    const hideEstado = root.dataset.hideEstado === "true";
    const hideServicio = root.dataset.hideServicio === "true";
    document.querySelectorAll<HTMLElement>("[data-active-crumbs]").forEach((host) => {
      const light = host.dataset.crumbsTheme === "light";
      const crumbState: FilterState = {
        q: state.q,
        servicio: hideServicio ? new Set() : state.servicio,
        estado: hideEstado ? new Set() : state.estado,
      };
      if (!hasFilters(crumbState, root)) {
        host.hidden = true;
        host.replaceChildren();
        return;
      }
      host.hidden = false;
      const nodes: Node[] = [];
      appendCrumbGroup(nodes, [...crumbState.estado], "estado", light);
      appendCrumbGroup(nodes, [...crumbState.servicio], "servicio", light);
      if (crumbState.q) {
        nodes.push(crumbSep(light), crumbPill(`“${crumbState.q}”`, "q", crumbState.q, light));
      }
      host.replaceChildren(...nodes);
    });
    syncSiteTaglineFromCrumbs();
  }

  /** User wants the mobile filters panel open (survives scroll-down auto-hide). */
  let mobileFiltersWanted = false;
  /** Ignore scroll hide/restore briefly after panel open/close (layout shift). */
  let ignoreMobileFiltersScrollUntil = 0;
  let filterBarCleanup: AbortController | null = null;
  let filterBarHeaderRo: ResizeObserver | null = null;

  function setMobileFiltersOpen(
    root: HTMLElement,
    open: boolean,
    opts?: { fromUser?: boolean },
  ) {
    const panel = root.querySelector<HTMLElement>("[data-mobile-filters]");
    const toggle = root.querySelector<HTMLButtonElement>("[data-mobile-filters-toggle]");
    if (!panel || !toggle) return;
    const nextHidden = !open;
    if (panel.hidden !== nextHidden) {
      // Opening/closing changes sticky height and can synthesize scroll events.
      ignoreMobileFiltersScrollUntil = performance.now() + 450;
    }
    panel.hidden = nextHidden;
    toggle.setAttribute("aria-expanded", open ? "true" : "false");
    if (opts?.fromUser) mobileFiltersWanted = open;
  }

  function uiState(state: FilterState, root: HTMLElement): FilterState {
    return {
      q: state.q,
      servicio: root.dataset.hideServicio === "true" ? new Set() : state.servicio,
      estado: root.dataset.hideEstado === "true" ? new Set() : state.estado,
    };
  }

  /** Search query includes taxonomy locks so the grid matches D1/API. */
  function queryState(state: FilterState, root: HTMLElement): FilterState {
    const servicio = new Set(state.servicio);
    const estado = new Set(selectedEstados(state.estado));
    const lockServicio = root.dataset.lockServicio;
    const lockEstado = root.dataset.lockEstado;
    if (lockServicio) servicio.add(lockServicio);
    if (lockEstado) estado.add(lockEstado);
    // Default empty = México only. Explicit "todas" = no estado filter (world).
    if (
      root.dataset.hideEstado !== "true" &&
      !lockEstado &&
      estado.size === 0 &&
      !isAllLocations(state.estado)
    ) {
      MEXICO_ONLY_ESTADOS.forEach((mexicoEstado) => estado.add(mexicoEstado));
    }
    return { q: state.q, servicio, estado };
  }

  function buildSearchParams(state: FilterState) {
    const params = new URLSearchParams();
    if (state.q) params.set("q", state.q);
    if (state.servicio.size) params.set("servicio", [...state.servicio].join(","));
    if (state.estado.size) params.set("estado", [...state.estado].join(","));
    return params;
  }

  function paintChrome(root: HTMLElement, state: FilterState, effective: FilterState) {
    root.querySelectorAll<HTMLButtonElement>("[data-filter-chip]").forEach((chip) => {
      chip.setAttribute(
        "aria-pressed",
        effective.servicio.has(chip.dataset.value || "") ? "true" : "false",
      );
    });
    const allOn = isAllLocations(effective.estado);
    const mexicoOn = isMexicoScope(effective.estado);
    root.querySelectorAll<HTMLInputElement>("[data-estado-scope]").forEach((box) => {
      if (box.value === ALL_LOCATIONS) box.checked = allOn;
      else if (box.value === MEXICO_SCOPE) box.checked = mexicoOn;
    });
    root.querySelectorAll<HTMLInputElement>("[data-estado-option]").forEach((box) => {
      box.checked = !allOn && !mexicoOn && effective.estado.has(box.value);
    });
    syncEstadoLabels(root, effective);
    requestAnimationFrame(() => syncEstadoLabels(root, effective));
    renderActiveCrumbs(effective, root);

    const qInput = root.querySelector<HTMLInputElement>("[data-filter-q]");
    if (qInput && qInput.value !== state.q) qInput.value = state.q;

    root.querySelectorAll<HTMLButtonElement>("[data-filter-clear]").forEach((btn) => {
      btn.disabled = !hasFilters(effective, root);
    });

    const badge = root.querySelector<HTMLElement>("[data-sheet-badge]");
    if (badge) {
      const n = facetCount(effective, root);
      if (n > 0) {
        badge.hidden = false;
        badge.textContent = String(n);
      } else {
        badge.hidden = true;
      }
    }
  }

  function paintCounts(root: HTMLElement, effective: FilterState, visible: number, total: number) {
    const narrowed = hasNarrowingFilters(effective, root);
    const countText = narrowed ? `${visible} de ${total}` : `${visible}`;
    const countEl = root.querySelector<HTMLElement>("[data-filter-count]");
    const countValue = root.querySelector<HTMLElement>("[data-filter-count-value]");
    if (countValue) countValue.textContent = countText;
    if (countEl) {
      countEl.title = narrowed ? `${visible} de ${total} perfiles` : `${visible} perfiles`;
    }
    const empty = document.querySelector<HTMLElement>("[data-filter-empty]");
    if (empty) {
      const showEmpty = visible === 0;
      empty.classList.toggle("hidden", !showEmpty);
      if (showEmpty) {
        empty.textContent = hasFilters(effective, root)
          ? "No hay perfiles con esos filtros."
          : "No hay perfiles en el directorio.";
      }
    }
  }

  function paintGrid(results: SearchableProfile[]) {
    const grid = document.querySelector<HTMLElement>("[data-profile-grid]");
    if (!grid) return;
    grid.innerHTML = results.map((profile) => renderProfileCardHtml(profile)).join("");
    injectDirectoryThemes(results);
  }

  async function loadResults(root: HTMLElement, state: FilterState): Promise<SearchableProfile[]> {
    const q = queryState(state, root);
    const searchQuery = {
      q: q.q,
      servicio: [...q.servicio],
      estado: [...q.estado],
    };

    try {
      const res = await fetch(`/api/search?${buildSearchParams(q)}`);
      if (!res.ok) throw new Error(`search ${res.status}`);
      const data = (await res.json()) as {
        ok?: boolean;
        results?: SearchableProfile[];
      };
      if (!data.ok || !Array.isArray(data.results)) throw new Error("bad search payload");
      return data.results;
    } catch {
      const res = await fetch("/data/profiles.json");
      if (!res.ok) throw new Error("profiles.json unavailable");
      const profiles = (await res.json()) as SearchableProfile[];
      return filterProfiles(profiles, searchQuery);
    }
  }

  let applySeq = 0;
  let catalogTotal = 0;
  /** Slug order for this page load — random once, stable while filtering. */
  let sessionOrder: string[] | null = null;

  function shuffleProfiles(items: SearchableProfile[]): SearchableProfile[] {
    const next = [...items];
    for (let i = next.length - 1; i > 0; i -= 1) {
      const j = Math.floor(Math.random() * (i + 1));
      const tmp = next[i]!;
      next[i] = next[j]!;
      next[j] = tmp;
    }
    return next;
  }

  function orderForSession(results: SearchableProfile[], reshuffle: boolean): SearchableProfile[] {
    if (reshuffle || !sessionOrder) {
      const shuffled = shuffleProfiles(results);
      sessionOrder = shuffled.map((p) => p.slug);
      return shuffled;
    }
    const rank = new Map(sessionOrder.map((slug, i) => [slug, i]));
    return [...results].sort(
      (a, b) =>
        (rank.get(a.slug) ?? Number.MAX_SAFE_INTEGER) -
        (rank.get(b.slug) ?? Number.MAX_SAFE_INTEGER),
    );
  }

  async function apply(root: HTMLElement, state: FilterState) {
    const effective = uiState(state, root);
    paintChrome(root, state, effective);

    const seq = ++applySeq;
    try {
      const raw = await loadResults(root, state);
      if (seq !== applySeq) return;
      const narrowed = hasNarrowingFilters(effective, root);
      if (!narrowed) catalogTotal = raw.length;
      const results = orderForSession(raw, sessionOrder === null);
      paintGrid(results);
      paintCounts(root, effective, results.length, catalogTotal || results.length);
    } catch {
      if (seq !== applySeq) return;
      paintGrid([]);
      paintCounts(root, effective, 0, catalogTotal);
    }
  }

  function init() {
    const root = document.querySelector<HTMLElement>(".directory-filter[data-directory-filter]");
    if (!root) return;

    // astro:page-load also fires on first load — drop prior listeners so clicks don't multi-toggle.
    filterBarCleanup?.abort();
    filterBarCleanup = new AbortController();
    const { signal } = filterBarCleanup;
    filterBarHeaderRo?.disconnect();
    filterBarHeaderRo = null;

    const stack = root.querySelector<HTMLElement>("[data-sticky-stack]");
    const siteHeader = document.querySelector<HTMLElement>("[data-site-header]");
    const sentinel = document.querySelector("[data-filter-sentinel]");

    const syncSiteHeaderHeight = () => {
      if (!siteHeader) {
        document.documentElement.style.setProperty("--dm-site-header-h", "52px");
        return;
      }
      // Floor so sticky top never sits below the visible header (avoids the desktop gap).
      const h = Math.max(1, Math.floor(siteHeader.getBoundingClientRect().height));
      document.documentElement.style.setProperty("--dm-site-header-h", `${h}px`);
    };

    const setCollapsed = (collapsed: boolean) => {
      const wasCollapsed = root.hasAttribute("data-collapsed");
      if (collapsed === wasCollapsed) return;

      root.toggleAttribute("data-collapsed", collapsed);
      siteHeader?.toggleAttribute("data-compact", collapsed);
      // Measure after compact styles apply (and again on the next frame during transitions).
      syncSiteHeaderHeight();
      requestAnimationFrame(() => {
        syncSiteHeaderHeight();
        requestAnimationFrame(syncSiteHeaderHeight);
      });

      if (collapsed && stack && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        stack.animate(
          [
            { transform: "translateY(-0.35rem)", opacity: 0.85 },
            { transform: "translateY(0)", opacity: 1 },
          ],
          { duration: 160, easing: "ease-out" },
        );
      }
    };

    /**
     * Stick/unstick from live geometry — not a one-shot IntersectionObserver rootMargin.
     * A fixed rootMargin captured at init uses the *expanded* header height; after
     * data-compact shrinks the bar, that margin stays too large and the sentinel can
     * never re-intersect when scrolling back to the top (header stays compact).
     */
    const syncCollapsedFromScroll = () => {
      if (!sentinel) return;
      const headerBottom = siteHeader
        ? Math.floor(siteHeader.getBoundingClientRect().bottom)
        : 52;
      const sentinelTop = sentinel.getBoundingClientRect().top;
      // Collapse once the sentinel scrolls up under (or past) the sticky header.
      setCollapsed(sentinelTop < headerBottom - 1);
    };

    /** Hide open mobile filters on scroll-down; restore on scroll-up if still wanted. */
    const SCROLL_DIR_THRESHOLD = 40;
    let lastScrollY = window.scrollY;
    let scrollAccum = 0;
    const isMobileFiltersViewport = () => window.matchMedia("(max-width: 767px)").matches;

    const syncMobileFiltersFromScroll = () => {
      if (performance.now() < ignoreMobileFiltersScrollUntil) {
        lastScrollY = window.scrollY;
        scrollAccum = 0;
        return;
      }
      if (!isMobileFiltersViewport() || !mobileFiltersWanted) {
        lastScrollY = window.scrollY;
        scrollAccum = 0;
        return;
      }
      const y = window.scrollY;
      const dy = y - lastScrollY;
      lastScrollY = y;
      if (dy === 0) return;
      if ((scrollAccum > 0 && dy < 0) || (scrollAccum < 0 && dy > 0)) {
        scrollAccum = 0;
      }
      scrollAccum += dy;
      if (scrollAccum >= SCROLL_DIR_THRESHOLD) {
        scrollAccum = 0;
        const panel = root.querySelector<HTMLElement>("[data-mobile-filters]");
        if (panel && !panel.hidden) setMobileFiltersOpen(root, false);
      } else if (scrollAccum <= -SCROLL_DIR_THRESHOLD) {
        scrollAccum = 0;
        const panel = root.querySelector<HTMLElement>("[data-mobile-filters]");
        if (panel && panel.hidden) setMobileFiltersOpen(root, true);
      }
    };

    const onScroll = () => {
      syncCollapsedFromScroll();
      syncMobileFiltersFromScroll();
    };

    syncSiteHeaderHeight();
    if (siteHeader && typeof ResizeObserver !== "undefined") {
      const headerRo = new ResizeObserver(() => {
        syncSiteHeaderHeight();
        // Compact height changes shift the threshold; re-evaluate stick state.
        syncCollapsedFromScroll();
      });
      headerRo.observe(siteHeader);
      filterBarHeaderRo = headerRo;
      signal.addEventListener("abort", () => headerRo.disconnect());
    }

    if (sentinel) syncCollapsedFromScroll();
    window.addEventListener("scroll", onScroll, { passive: true, signal });

    let state = readUrl();
    if (root.dataset.hideEstado === "true") state = { ...state, estado: new Set() };
    if (root.dataset.hideServicio === "true") state = { ...state, servicio: new Set() };
    apply(root, state);
    setMobileFiltersOpen(root, false, { fromUser: true });

    let resizeTimer: number | undefined;
    window.addEventListener(
      "resize",
      () => {
        window.clearTimeout(resizeTimer);
        resizeTimer = window.setTimeout(() => {
          syncSiteHeaderHeight();
          syncCollapsedFromScroll();
          syncEstadoLabels(root, state);
          syncSiteTaglineFromCrumbs();
        }, 100);
      },
      { signal },
    );

    const normalizeText = (s: string) =>
      s
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .toLowerCase();

    const normalizedLocationAliases = Object.entries(LOCATION_ALIASES).map(([alias, estado]) => ({
      alias: normalizeText(alias),
      estado,
    }));

    root.querySelectorAll<HTMLElement>("[data-estado-multi]").forEach((wrap) => {
      const toggle = wrap.querySelector<HTMLButtonElement>("[data-estado-toggle]");
      const panel = wrap.querySelector<HTMLElement>("[data-estado-panel]");
      const search = wrap.querySelector<HTMLInputElement>("[data-estado-search]");
      const rows = Array.from(wrap.querySelectorAll<HTMLElement>("[data-estado-row]"));
      const separators = Array.from(wrap.querySelectorAll<HTMLElement>("[data-estado-separator]"));
      const noResults = wrap.querySelector<HTMLElement>("[data-estado-noresults]");

      const runSearch = () => {
        const q = normalizeText((search?.value || "").trim());
        const aliasEstados = new Set<string>(
          q
            ? normalizedLocationAliases
                .filter(({ alias }) => alias.includes(q))
                .map(({ estado }) => estado)
            : [],
        );
        let visible = 0;
        let scopeVisible = false;
        let outsideVisible = false;
        let mexicoVisible = false;
        rows.forEach((row) => {
          const scopeBox = row.querySelector<HTMLInputElement>("[data-estado-scope]");
          const opt = row.querySelector<HTMLInputElement>("[data-estado-option]");
          const name = scopeBox
            ? scopeBox.value === ALL_LOCATIONS
              ? ALL_LOCATIONS_LABEL
              : MEXICO_SCOPE_LABEL
            : opt?.value || "";
          const match = !q || normalizeText(name).includes(q) || aliasEstados.has(name);
          row.hidden = !match;
          if (match) {
            visible += 1;
            if (scopeBox) scopeVisible = true;
            else if (name === OUTSIDE_MEXICO) outsideVisible = true;
            else mexicoVisible = true;
          }
        });
        separators.forEach((separator, index) => {
          // First separator after the scope pair; second between Fuera and states.
          if (index === 0) separator.hidden = !(scopeVisible && (outsideVisible || mexicoVisible));
          else separator.hidden = !(outsideVisible && mexicoVisible);
        });
        if (noResults) noResults.hidden = visible > 0;
      };

      search?.addEventListener("input", runSearch, { signal });

      toggle?.addEventListener(
        "click",
        (e) => {
          e.stopPropagation();
          if (!panel || !toggle) return;
          const willOpen = panel.hidden;
          root.querySelectorAll<HTMLElement>("[data-estado-panel]").forEach((p) => {
            p.hidden = true;
          });
          root.querySelectorAll("[data-estado-toggle]").forEach((t) => {
            t.setAttribute("aria-expanded", "false");
          });
          panel.hidden = !willOpen;
          toggle.setAttribute("aria-expanded", willOpen ? "true" : "false");
          if (willOpen && search) {
            if (search.value) {
              search.value = "";
              runSearch();
            }
            requestAnimationFrame(() => search.focus());
          }
        },
        { signal },
      );
    });

    const qInput = root.querySelector<HTMLInputElement>("[data-filter-q]");
    let debounce: number | undefined;
    qInput?.addEventListener(
      "input",
      () => {
        window.clearTimeout(debounce);
        debounce = window.setTimeout(() => {
          state = { ...state, q: (qInput.value || "").trim() };
          writeUrl(state);
          apply(root, state);
        }, 150);
      },
      { signal },
    );

    root.querySelectorAll<HTMLButtonElement>("[data-filter-chip]").forEach((chip) => {
      chip.addEventListener(
        "click",
        () => {
          const value = chip.dataset.value || "";
          const next = new Set(state.servicio);
          if (next.has(value)) next.delete(value);
          else next.add(value);
          state = { ...state, servicio: next };
          writeUrl(state);
          apply(root, state);
        },
        { signal },
      );
    });

    root.querySelectorAll<HTMLInputElement>("[data-estado-scope]").forEach((box) => {
      box.addEventListener(
        "change",
        () => {
          // Presets are exclusive: picking one turns the other off and clears state checkboxes.
          const next =
            box.value === ALL_LOCATIONS
              ? new Set([ALL_LOCATIONS])
              : new Set<string>(); // Sólo México = empty (default)
          // Keep the chosen scope checked even if user tries to uncheck it.
          root.querySelectorAll<HTMLInputElement>("[data-estado-scope]").forEach((other) => {
            other.checked = other.value === box.value;
          });
          root.querySelectorAll<HTMLInputElement>("[data-estado-option]").forEach((other) => {
            other.checked = false;
          });
          state = { ...state, estado: next };
          writeUrl(state);
          apply(root, state);
        },
        { signal },
      );
    });

    root.querySelectorAll<HTMLInputElement>("[data-estado-option]").forEach((box) => {
      box.addEventListener(
        "change",
        () => {
          const next = new Set(selectedEstados(state.estado));
          if (box.checked) next.add(box.value);
          else next.delete(box.value);
          root.querySelectorAll<HTMLInputElement>("[data-estado-scope]").forEach((other) => {
            other.checked = false;
          });
          root.querySelectorAll<HTMLInputElement>("[data-estado-option]").forEach((other) => {
            if (other.value === box.value) other.checked = box.checked;
          });
          state = { ...state, estado: next };
          writeUrl(state);
          apply(root, state);
        },
        { signal },
      );
    });

    root.querySelectorAll<HTMLButtonElement>("[data-filter-clear]").forEach((btn) => {
      btn.addEventListener(
        "click",
        () => {
          state = { q: "", servicio: new Set(), estado: new Set() };
          writeUrl(state);
          apply(root, state);
          root.querySelectorAll<HTMLElement>("[data-estado-panel]").forEach((p) => {
            p.hidden = true;
          });
        },
        { signal },
      );
    });

    document.querySelectorAll<HTMLElement>("[data-active-crumbs]").forEach((host) => {
      host.addEventListener(
        "click",
        (e) => {
          const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-remove-facet]");
          if (!btn) return;
          e.stopPropagation();
          const facet = btn.dataset.removeFacet as "estado" | "servicio" | "q";
          const value = btn.dataset.removeValue || "";
          if (facet === "q") {
            state = { ...state, q: "" };
          } else {
            const next = new Set(state[facet]);
            next.delete(value);
            state = { ...state, [facet]: next };
          }
          writeUrl(state);
          apply(root, state);
        },
        { signal },
      );
    });

    document.querySelectorAll<HTMLAnchorElement>("[data-filter-home]").forEach((home) => {
      home.addEventListener(
        "click",
        (e) => {
          if (!hasFilters(state, root)) return;
          e.preventDefault();
          state = { q: "", servicio: new Set(), estado: new Set() };
          writeUrl(state);
          apply(root, state);
        },
        { signal },
      );
    });

    const mobileToggle = root.querySelector<HTMLButtonElement>("[data-mobile-filters-toggle]");
    mobileToggle?.addEventListener(
      "click",
      (e) => {
        e.stopPropagation();
        const panel = root.querySelector<HTMLElement>("[data-mobile-filters]");
        const willOpen = panel?.hidden ?? true;
        setMobileFiltersOpen(root, willOpen, { fromUser: true });
      },
      { signal },
    );

    document.addEventListener(
      "click",
      (e) => {
        const target = e.target as Node;
        if (!root.contains(target)) {
          setMobileFiltersOpen(root, false, { fromUser: true });
        }
        root.querySelectorAll<HTMLElement>("[data-estado-multi]").forEach((wrap) => {
          const panel = wrap.querySelector<HTMLElement>("[data-estado-panel]");
          if (panel && !wrap.contains(target)) panel.hidden = true;
        });
      },
      { signal },
    );
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
