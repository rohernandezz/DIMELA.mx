---
/**
 * Option B filter bar — desktop chips; mobile dropdown under search.
 */
import { MEXICO_ESTADOS, SERVICIOS } from "../data/taxonomy";

const estados = [...MEXICO_ESTADOS];
const servicios = [...SERVICIOS];
---

<section
  class="directory-filter mb-6 md:relative"
  data-directory-filter
  aria-label="Filtrar directorio"
>
  {/* On mobile, the real <header> is moved here so grey bar + search stick as one unit */}
  <div data-sticky-stack class="md:contents">
    <div class="filter-shell overflow-visible rounded border border-dm-offblack/15 bg-white md:rounded md:border">
      {/* Top row — always visible */}
      <div class="filter-top flex items-center gap-2 px-3 py-2.5 md:flex-nowrap">
        <label class="filter-search relative min-w-0 flex-1 md:max-w-xs md:flex-none md:w-56">
          <span class="sr-only">Buscar</span>
          <input
            type="search"
            name="q"
            data-filter-q
            placeholder="Buscar…"
            autocomplete="off"
            class="w-full rounded border border-dm-offblack/20 bg-dm-offwhite px-2.5 py-2 text-sm outline-none focus:border-dm-offblack/50 md:py-1.5"
          />
        </label>

      {/* Desktop ubicación — fills remaining width */}
      <div class="relative hidden min-w-0 flex-1 md:block" data-estado-multi data-estado-desktop>
        <button
          type="button"
          data-estado-toggle
          class="flex w-full min-w-0 items-center gap-2 rounded border border-dm-offblack/20 bg-dm-blue/50 px-3 py-1.5 text-left text-sm text-dm-offblack"
          aria-expanded="false"
        >
          <span class="shrink-0 text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase"
            >Ubicación</span
          >
          <span data-estado-label class="min-w-0 flex-1 truncate">Todo México</span>
          <span class="shrink-0 text-dm-offblack/40" aria-hidden="true">▾</span>
        </button>
        <div
          data-estado-panel
          hidden
          class="absolute top-full left-0 z-30 mt-1 max-h-64 w-full min-w-56 overflow-auto rounded border border-dm-offblack/20 bg-white py-1 shadow-lg"
        >
          {
            estados.map((estado) => (
              <label class="flex cursor-pointer items-center gap-2 px-2.5 py-1.5 text-xs hover:bg-dm-offwhite">
                <input type="checkbox" data-estado-option value={estado} class="rounded" />
                <span>{estado}</span>
              </label>
            ))
          }
        </div>
      </div>

      {/* Count: end of bar, before Limpiar / Filtros */}
      <p
        class="flex shrink-0 items-baseline gap-1.5 md:ml-1"
        data-filter-count
        aria-live="polite"
      >
        <span class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase"
          >Resultados</span
        >
        <span class="text-xs text-dm-offblack/60 tabular-nums" data-filter-count-value></span>
      </p>

      <button
        type="button"
        data-filter-clear
        class="hidden shrink-0 rounded border border-dm-offblack/20 px-2 py-1 text-xs text-dm-offblack/60 hover:bg-dm-offblack hover:text-white disabled:opacity-40 md:inline"
        disabled
      >
        Limpiar
      </button>

      {/* Mobile: toggle dropdown under search */}
      <button
        type="button"
        data-mobile-filters-toggle
        class="relative shrink-0 rounded border border-dm-offblack/25 bg-dm-offblack px-3 py-2 text-sm text-dm-offwhite md:hidden"
        aria-expanded="false"
        aria-controls="mobile-filters-dropdown"
      >
        Filtros
        <span aria-hidden="true" class="ml-0.5 opacity-70">▾</span>
        <span
          data-sheet-badge
          hidden
          class="absolute -top-1.5 -right-1.5 flex h-5 min-w-5 items-center justify-center rounded-full bg-dm-pink px-1 text-[10px] font-bold text-dm-offblack"
        ></span>
      </button>
    </div>

    {/* Mobile dropdown — expands under the search row */}
    <div
      id="mobile-filters-dropdown"
      data-mobile-filters
      hidden
      class="border-t border-dm-offblack/10 px-3 py-3 md:hidden"
    >
      <div class="relative mb-4" data-estado-multi data-estado-mobile>
        <p class="mb-1.5 text-xs font-semibold tracking-wide text-dm-offblack/50 uppercase">
          Ubicación
        </p>
        <button
          type="button"
          data-estado-toggle
          class="flex w-full items-center justify-between rounded border border-dm-offblack/20 bg-dm-blue/40 px-3 py-2 text-left text-sm"
          aria-expanded="false"
        >
          <span data-estado-label class="min-w-0 flex-1 truncate">Todo México</span>
          <span class="text-dm-offblack/40" aria-hidden="true">▾</span>
        </button>
        <div
          data-estado-panel
          hidden
          class="mt-1 max-h-40 overflow-auto rounded border border-dm-offblack/20 bg-white py-1"
        >
          {
            estados.map((estado) => (
              <label class="flex cursor-pointer items-center gap-2 px-3 py-2 text-sm hover:bg-dm-offwhite">
                <input type="checkbox" data-estado-option value={estado} class="rounded" />
                <span>{estado}</span>
              </label>
            ))
          }
        </div>
      </div>

      <div class="mb-4">
        <p class="mb-1.5 text-xs font-semibold tracking-wide text-dm-offblack/50 uppercase">
          Servicio
        </p>
        <div class="flex flex-wrap gap-2">
          {
            servicios.map((servicio) => (
              <button
                type="button"
                class="filter-chip rounded border border-dm-offblack/25 bg-white px-3 py-1.5 text-sm text-dm-offblack"
                data-filter-chip
                data-value={servicio}
                aria-pressed="false"
              >
                {servicio}
              </button>
            ))
          }
        </div>
      </div>

      <button
        type="button"
        data-filter-clear
        class="w-full rounded border border-dm-offblack/20 py-2 text-sm text-dm-offblack/70 disabled:opacity-40"
        disabled
      >
        Limpiar filtros
      </button>
    </div>

    {/* Desktop: servicio chips */}
    <div class="hidden border-t border-dm-offblack/10 px-3 py-3 md:block">
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-xs font-semibold tracking-wide text-dm-offblack/50 uppercase"
          >Servicio</span
        >
        <div class="flex flex-wrap gap-1.5">
          {
            servicios.map((servicio) => (
              <button
                type="button"
                class="filter-chip rounded border border-dm-offblack/25 bg-white px-2.5 py-1 text-sm text-dm-offblack hover:border-dm-offblack"
                data-filter-chip
                data-value={servicio}
                aria-pressed="false"
              >
                {servicio}
              </button>
            ))
          }
        </div>
      </div>
    </div>
  </div>
  </div>
</section>

<style>
  .filter-chip[aria-pressed="true"] {
    background-color: var(--color-dm-offblack);
    color: var(--color-dm-offwhite);
    border-color: var(--color-dm-offblack);
  }

  :global(.active-crumb) {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    max-width: 11rem;
    font-weight: 500;
  }
  :global(.active-crumb span) {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  :global(.active-crumb button) {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 1.2rem;
    height: 1.2rem;
    border-radius: 9999px;
    line-height: 1;
    font-size: 0.65rem;
    opacity: 0.85;
  }

  /*
   * Mobile: grey header + search are one sticky stack (same header element).
   * Break out of main padding only (not 100vw) so logo aligns with cards.
   */
  @media (max-width: 767px) {
    .directory-filter[data-mobile-stack] {
      position: sticky;
      top: 0;
      z-index: 40;
      margin-left: calc(-1 * var(--dm-page-px));
      margin-right: calc(-1 * var(--dm-page-px));
      margin-top: -1.5rem; /* cancel main py-6 top */
      margin-bottom: 1.5rem;
      background-color: var(--color-dm-offwhite);
    }
    .directory-filter[data-mobile-stack] [data-sticky-stack] {
      display: flex;
      flex-direction: column;
    }
    .directory-filter[data-mobile-stack] header [data-header-inner] {
      max-width: none;
      margin-inline: 0;
      padding-left: var(--dm-page-px);
      padding-right: var(--dm-page-px);
    }
    .directory-filter[data-mobile-stack] .filter-shell {
      border-radius: 0;
      border-left: none;
      border-right: none;
      border-top: none;
      width: 100%;
      margin-inline: 0;
      background-color: #fff;
    }
    .directory-filter[data-mobile-stack] .filter-top,
    .directory-filter[data-mobile-stack] [data-mobile-filters] {
      padding-left: var(--dm-page-px);
      padding-right: var(--dm-page-px);
    }
    .directory-filter[data-mobile-stack] .filter-search {
      flex: 1 1 auto;
      min-width: 0;
      max-width: none;
    }
    .directory-filter[data-mobile-stack] [data-filter-count] {
      display: none;
    }
  }
</style>

<script>
  type FilterState = {
    q: string;
    servicio: Set<string>;
    estado: Set<string>;
  };

  function parseList(param: string | null): string[] {
    if (!param) return [];
    return param
      .split(",")
      .map((s) => s.trim())
      .filter(Boolean);
  }

  function readUrl(): FilterState {
    const params = new URLSearchParams(window.location.search);
    return {
      q: (params.get("q") || "").trim(),
      servicio: new Set(parseList(params.get("servicio"))),
      estado: new Set(parseList(params.get("estado"))),
    };
  }

  function writeUrl(state: FilterState) {
    const params = new URLSearchParams();
    if (state.q) params.set("q", state.q);
    if (state.servicio.size) params.set("servicio", [...state.servicio].join(","));
    if (state.estado.size) params.set("estado", [...state.estado].join(","));
    const qs = params.toString();
    window.history.replaceState(
      {},
      "",
      qs ? `${window.location.pathname}?${qs}` : window.location.pathname,
    );
  }

  function hasFilters(state: FilterState) {
    return Boolean(state.q || state.servicio.size || state.estado.size);
  }

  function facetCount(state: FilterState) {
    return state.servicio.size + state.estado.size;
  }

  function estadoListLabel(values: string[], empty: string) {
    if (!values.length) return empty;
    return values.join(", ");
  }

  /** Full list when it fits; otherwise show as many names as fit, then +N. */
  function fitEstadoLabel(label: HTMLElement, values: string[], empty: string) {
    const full = estadoListLabel(values, empty);
    label.title = values.length ? full : "";
    label.textContent = full;
    if (values.length <= 1) return;
    if (label.scrollWidth <= label.clientWidth + 1) return;

    let lo = 1;
    let hi = values.length - 1;
    let best = 1;
    while (lo <= hi) {
      const mid = (lo + hi) >> 1;
      const remaining = values.length - mid;
      label.textContent = `${values.slice(0, mid).join(", ")} +${remaining}`;
      if (label.scrollWidth <= label.clientWidth + 1) {
        best = mid;
        lo = mid + 1;
      } else {
        hi = mid - 1;
      }
    }
    const remaining = values.length - best;
    label.textContent = `${values.slice(0, best).join(", ")} +${remaining}`;
  }

  function syncEstadoLabels(root: HTMLElement, state: FilterState) {
    const values = [...state.estado];
    root.querySelectorAll<HTMLElement>("[data-estado-label]").forEach((label) => {
      fitEstadoLabel(label, values, "Todo México");
    });
  }

  function crumbSep(light: boolean) {
    const sep = document.createElement("span");
    sep.className = light ? "text-dm-offblack/35" : "text-dm-offwhite/35";
    sep.setAttribute("aria-hidden", "true");
    sep.textContent = "›";
    return sep;
  }

  function crumbPipe(light: boolean) {
    const sep = document.createElement("span");
    sep.className = light ? "text-dm-offblack/40" : "text-dm-offwhite/40";
    sep.setAttribute("aria-hidden", "true");
    sep.textContent = "|";
    return sep;
  }

  function crumbPill(
    label: string,
    facet: "estado" | "servicio" | "q",
    value: string,
    light: boolean,
  ) {
    const wrap = document.createElement("span");
    wrap.className = light ? "active-crumb active-crumb--light" : "active-crumb";
    const text = document.createElement("span");
    text.textContent = label;
    text.title = label;
    const btn = document.createElement("button");
    btn.type = "button";
    btn.dataset.removeFacet = facet;
    btn.dataset.removeValue = value;
    btn.setAttribute("aria-label", `Quitar ${label}`);
    btn.textContent = "×";
    wrap.append(text, btn);
    return wrap;
  }

  function appendCrumbGroup(
    nodes: Node[],
    values: string[],
    facet: "estado" | "servicio",
    light: boolean,
  ) {
    if (!values.length) return;
    nodes.push(crumbSep(light));
    values.forEach((value, i) => {
      if (i > 0) nodes.push(crumbPipe(light));
      nodes.push(crumbPill(value, facet, value, light));
    });
  }

  function renderActiveCrumbs(state: FilterState) {
    document.querySelectorAll<HTMLElement>("[data-active-crumbs]").forEach((host) => {
      const light = host.dataset.crumbsTheme === "light";
      if (!hasFilters(state)) {
        host.hidden = true;
        host.replaceChildren();
        return;
      }
      host.hidden = false;
      const nodes: Node[] = [];
      appendCrumbGroup(nodes, [...state.estado], "estado", light);
      appendCrumbGroup(nodes, [...state.servicio], "servicio", light);
      if (state.q) {
        nodes.push(crumbSep(light), crumbPill(`“${state.q}”`, "q", state.q, light));
      }
      host.replaceChildren(...nodes);
    });
  }

  function matches(card: HTMLElement, state: FilterState) {
    const name = (card.dataset.name || "").toLowerCase();
    const description = (card.dataset.description || "").toLowerCase();
    const estado = card.dataset.estado || "";
    let servicios: string[] = [];
    try {
      servicios = JSON.parse(card.dataset.servicios || "[]");
    } catch {
      servicios = [];
    }
    if (state.q) {
      const q = state.q.toLowerCase();
      if (!name.includes(q) && !description.includes(q)) return false;
    }
    if (state.servicio.size && ![...state.servicio].some((s) => servicios.includes(s)))
      return false;
    if (state.estado.size && !state.estado.has(estado)) return false;
    return true;
  }

  function setMobileFiltersOpen(root: HTMLElement, open: boolean) {
    const panel = root.querySelector<HTMLElement>("[data-mobile-filters]");
    const toggle = root.querySelector<HTMLButtonElement>("[data-mobile-filters-toggle]");
    if (!panel || !toggle) return;
    panel.hidden = !open;
    toggle.setAttribute("aria-expanded", open ? "true" : "false");
  }

  function apply(root: HTMLElement, state: FilterState) {
    const cards = document.querySelectorAll<HTMLElement>("[data-profile-card]");
    let visible = 0;
    cards.forEach((card) => {
      const ok = matches(card, state);
      card.hidden = !ok;
      if (ok) visible += 1;
    });

    root.querySelectorAll<HTMLButtonElement>("[data-filter-chip]").forEach((chip) => {
      chip.setAttribute(
        "aria-pressed",
        state.servicio.has(chip.dataset.value || "") ? "true" : "false",
      );
    });
    root.querySelectorAll<HTMLInputElement>("[data-estado-option]").forEach((box) => {
      box.checked = state.estado.has(box.value);
    });
    syncEstadoLabels(root, state);
    // Remeasure after layout so we only abbreviate when the full list overflows.
    requestAnimationFrame(() => syncEstadoLabels(root, state));
    renderActiveCrumbs(state);

    const qInput = root.querySelector<HTMLInputElement>("[data-filter-q]");
    if (qInput && qInput.value !== state.q) qInput.value = state.q;

    root.querySelectorAll<HTMLButtonElement>("[data-filter-clear]").forEach((btn) => {
      btn.disabled = !hasFilters(state);
    });

    const countText = hasFilters(state)
      ? `${visible} de ${cards.length}`
      : `${cards.length}`;
    const countEl = root.querySelector<HTMLElement>("[data-filter-count]");
    const countValue = root.querySelector<HTMLElement>("[data-filter-count-value]");
    if (countValue) countValue.textContent = countText;
    if (countEl) {
      countEl.title = hasFilters(state)
        ? `${visible} de ${cards.length} perfiles`
        : `${cards.length} perfiles`;
    }

    const badge = root.querySelector<HTMLElement>("[data-sheet-badge]");
    if (badge) {
      const n = facetCount(state);
      if (n > 0) {
        badge.hidden = false;
        badge.textContent = String(n);
      } else {
        badge.hidden = true;
      }
    }

    const empty = document.querySelector<HTMLElement>("[data-filter-empty]");
    if (empty) empty.classList.toggle("hidden", visible > 0 || !cards.length);
  }

  function init() {
    const root = document.querySelector<HTMLElement>(".directory-filter[data-directory-filter]");
    if (!root) return;

    const mobileMq = window.matchMedia("(max-width: 767px)");
    const stack = root.querySelector<HTMLElement>("[data-sticky-stack]");
    const main = document.querySelector("main");

    const placeHeader = () => {
      const header = document.querySelector<HTMLElement>("header");
      if (!header || !stack || !main) return;
      if (mobileMq.matches) {
        root.setAttribute("data-mobile-stack", "");
        if (header.parentElement !== stack) {
          stack.prepend(header);
        }
      } else {
        root.removeAttribute("data-mobile-stack");
        if (header.parentElement === stack) {
          main.parentElement?.insertBefore(header, main);
        }
      }
    };

    placeHeader();
    mobileMq.addEventListener("change", placeHeader);

    let state = readUrl();
    apply(root, state);
    setMobileFiltersOpen(root, false);

    let resizeTimer: number | undefined;
    window.addEventListener("resize", () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => syncEstadoLabels(root, state), 100);
    });

    root.querySelectorAll<HTMLElement>("[data-estado-multi]").forEach((wrap) => {
      const toggle = wrap.querySelector<HTMLButtonElement>("[data-estado-toggle]");
      const panel = wrap.querySelector<HTMLElement>("[data-estado-panel]");
      toggle?.addEventListener("click", (e) => {
        e.stopPropagation();
        if (!panel || !toggle) return;
        const willOpen = panel.hidden;
        root.querySelectorAll<HTMLElement>("[data-estado-panel]").forEach((p) => {
          p.hidden = true;
        });
        root.querySelectorAll("[data-estado-toggle]").forEach((t) => {
          t.setAttribute("aria-expanded", "false");
        });
        panel.hidden = !willOpen;
        toggle.setAttribute("aria-expanded", willOpen ? "true" : "false");
      });
    });

    const qInput = root.querySelector<HTMLInputElement>("[data-filter-q]");
    let debounce: number | undefined;
    qInput?.addEventListener("input", () => {
      window.clearTimeout(debounce);
      debounce = window.setTimeout(() => {
        state = { ...state, q: (qInput.value || "").trim() };
        writeUrl(state);
        apply(root, state);
      }, 150);
    });

    root.querySelectorAll<HTMLButtonElement>("[data-filter-chip]").forEach((chip) => {
      chip.addEventListener("click", () => {
        const value = chip.dataset.value || "";
        const next = new Set(state.servicio);
        if (next.has(value)) next.delete(value);
        else next.add(value);
        state = { ...state, servicio: next };
        writeUrl(state);
        apply(root, state);
      });
    });

    root.querySelectorAll<HTMLInputElement>("[data-estado-option]").forEach((box) => {
      box.addEventListener("change", () => {
        const next = new Set(state.estado);
        if (box.checked) next.add(box.value);
        else next.delete(box.value);
        root.querySelectorAll<HTMLInputElement>("[data-estado-option]").forEach((other) => {
          if (other.value === box.value) other.checked = box.checked;
        });
        state = { ...state, estado: next };
        writeUrl(state);
        apply(root, state);
      });
    });

    root.querySelectorAll<HTMLButtonElement>("[data-filter-clear]").forEach((btn) => {
      btn.addEventListener("click", () => {
        state = { q: "", servicio: new Set(), estado: new Set() };
        writeUrl(state);
        apply(root, state);
        root.querySelectorAll<HTMLElement>("[data-estado-panel]").forEach((p) => {
          p.hidden = true;
        });
      });
    });

    document.querySelectorAll<HTMLElement>("[data-active-crumbs]").forEach((host) => {
      host.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-remove-facet]");
        if (!btn) return;
        e.stopPropagation();
        const facet = btn.dataset.removeFacet as "estado" | "servicio" | "q";
        const value = btn.dataset.removeValue || "";
        if (facet === "q") {
          state = { ...state, q: "" };
        } else {
          const next = new Set(state[facet]);
          next.delete(value);
          state = { ...state, [facet]: next };
        }
        writeUrl(state);
        apply(root, state);
      });
    });

    document.querySelectorAll<HTMLAnchorElement>("[data-filter-home]").forEach((home) => {
      home.addEventListener("click", (e) => {
        if (!hasFilters(state)) return;
        e.preventDefault();
        state = { q: "", servicio: new Set(), estado: new Set() };
        writeUrl(state);
        apply(root, state);
      });
    });

    const mobileToggle = root.querySelector<HTMLButtonElement>("[data-mobile-filters-toggle]");
    mobileToggle?.addEventListener("click", (e) => {
      e.stopPropagation();
      const panel = root.querySelector<HTMLElement>("[data-mobile-filters]");
      const open = panel?.hidden ?? true;
      setMobileFiltersOpen(root, open);
    });

    document.addEventListener("click", (e) => {
      const target = e.target as Node;
      if (!root.contains(target)) {
        setMobileFiltersOpen(root, false);
      }
      root.querySelectorAll<HTMLElement>("[data-estado-multi]").forEach((wrap) => {
        const panel = wrap.querySelector<HTMLElement>("[data-estado-panel]");
        if (panel && !wrap.contains(target)) panel.hidden = true;
      });
    });
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
