---
/**
 * DirectoryFilterBar — compact mock.
 * Servicios: chips. Estados: multi-select dropdown (OR within facet).
 * URL: ?q=&servicio=&estado=CDMX,Puebla
 */
interface Props {
  servicios: string[];
  estados: string[];
}

const { servicios, estados } = Astro.props;
---

<section
  class="directory-filter mb-6 rounded border border-dm-offblack/15 bg-white px-3 py-2.5"
  data-directory-filter
  aria-label="Filtrar directorio"
>
  <div class="flex flex-wrap items-center gap-2">
    <label class="relative w-full max-w-xs sm:w-64">
      <span class="sr-only">Buscar</span>
      <input
        type="search"
        name="q"
        data-filter-q
        placeholder="Buscar…"
        autocomplete="off"
        class="w-full rounded border border-dm-offblack/20 bg-dm-offwhite px-2.5 py-1.5 text-sm text-dm-offblack outline-none placeholder:text-dm-offblack/40 focus:border-dm-offblack/50"
      />
    </label>

    <div class="relative" data-estado-multi>
      <button
        type="button"
        data-estado-toggle
        class="flex max-w-[14rem] items-center gap-1 rounded border border-dm-offblack/20 bg-dm-blue/50 px-2 py-1 text-left text-[11px] text-dm-offblack"
        aria-expanded="false"
        aria-haspopup="listbox"
      >
        <span class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase"
          >Ubicación</span
        >
        <span data-estado-label class="truncate font-normal">Todo México</span>
        <span aria-hidden="true" class="text-dm-offblack/40">▾</span>
      </button>
      <div
        data-estado-panel
        hidden
        class="absolute top-full left-0 z-30 mt-1 max-h-64 w-56 overflow-auto rounded border border-dm-offblack/20 bg-white py-1 shadow-lg"
        role="listbox"
        aria-multiselectable="true"
      >
        {
          estados.map((estado) => (
            <label class="flex cursor-pointer items-center gap-2 px-2.5 py-1 text-xs text-dm-offblack hover:bg-dm-offwhite">
              <input
                type="checkbox"
                data-estado-option
                value={estado}
                class="rounded border-dm-offblack/30"
              />
              <span>{estado}</span>
            </label>
          ))
        }
      </div>
    </div>

    <p class="text-xs text-dm-offblack/50" data-filter-count aria-live="polite"></p>
    <button
      type="button"
      data-filter-clear
      class="ml-auto shrink-0 rounded border border-dm-offblack/20 px-2 py-1 text-xs text-dm-offblack/60 hover:bg-dm-offblack hover:text-dm-offwhite disabled:cursor-default disabled:opacity-40 sm:ml-0"
      disabled
    >
      Limpiar
    </button>
  </div>

  <div class="mt-2 flex flex-wrap items-center gap-1.5">
    <span class="shrink-0 text-xs font-semibold tracking-wide text-dm-offblack/50 uppercase">
      Servicio
    </span>
    <div class="flex flex-wrap gap-1.5" role="group" aria-label="Filtrar por servicio">
      {
        servicios.map((servicio) => (
          <button
            type="button"
            class="filter-chip rounded border border-dm-offblack/25 bg-white px-2.5 py-1 text-sm leading-tight text-dm-offblack transition hover:border-dm-offblack"
            data-filter-chip
            data-facet="servicio"
            data-value={servicio}
            aria-pressed="false"
          >
            {servicio}
          </button>
        ))
      }
    </div>
  </div>
</section>

<style>
  .filter-chip[aria-pressed="true"] {
    background-color: var(--color-dm-offblack);
    color: var(--color-dm-offwhite);
    border-color: var(--color-dm-offblack);
  }
</style>

<script>
  type FilterState = {
    q: string;
    servicio: Set<string>;
    estado: Set<string>;
  };

  function parseList(param: string | null): string[] {
    if (!param) return [];
    return param
      .split(",")
      .map((s) => s.trim())
      .filter(Boolean);
  }

  function readUrl(): FilterState {
    const params = new URLSearchParams(window.location.search);
    return {
      q: (params.get("q") || "").trim(),
      servicio: new Set(parseList(params.get("servicio"))),
      estado: new Set(parseList(params.get("estado"))),
    };
  }

  function writeUrl(state: FilterState) {
    const params = new URLSearchParams();
    if (state.q) params.set("q", state.q);
    if (state.servicio.size) params.set("servicio", [...state.servicio].join(","));
    if (state.estado.size) params.set("estado", [...state.estado].join(","));
    const qs = params.toString();
    const next = qs ? `${window.location.pathname}?${qs}` : window.location.pathname;
    window.history.replaceState({}, "", next);
  }

  function hasFilters(state: FilterState) {
    return Boolean(state.q || state.servicio.size || state.estado.size);
  }

  function estadoLabel(state: FilterState) {
    if (!state.estado.size) return "Todo México";
    const list = [...state.estado];
    if (list.length === 1) return list[0];
    if (list.length === 2) return `${list[0]}, ${list[1]}`;
    return `${list[0]} +${list.length - 1}`;
  }

  function matches(card: HTMLElement, state: FilterState) {
    const name = (card.dataset.name || "").toLowerCase();
    const description = (card.dataset.description || "").toLowerCase();
    const estado = card.dataset.estado || "";
    let servicios: string[] = [];
    try {
      servicios = JSON.parse(card.dataset.servicios || "[]");
    } catch {
      servicios = [];
    }

    if (state.q) {
      const q = state.q.toLowerCase();
      if (!name.includes(q) && !description.includes(q)) return false;
    }

    if (state.servicio.size) {
      const hit = [...state.servicio].some((s) => servicios.includes(s));
      if (!hit) return false;
    }

    // OR within estados
    if (state.estado.size && !state.estado.has(estado)) return false;

    return true;
  }

  function apply(root: HTMLElement, state: FilterState) {
    const cards = document.querySelectorAll<HTMLElement>("[data-profile-card]");
    let visible = 0;
    cards.forEach((card) => {
      const ok = matches(card, state);
      card.hidden = !ok;
      if (ok) visible += 1;
    });

    root.querySelectorAll<HTMLButtonElement>("[data-filter-chip]").forEach((chip) => {
      const value = chip.dataset.value || "";
      chip.setAttribute("aria-pressed", state.servicio.has(value) ? "true" : "false");
    });

    root.querySelectorAll<HTMLInputElement>("[data-estado-option]").forEach((box) => {
      box.checked = state.estado.has(box.value);
    });

    const label = root.querySelector<HTMLElement>("[data-estado-label]");
    if (label) label.textContent = estadoLabel(state);

    const qInput = root.querySelector<HTMLInputElement>("[data-filter-q]");
    if (qInput && qInput.value !== state.q) qInput.value = state.q;

    const clearBtn = root.querySelector<HTMLButtonElement>("[data-filter-clear]");
    if (clearBtn) clearBtn.disabled = !hasFilters(state);

    const countEl = root.querySelector<HTMLElement>("[data-filter-count]");
    if (countEl) {
      const total = cards.length;
      countEl.textContent = hasFilters(state)
        ? `${visible} de ${total} perfiles`
        : `${total} perfiles`;
    }
  }

  function setEstadoOpen(root: HTMLElement, open: boolean) {
    const panel = root.querySelector<HTMLElement>("[data-estado-panel]");
    const toggle = root.querySelector<HTMLButtonElement>("[data-estado-toggle]");
    if (!panel || !toggle) return;
    panel.hidden = !open;
    toggle.setAttribute("aria-expanded", open ? "true" : "false");
  }

  function init() {
    const root = document.querySelector<HTMLElement>("[data-directory-filter]");
    if (!root) return;

    let state = readUrl();
    apply(root, state);
    setEstadoOpen(root, false);

    const qInput = root.querySelector<HTMLInputElement>("[data-filter-q]");
    let debounce: number | undefined;
    qInput?.addEventListener("input", () => {
      window.clearTimeout(debounce);
      debounce = window.setTimeout(() => {
        state = { ...state, q: (qInput.value || "").trim() };
        writeUrl(state);
        apply(root, state);
      }, 150);
    });

    root.querySelectorAll<HTMLButtonElement>("[data-filter-chip]").forEach((chip) => {
      chip.addEventListener("click", () => {
        const value = chip.dataset.value || "";
        const next = new Set(state.servicio);
        if (next.has(value)) next.delete(value);
        else next.add(value);
        state = { ...state, servicio: next };
        writeUrl(state);
        apply(root, state);
      });
    });

    root.querySelector<HTMLButtonElement>("[data-estado-toggle]")?.addEventListener("click", (e) => {
      e.stopPropagation();
      const toggle = e.currentTarget as HTMLButtonElement;
      const open = toggle.getAttribute("aria-expanded") === "true";
      setEstadoOpen(root, !open);
    });

    root.querySelectorAll<HTMLInputElement>("[data-estado-option]").forEach((box) => {
      box.addEventListener("change", () => {
        const next = new Set(state.estado);
        if (box.checked) next.add(box.value);
        else next.delete(box.value);
        state = { ...state, estado: next };
        writeUrl(state);
        apply(root, state);
      });
    });

    root.querySelector<HTMLButtonElement>("[data-filter-clear]")?.addEventListener("click", () => {
      state = { q: "", servicio: new Set(), estado: new Set() };
      writeUrl(state);
      apply(root, state);
      setEstadoOpen(root, false);
    });

    document.addEventListener("click", (e) => {
      const wrap = root.querySelector("[data-estado-multi]");
      if (wrap && !wrap.contains(e.target as Node)) setEstadoOpen(root, false);
    });
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
