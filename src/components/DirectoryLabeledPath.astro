---
/**
 * Labeled path in the dark header:
 * DIMELA › Ubicación: CDMX ▾ › Servicio: Lettering ▾
 */
import { MEXICO_ESTADOS, SERVICIOS } from "../data/taxonomy";

const estados = [...MEXICO_ESTADOS];
const servicios = [...SERVICIOS];
---

<div
  class="directory-labeled flex min-w-0 flex-1 flex-wrap items-center gap-x-1.5 gap-y-2 text-sm"
  data-directory-filter
  aria-label="Filtrar directorio"
>
  <a
    href="/labeled/"
    data-filter-home
    class="shrink-0 text-base tracking-wide text-dm-offwhite hover:opacity-80"
  >
    DIMELA.mx
  </a>

  <span class="text-dm-offwhite/35" aria-hidden="true">›</span>

  <div class="relative flex items-center gap-1" data-menu="estado">
    <span class="text-[10px] font-semibold tracking-wide text-dm-offwhite/45 uppercase"
      >Ubicación:</span
    >
    <button
      type="button"
      data-menu-toggle
      class="flex max-w-[12rem] items-center gap-1 rounded px-1.5 py-0.5 text-dm-offwhite hover:bg-white/10"
      aria-expanded="false"
    >
      <span data-estado-label class="truncate">Todo México</span>
      <span class="text-dm-offwhite/50" aria-hidden="true">▾</span>
    </button>
    <div
      data-menu-panel
      hidden
      class="absolute top-full left-0 z-40 mt-1 max-h-64 w-56 overflow-auto rounded border border-black/20 bg-white py-1 text-dm-offblack shadow-lg"
    >
      {
        estados.map((estado) => (
          <label class="flex cursor-pointer items-center gap-2 px-2.5 py-1.5 text-xs hover:bg-dm-offwhite">
            <input type="checkbox" data-estado-option value={estado} class="rounded" />
            <span>{estado}</span>
          </label>
        ))
      }
    </div>
  </div>

  <span class="text-dm-offwhite/35" aria-hidden="true">›</span>

  <div class="relative flex items-center gap-1" data-menu="servicio">
    <span class="text-[10px] font-semibold tracking-wide text-dm-offwhite/45 uppercase"
      >Servicio:</span
    >
    <button
      type="button"
      data-menu-toggle
      class="flex max-w-[14rem] items-center gap-1 rounded px-1.5 py-0.5 text-dm-offwhite hover:bg-white/10"
      aria-expanded="false"
    >
      <span data-servicio-label class="truncate">Todos</span>
      <span class="text-dm-offwhite/50" aria-hidden="true">▾</span>
    </button>
    <div
      data-menu-panel
      hidden
      class="absolute top-full left-0 z-40 mt-1 w-[min(100vw-2rem,22rem)] rounded border border-black/20 bg-white p-3 text-dm-offblack shadow-lg"
    >
      <div class="flex flex-wrap gap-2">
        {
          servicios.map((servicio) => (
            <button
              type="button"
              class="filter-chip rounded border border-dm-offblack/25 bg-dm-offwhite px-3 py-1.5 text-sm"
              data-filter-chip
              data-value={servicio}
              aria-pressed="false"
            >
              {servicio}
            </button>
          ))
        }
      </div>
    </div>
  </div>

  <label class="relative ml-1 w-full max-w-[11rem] sm:w-40">
    <span class="sr-only">Buscar</span>
    <input
      type="search"
      data-filter-q
      placeholder="Buscar…"
      autocomplete="off"
      class="w-full rounded border border-white/20 bg-white/10 px-2 py-1 text-sm text-dm-offwhite outline-none placeholder:text-dm-offwhite/40 focus:border-white/40"
    />
  </label>

  <p class="text-xs text-dm-offwhite/45" data-filter-count aria-live="polite"></p>
  <button
    type="button"
    data-filter-clear
    class="rounded border border-white/20 px-2 py-0.5 text-xs text-dm-offwhite/70 hover:bg-white/10 disabled:opacity-30"
    disabled
  >
    Limpiar
  </button>
</div>

<style>
  .filter-chip[aria-pressed="true"] {
    background-color: var(--color-dm-offblack);
    color: var(--color-dm-offwhite);
    border-color: var(--color-dm-offblack);
  }
</style>

<script>
  type FilterState = { q: string; servicio: Set<string>; estado: Set<string> };

  function parseList(param: string | null) {
    if (!param) return [];
    return param.split(",").map((s) => s.trim()).filter(Boolean);
  }
  function readUrl(): FilterState {
    const p = new URLSearchParams(window.location.search);
    return {
      q: (p.get("q") || "").trim(),
      servicio: new Set(parseList(p.get("servicio"))),
      estado: new Set(parseList(p.get("estado"))),
    };
  }
  function writeUrl(state: FilterState) {
    const p = new URLSearchParams();
    if (state.q) p.set("q", state.q);
    if (state.servicio.size) p.set("servicio", [...state.servicio].join(","));
    if (state.estado.size) p.set("estado", [...state.estado].join(","));
    const qs = p.toString();
    history.replaceState({}, "", qs ? `${location.pathname}?${qs}` : location.pathname);
  }
  function hasFilters(s: FilterState) {
    return Boolean(s.q || s.servicio.size || s.estado.size);
  }
  function shortList(values: string[], empty: string) {
    if (!values.length) return empty;
    if (values.length === 1) return values[0];
    if (values.length === 2) return `${values[0]}, ${values[1]}`;
    return `${values[0]} +${values.length - 1}`;
  }
  function matches(card: HTMLElement, state: FilterState) {
    const name = (card.dataset.name || "").toLowerCase();
    const description = (card.dataset.description || "").toLowerCase();
    const estado = card.dataset.estado || "";
    let servicios: string[] = [];
    try { servicios = JSON.parse(card.dataset.servicios || "[]"); } catch { /* */ }
    if (state.q) {
      const q = state.q.toLowerCase();
      if (!name.includes(q) && !description.includes(q)) return false;
    }
    if (state.servicio.size && ![...state.servicio].some((s) => servicios.includes(s))) return false;
    if (state.estado.size && !state.estado.has(estado)) return false;
    return true;
  }
  function closeMenus(root: HTMLElement) {
    root.querySelectorAll<HTMLElement>("[data-menu-panel]").forEach((el) => { el.hidden = true; });
    root.querySelectorAll("[data-menu-toggle]").forEach((t) => t.setAttribute("aria-expanded", "false"));
  }
  function apply(root: HTMLElement, state: FilterState) {
    const cards = document.querySelectorAll<HTMLElement>("[data-profile-card]");
    let visible = 0;
    cards.forEach((card) => {
      const ok = matches(card, state);
      card.hidden = !ok;
      if (ok) visible += 1;
    });
    root.querySelectorAll<HTMLButtonElement>("[data-filter-chip]").forEach((chip) => {
      chip.setAttribute("aria-pressed", state.servicio.has(chip.dataset.value || "") ? "true" : "false");
    });
    root.querySelectorAll<HTMLInputElement>("[data-estado-option]").forEach((box) => {
      box.checked = state.estado.has(box.value);
    });
    const el = root.querySelector("[data-estado-label]");
    if (el) el.textContent = shortList([...state.estado], "Todo México");
    const sl = root.querySelector("[data-servicio-label]");
    if (sl) sl.textContent = shortList([...state.servicio], "Todos");
    const qInput = root.querySelector<HTMLInputElement>("[data-filter-q]");
    if (qInput && qInput.value !== state.q) qInput.value = state.q;
    const clearBtn = root.querySelector<HTMLButtonElement>("[data-filter-clear]");
    if (clearBtn) clearBtn.disabled = !hasFilters(state);
    const countEl = root.querySelector("[data-filter-count]");
    if (countEl) {
      countEl.textContent = cards.length
        ? hasFilters(state) ? `${visible} de ${cards.length}` : `${cards.length}`
        : "";
    }
    document.querySelector("[data-filter-empty]")?.classList.toggle("hidden", !cards.length || visible > 0);
  }

  function init() {
    const root = document.querySelector<HTMLElement>(".directory-labeled[data-directory-filter]");
    if (!root) return;
    let state = readUrl();
    apply(root, state);
    closeMenus(root);

    root.querySelectorAll<HTMLButtonElement>("[data-menu-toggle]").forEach((toggle) => {
      toggle.addEventListener("click", (e) => {
        e.stopPropagation();
        const panel = toggle.closest("[data-menu]")?.querySelector<HTMLElement>("[data-menu-panel]");
        if (!panel) return;
        const open = panel.hidden;
        closeMenus(root);
        panel.hidden = !open;
        toggle.setAttribute("aria-expanded", open ? "true" : "false");
      });
    });

    const qInput = root.querySelector<HTMLInputElement>("[data-filter-q]");
    let t: number | undefined;
    qInput?.addEventListener("input", () => {
      clearTimeout(t);
      t = window.setTimeout(() => {
        state = { ...state, q: (qInput.value || "").trim() };
        writeUrl(state);
        apply(root, state);
      }, 150);
    });

    root.querySelectorAll<HTMLButtonElement>("[data-filter-chip]").forEach((chip) => {
      chip.addEventListener("click", (e) => {
        e.stopPropagation();
        const v = chip.dataset.value || "";
        const next = new Set(state.servicio);
        if (next.has(v)) next.delete(v); else next.add(v);
        state = { ...state, servicio: next };
        writeUrl(state);
        apply(root, state);
      });
    });

    root.querySelectorAll<HTMLInputElement>("[data-estado-option]").forEach((box) => {
      box.addEventListener("change", () => {
        const next = new Set(state.estado);
        if (box.checked) next.add(box.value); else next.delete(box.value);
        state = { ...state, estado: next };
        writeUrl(state);
        apply(root, state);
      });
    });

    const clear = () => {
      state = { q: "", servicio: new Set(), estado: new Set() };
      writeUrl(state);
      apply(root, state);
      closeMenus(root);
    };
    root.querySelector("[data-filter-clear]")?.addEventListener("click", clear);
    root.querySelector("[data-filter-home]")?.addEventListener("click", (e) => {
      if (!hasFilters(state)) return;
      e.preventDefault();
      clear();
    });
    document.addEventListener("click", (e) => {
      if (!root.contains(e.target as Node)) closeMenus(root);
    });
  }
  init();
  document.addEventListener("astro:page-load", init);
</script>
