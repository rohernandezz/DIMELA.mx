---
/**
 * Profile card — Pro fills the grid cell; Free is 98% wide, 96% tall from center
 * (visual margin inside the same cell). Pro keeps badge + stronger border.
 */
import type { MockProfile } from "../data/mockProfiles";
import { estadoSlug } from "../lib/slugs";
import { bioLeadPlainText, bioPlainText } from "../lib/bio";
import { websiteHref, websiteLabel, websiteCapsuleClass, profileTagPillClass } from "../lib/website";

interface Props {
  profile: MockProfile;
}

const { profile } = Astro.props;
const descriptionPlain = bioPlainText(profile.description);
const leadPlain = bioLeadPlainText(profile.description);
const siteHref = profile.website ? websiteHref(profile.website) : "";
const siteLabel = profile.website ? websiteLabel(profile.website) : "";
const isPro = profile.tier === "pro";
const href = `/directorio/${profile.slug}/`;
const estadoHref = `/estado/${estadoSlug(profile.estado)}/`;
---

<article
  class:list={[
    "profile-card group relative flex h-full min-h-0 w-full flex-col overflow-hidden rounded-md border-2 bg-white shadow-md transition hover:-translate-y-0.5 hover:shadow-lg",
    isPro
      ? "border-dm-offblack/35 shadow-lg"
      : "origin-center scale-x-[0.98] scale-y-[0.96] border-dm-offblack/15",
  ]}
  data-profile-card
  data-profile-theme={profile.slug}
  data-slug={profile.slug}
  data-name={profile.name}
  data-description={descriptionPlain}
  data-estado={profile.estado}
  data-servicios={JSON.stringify(profile.servicios)}
>
  {
    isPro && (
      <span class="absolute top-3 right-3 z-10 rounded bg-dm-pink px-2 py-0.5 text-[10px] font-semibold tracking-wide text-dm-offblack uppercase">
        Pro
      </span>
    )
  }

  <div class="relative aspect-[16/10] shrink-0 overflow-hidden bg-dm-blue">
    {
      profile.cover ? (
        <img
          src={profile.cover}
          alt=""
          class="absolute inset-0 h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div
          class="absolute inset-0 flex items-end bg-gradient-to-br from-dm-blue-strong via-dm-blue to-dm-offwhite p-4"
          aria-hidden="true"
        >
          <span class="text-3xl font-bold text-dm-offblack/25 select-none">Aa</span>
        </div>
      )
    }
  </div>

  <div class="flex min-h-0 flex-1 flex-col gap-3 p-4">
    <header class="flex shrink-0 items-center gap-3">
      {
        profile.avatar ? (
          <img
            src={profile.avatar}
            alt=""
            class="h-12 w-12 shrink-0 rounded-full object-cover shadow-md ring-2 ring-white"
            width="48"
            height="48"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div
            class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-dm-offblack/10 text-dm-offblack/50 shadow-md ring-2 ring-white"
            aria-hidden="true"
          >
            <svg class="h-7 w-7" viewBox="0 0 24 24" fill="currentColor">
              <circle cx="12" cy="8" r="4"></circle>
              <path d="M4 22c0-5 4-8 8-8s8 3 8 8v2H4v-2z"></path>
            </svg>
          </div>
        )
      }
      <div class="min-w-0">
        <a
          href={href}
          class="block truncate text-lg font-bold text-dm-offblack underline-offset-2 hover:underline"
        >
          {profile.name}
        </a>
        <div class="mt-0.5 flex flex-wrap items-center gap-x-2 gap-y-1">
          <a
            href={estadoHref}
            class="relative z-10 truncate text-sm text-dm-offblack/60 hover:underline"
          >
            {profile.estado}
          </a>
          {
            siteHref && (
              <a
                href={siteHref}
                class={websiteCapsuleClass}
                rel="noopener noreferrer"
                target="_blank"
              >
                <span class="truncate">{siteLabel}</span>
                <span aria-hidden="true" class="shrink-0 opacity-60">↗</span>
              </a>
            )
          }
        </div>
      </div>
    </header>

    <p class="bio-lead line-clamp-3 min-h-0 text-sm font-medium leading-relaxed text-dm-offblack/85">
      {leadPlain}
    </p>

    <div class="mt-auto min-h-12 shrink-0 border-t border-dm-offblack/10 pt-3">
      <div class="flex flex-wrap content-start gap-1.5">
        {
          profile.servicios.map((servicio) => (
            <span class="rounded border border-dm-offblack/20 bg-dm-offwhite px-2 py-0.5 text-[11px] text-dm-offblack/80">
              {servicio}
            </span>
          ))
        }
      </div>
      {
        (profile.tags || []).length > 0 && (
          <div class="mt-1.5 flex flex-wrap content-start gap-1.5">
            {(profile.tags || []).map((tag) => (
              <a
                href={`/directorio/?q=${encodeURIComponent(tag)}`}
                class={profileTagPillClass}
              >
                {tag}
              </a>
            ))}
          </div>
        )
      }
    </div>
  </div>

  <a href={href} class="absolute inset-0 z-0" aria-hidden="true" tabindex="-1"></a>
</article>
