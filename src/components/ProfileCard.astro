---
/**
 * Profile card mock — Free vs Pro on the same simple grid.
 * Pro is the same column span, slightly larger visually.
 */
import type { MockProfile } from "../data/mockProfiles";

interface Props {
  profile: MockProfile;
}

const { profile } = Astro.props;
const isPro = profile.tier === "pro";
const href = `#${profile.slug}`;
---

<article
  class:list={[
    "profile-card group relative flex h-full flex-col overflow-hidden rounded-md border-2 bg-white shadow-md transition hover:-translate-y-0.5 hover:shadow-lg",
    isPro
      ? "profile-card--pro border-dm-offblack/30 shadow-lg"
      : "border-dm-offblack/15",
  ]}
  data-profile-card
  data-name={profile.name}
  data-description={profile.description}
  data-estado={profile.estado}
  data-servicios={JSON.stringify(profile.servicios)}
>
  {
    isPro && (
      <span class="absolute top-3 right-3 z-10 rounded bg-dm-pink px-2 py-0.5 text-[10px] font-semibold tracking-wide text-dm-offblack uppercase">
        Pro
      </span>
    )
  }

  <div
    class:list={[
      "relative shrink-0 overflow-hidden bg-dm-blue",
      isPro ? "aspect-[5/4]" : "aspect-[16/10]",
    ]}
  >
    {
      profile.cover ? (
        <img
          src={profile.cover}
          alt=""
          class="absolute inset-0 h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div
          class="absolute inset-0 flex items-end bg-gradient-to-br from-dm-blue-strong via-dm-blue to-dm-offwhite p-4"
          aria-hidden="true"
        >
          <span class="text-3xl font-bold text-dm-offblack/25 select-none">Aa</span>
        </div>
      )
    }
  </div>

  <div class:list={["flex flex-1 flex-col gap-3", isPro ? "p-5" : "p-4"]}>
    <header class="flex items-center gap-3">
      {
        profile.avatar ? (
          <img
            src={profile.avatar}
            alt=""
            class:list={[
              "rounded-full object-cover shadow-md ring-2 ring-white",
              isPro ? "h-14 w-14" : "h-12 w-12",
            ]}
            width={isPro ? 56 : 48}
            height={isPro ? 56 : 48}
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div
            class:list={[
              "flex items-center justify-center rounded-full bg-dm-offblack/10 text-dm-offblack/50 shadow-md ring-2 ring-white",
              isPro ? "h-14 w-14" : "h-12 w-12",
            ]}
            aria-hidden="true"
          >
            <svg class={isPro ? "h-8 w-8" : "h-7 w-7"} viewBox="0 0 24 24" fill="currentColor">
              <circle cx="12" cy="8" r="4"></circle>
              <path d="M4 22c0-5 4-8 8-8s8 3 8 8v2H4v-2z"></path>
            </svg>
          </div>
        )
      }
      <div class="min-w-0">
        <a
          href={href}
          class:list={[
            "block truncate font-bold text-dm-offblack underline-offset-2 hover:underline",
            isPro ? "text-xl" : "text-lg",
          ]}
        >
          {profile.name}
        </a>
        <a
          href={`/estado/#${profile.estado}`}
          class="relative z-10 text-sm text-dm-offblack/60 hover:underline"
        >
          {profile.estado}
        </a>
      </div>
    </header>

    <p
      class:list={[
        "leading-relaxed text-dm-offblack/75",
        isPro ? "line-clamp-3 text-[15px]" : "line-clamp-2 text-sm",
      ]}
    >
      {profile.description}
    </p>

    <div class="mt-auto flex flex-wrap gap-1.5 pt-1">
      {
        profile.servicios.map((servicio) => (
          <span class="rounded border border-dm-offblack/20 bg-dm-offwhite px-2 py-0.5 text-[11px] text-dm-offblack/80">
            {servicio}
          </span>
        ))
      }
    </div>
  </div>

  <a href={href} class="absolute inset-0 z-0" aria-hidden="true" tabindex="-1"></a>
</article>
