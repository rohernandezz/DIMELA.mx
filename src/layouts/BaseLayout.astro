---
/**
 * BaseLayout — HTML shell shared by every page.
 */
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  /** path = filters in header crumbs; simple = logo/nav only */
  headerVariant?: "path" | "simple";
  /** Logo target for simple header (compare homes). */
  homeHref?: string;
}

const {
  title = "DIMELA.mx",
  description = "Directorio Mexicano de Letristas",
  headerVariant = "simple",
  homeHref = "/",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="flex min-h-screen flex-col">
    <Header variant={headerVariant} homeHref={homeHref} />
    <main class="mx-auto w-full max-w-7xl flex-1 px-4 py-6 sm:px-6">
      <slot />
    </main>
    <Footer />
  </body>
</html>
