---
/**
 * Homepage B — simple header + filter bar (desktop chips / mobile sheet).
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import ProfileCard from "../components/ProfileCard.astro";
import DirectoryFilterBar from "../components/DirectoryFilterBar.astro";
import CompareHomes from "../components/CompareHomes.astro";
import { MOCK_PROFILES } from "../data/mockProfiles";
---

<BaseLayout title="DIMELA.mx — Filter bar UI" headerVariant="simple" homeHref="/bar/">
  <DirectoryFilterBar />
  <section aria-label="Directorio">
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3" data-profile-grid>
      {MOCK_PROFILES.map((profile) => <ProfileCard profile={profile} />)}
    </div>
    <p class="mt-8 hidden text-center text-sm text-dm-offblack/55" data-filter-empty>
      No hay perfiles con esos filtros.
    </p>
  </section>
  <CompareHomes current="bar" />
</BaseLayout>
