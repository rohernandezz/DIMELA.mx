---
/**
 * Former homepage A — path filters in the header.
 * Kept as a UI prototype; canonical home is Option B (`/`).
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import ProfileCard from "../components/ProfileCard.astro";
import CompareHomes from "../components/CompareHomes.astro";
import { MOCK_PROFILES } from "../data/mockProfiles";
---

<BaseLayout title="DIMELA.mx — UI prototype A (path)" headerVariant="path" homeHref="/path/">
  <section aria-label="Directorio">
    <div
      class="grid auto-rows-fr grid-cols-[repeat(auto-fill,minmax(min(100%,18.5rem),1fr))] gap-5"
      data-profile-grid
    >
      {MOCK_PROFILES.map((profile) => <ProfileCard profile={profile} />)}
    </div>
    <p class="mt-8 hidden text-center text-sm text-dm-offblack/55" data-filter-empty>
      No hay perfiles con esos filtros.
    </p>
  </section>
  <CompareHomes current="path" />
</BaseLayout>
