---
/**
 * Browse by servicio — counts from /api/search (D1).
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Servicios — DIMELA.mx" headerVariant="simple" homeHref="/" showTagline>
  <header class="mb-8">
    <p class="mb-2 text-sm text-dm-offblack/50">
      <a href="/" class="hover:underline">Inicio</a>
      <span class="mx-1.5" aria-hidden="true">›</span>
      <span class="text-dm-offblack/70">Servicios</span>
    </p>
    <h1 class="dm-ui-page-title">Explorar por servicio</h1>
    <p class="mt-2 text-sm text-dm-offblack/65" data-taxonomy-summary>Cargando…</p>
  </header>

  <ul class="grid gap-2 sm:grid-cols-2" data-taxonomy-index data-taxonomy-kind="servicio"></ul>
</BaseLayout>

<script>
  import { fetchSearchResults } from "../../lib/fetchDirectory";
  import { countByServicio } from "../../lib/taxonomyCounts";

  function rowHtml(href: string, label: string, count: number) {
    const active = count > 0;
    const cls = active
      ? "border-dm-offblack/15 bg-white hover:border-dm-offblack/35 hover:shadow-sm"
      : "pointer-events-none border-dm-offblack/10 bg-white/50 text-dm-offblack/40";
    return `<li><a href="${href}" class="flex items-baseline justify-between gap-3 rounded border px-3 py-2.5 transition ${cls}"><span class="min-w-0 truncate font-medium">${label}</span><span class="shrink-0 text-sm tabular-nums text-dm-offblack/55">${count}</span></a></li>`;
  }

  async function init() {
    const list = document.querySelector<HTMLElement>(
      '[data-taxonomy-index][data-taxonomy-kind="servicio"]',
    );
    const summary = document.querySelector<HTMLElement>("[data-taxonomy-summary]");
    if (!list) return;

    try {
      const profiles = await fetchSearchResults();
      const rows = countByServicio(profiles);
      const mentions = rows.reduce((n, r) => n + r.count, 0);
      list.innerHTML = rows
        .map((row) => rowHtml(`/servicios/${row.slug}/`, row.label, row.count))
        .join("");
      if (summary) {
        summary.textContent = `${rows.length} servicios · ${mentions} menciones en el directorio.`;
      }
    } catch {
      if (summary) summary.textContent = "No se pudo cargar el directorio.";
    }
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
