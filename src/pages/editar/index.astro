---
/**
 * Member profile editor — magic-link auth + TipTap bio + D1 save.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import { MEXICO_ESTADOS } from "../../data/taxonomy";
---

<BaseLayout
  title="Editar perfil — DIMELA.mx"
  description="Editor de perfil para miembros DIMELA."
  headerVariant="simple"
  homeHref="/"
>
  <div class="mx-auto max-w-3xl pb-16">
    <!-- Login -->
    <section
      class="mb-10 space-y-4 rounded border border-dm-offblack/15 bg-white p-5"
      data-auth-panel
      hidden
    >
      <div>
        <p class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase">
          Cuenta
        </p>
        <h1 class="mt-1 text-2xl tracking-wide">Entrar con email</h1>
        <p class="mt-1 text-sm text-dm-offblack/65">
          Te enviamos un enlace mágico a tu correo. Si ya entraste, ve a
          <a href="/cuenta/" class="underline hover:text-dm-offblack">Mi cuenta</a>.
        </p>
      </div>
      <form class="flex flex-col gap-3 sm:flex-row sm:items-end" data-auth-form>
        <label class="block min-w-0 flex-1 space-y-1.5">
          <span class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase"
            >Email</span
          >
          <input
            type="email"
            name="email"
            required
            placeholder="tu@email.com"
            class="w-full rounded border border-dm-offblack/20 bg-dm-offwhite px-3 py-2 text-sm outline-none focus:border-dm-offblack/50"
          />
        </label>
        <button
          type="submit"
          class="rounded border border-dm-offblack bg-dm-pink px-4 py-2 text-sm text-dm-offblack hover:bg-dm-offblack hover:text-white"
        >
          Enviar enlace
        </button>
      </form>
      <p class="text-sm text-dm-offblack/60" data-auth-message></p>
      <p class="hidden break-all text-sm" data-auth-link></p>
    </section>

    <!-- Claim seeded profile -->
    <section
      class="mb-10 hidden space-y-4 rounded border border-dm-offblack/15 bg-dm-offwhite/80 p-5"
      data-claim-panel
    >
      <div>
        <h2 class="text-xl tracking-wide">Reclama tu perfil</h2>
        <p class="mt-1 text-sm text-dm-offblack/65">
          Hay un perfil en el directorio asociado a tu correo. Reclámalo antes de crear uno nuevo.
        </p>
      </div>
      <ul class="space-y-2" data-claim-list></ul>
      <p class="text-xs text-dm-offblack/50">
        <a href="/cuenta/" class="underline hover:text-dm-offblack">Mi cuenta</a>
      </p>
    </section>

    <!-- Editor (shown when logged in) -->
    <div data-editor-root hidden>
      <header class="mb-8 space-y-3">
        <p class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase">
          Cuenta · <span data-user-email></span>
        </p>
        <div class="flex flex-wrap items-end justify-between gap-3">
          <div>
            <h1 class="text-3xl tracking-wide">Editar perfil</h1>
            <p class="mt-1 text-sm text-dm-offblack/65">
              Guardado en D1. Publicado solo tras aprobación.
            </p>
          </div>
          <span
            class="rounded border border-dm-offblack/20 bg-dm-blue/60 px-2.5 py-1 text-[11px] font-semibold tracking-wide text-dm-offblack uppercase"
            data-status-badge
          >
            —
          </span>
        </div>

        <div class="flex flex-wrap gap-2 pt-1">
          <button
            type="button"
            class="rounded border border-dm-offblack bg-dm-pink px-3 py-1.5 text-sm text-dm-offblack transition hover:bg-dm-offblack hover:text-white"
            data-action="save"
          >
            Guardar borrador
          </button>
          <button
            type="button"
            class="rounded border border-dm-offblack/25 bg-dm-offblack px-3 py-1.5 text-sm text-dm-offwhite transition hover:opacity-90"
            data-action="submit"
          >
            Enviar a revisión
          </button>
          <a
            href="/directorio/"
            class="rounded border border-dm-offblack/20 bg-white px-3 py-1.5 text-sm text-dm-offblack/80 hover:border-dm-offblack/40"
            data-public-link
          >
            Vista pública
          </a>
          <button
            type="button"
            class="rounded border border-dm-offblack/15 px-3 py-1.5 text-sm text-dm-offblack/60 hover:border-dm-offblack/30"
            data-action="logout"
          >
            Salir
          </button>
        </div>
        <p class="hidden text-sm text-dm-offblack/55" data-editor-toast role="status"></p>
      </header>

      <form class="space-y-10" data-profile-editor novalidate>
        <section class="space-y-4" aria-labelledby="editor-identity">
          <div>
            <h2 id="editor-identity" class="text-lg tracking-wide">Identidad</h2>
            <p class="mt-1 text-sm text-dm-offblack/60">Nombre público y sitio web.</p>
            <p class="text-xs text-dm-offblack/45">La URL se genera sola al guardar; solo admin puede cambiarla.</p>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block space-y-1.5 sm:col-span-2">
              <span class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase"
                >Nombre</span
              >
              <input
                type="text"
                name="name"
                data-field="name"
                class="w-full rounded border border-dm-offblack/20 bg-white px-3 py-2 text-sm outline-none focus:border-dm-offblack/50"
              />
            </label>
            <p class="sm:col-span-2 text-[11px] text-dm-offblack/55" data-profile-slug hidden>
              URL del perfil: <span class="font-mono text-dm-offblack/70" data-profile-slug-value></span>
            </p>
            <label class="block space-y-1.5 sm:col-span-2">
              <span class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase"
                >Sitio web</span
              >
              <input
                type="url"
                name="website"
                data-field="website"
                placeholder="https://"
                class="w-full rounded border border-dm-offblack/20 bg-white px-3 py-2 text-sm outline-none focus:border-dm-offblack/50"
              />
            </label>
          </div>
        </section>

        <section class="space-y-4" aria-labelledby="editor-facets">
          <div>
            <h2 id="editor-facets" class="text-lg tracking-wide">Directorio</h2>
            <p class="mt-1 text-sm text-dm-offblack/60">Ubicación y servicios.</p>
          </div>
          <label class="block space-y-1.5">
            <span class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase"
              >Ubicación</span
            >
            <select
              name="estado"
              data-field="estado"
              class="w-full rounded border border-dm-offblack/20 bg-dm-blue/40 px-3 py-2 text-sm outline-none focus:border-dm-offblack/50"
            >
              {MEXICO_ESTADOS.map((estado) => <option value={estado}>{estado}</option>)}
            </select>
          </label>
          <fieldset>
            <legend
              class="mb-1 text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase"
            >
              Servicios
            </legend>
            <p class="mb-2 text-xs text-dm-offblack/50">
              Selecciona servicios; arrastra los seleccionados para ordenarlos en el perfil.
            </p>
            <div class="flex flex-wrap gap-1.5" data-servicios-host></div>
          </fieldset>
        </section>

        <section class="space-y-4" aria-labelledby="editor-bio">
          <div>
            <h2 id="editor-bio" class="text-lg tracking-wide">Bio</h2>
            <p class="mt-1 text-sm text-dm-offblack/60">TipTap · HTML sanitizado al guardar.</p>
            <p class="text-xs text-dm-offblack/45">El primer párrafo es el destacado en la tarjeta del directorio; después puedes ampliar en el perfil.</p>
          </div>
          <div class="overflow-hidden rounded border border-dm-offblack/20 bg-white" data-tiptap-shell>
            <div
              class="flex flex-wrap gap-1 border-b border-dm-offblack/10 bg-dm-offwhite px-2 py-1.5"
              data-bio-toolbar
            >
              <button type="button" data-bio-cmd="bold" aria-label="Negritas" class="inline-flex items-center gap-1.5 rounded border border-dm-offblack/15 bg-white px-2 py-1 text-[11px]">
                <span class="w-4 shrink-0 text-center text-xs font-bold leading-none" aria-hidden="true">B</span>
                <span>Negritas</span>
              </button>
              <button type="button" data-bio-cmd="italic" aria-label="Itálicas" class="inline-flex items-center gap-1.5 rounded border border-dm-offblack/15 bg-white px-2 py-1 text-[11px]">
                <span class="w-4 shrink-0 text-center text-xs italic leading-none" aria-hidden="true">I</span>
                <span>Itálicas</span>
              </button>
              <button type="button" data-bio-cmd="h2" aria-label="Título" class="inline-flex items-center gap-1.5 rounded border border-dm-offblack/15 bg-white px-2 py-1 text-[11px]">
                <span class="w-4 shrink-0 text-center text-sm leading-none" aria-hidden="true">🏷️</span>
                <span>Título</span>
              </button>
              <button type="button" data-bio-cmd="paragraph" aria-label="Texto" class="inline-flex items-center gap-1.5 rounded border border-dm-offblack/15 bg-white px-2 py-1 text-[11px]">
                <span class="w-4 shrink-0 text-center text-sm leading-none" aria-hidden="true">¶</span>
                <span>Texto</span>
              </button>
              <button type="button" data-bio-cmd="bullet" aria-label="Lista" class="inline-flex items-center gap-1.5 rounded border border-dm-offblack/15 bg-white px-2 py-1 text-[11px]">
                <span class="w-4 shrink-0 text-center text-sm leading-none" aria-hidden="true">•</span>
                <span>Lista</span>
              </button>
              <button type="button" data-bio-cmd="blockquote" aria-label="Cita" class="inline-flex items-center gap-1.5 rounded border border-dm-offblack/15 bg-white px-2 py-1 text-[11px]">
                <span class="w-4 shrink-0 text-center text-sm leading-none" aria-hidden="true">❝</span>
                <span>Cita</span>
              </button>
              <button type="button" data-bio-cmd="link" aria-label="Enlace" class="inline-flex items-center gap-1.5 rounded border border-dm-offblack/15 bg-white px-2 py-1 text-[11px]">
                <span class="w-4 shrink-0 text-center text-sm leading-none" aria-hidden="true">🔗</span>
                <span>Enlace</span>
              </button>
              <button type="button" data-bio-cmd="clear" aria-label="Quitar formato" class="inline-flex items-center gap-1.5 rounded border border-dm-offblack/15 bg-white px-2 py-1 text-[11px] text-dm-offblack/70">
                <span class="w-4 shrink-0 text-center text-sm leading-none" aria-hidden="true">🧹</span>
                <span>Quitar formato</span>
              </button>
            </div>
            <div data-bio-editor></div>
            <input type="hidden" name="description" value="" data-bio-html />
          </div>
        </section>

        <section class="space-y-4" aria-labelledby="editor-media">
          <div>
            <h2 id="editor-media" class="text-lg tracking-wide">Medios</h2>
            <p class="mt-1 text-sm text-dm-offblack/60">
              Portada y avatar se guardan en R2. Guarda el borrador al menos una vez antes de subir.
            </p>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="space-y-2">
              <p class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase">
                Portada
              </p>
              <div
                class="relative flex aspect-[16/10] items-end overflow-hidden rounded-md border border-dashed border-dm-offblack/25 bg-dm-blue"
                data-cover-preview
              >
                <div class="relative z-10 w-full bg-gradient-to-t from-dm-offblack/50 to-transparent p-3">
                  <button
                    type="button"
                    class="rounded border border-white/40 bg-white/90 px-2.5 py-1 text-xs text-dm-offblack disabled:opacity-50"
                    data-action="upload-cover"
                  >
                    Subir portada
                  </button>
                </div>
              </div>
              <p class="text-[11px] text-dm-offblack/50">JPEG, PNG, WebP o GIF · máx. 5 MB</p>
            </div>
            <div class="space-y-2">
              <p class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase">
                Avatar
              </p>
              <div
                class="flex aspect-square max-w-[12rem] flex-col items-center justify-center gap-3 rounded-md border border-dashed border-dm-offblack/25 bg-white p-4"
                data-avatar-preview
              >
                <div
                  class="flex h-20 w-20 items-center justify-center overflow-hidden rounded-full bg-dm-blue text-sm text-dm-offblack/40"
                  data-avatar-fallback
                >
                  Aa
                </div>
                <button
                  type="button"
                  class="rounded border border-dm-offblack/20 px-2.5 py-1 text-xs text-dm-offblack/80 disabled:opacity-50"
                  data-action="upload-avatar"
                >
                  Subir avatar
                </button>
              </div>
              <p class="text-[11px] text-dm-offblack/50">JPEG, PNG, WebP o GIF · máx. 2 MB · recorte circular</p>
            </div>
          </div>
          <input
            type="file"
            class="sr-only"
            accept="image/jpeg,image/png,image/webp,image/gif"
            data-upload-input
            tabindex="-1"
          />
          <div
            class="rounded border border-dm-offblack/15 bg-dm-offwhite/60 px-3 py-2.5 text-[11px] text-dm-offblack/65"
            data-media-quota
            hidden
          >
            <p class="font-medium text-dm-offblack/80">Uso de almacenamiento (directorio)</p>
            <p class="mt-1" data-quota-storage>—</p>
            <p class="mt-0.5" data-quota-ops>—</p>
            <p class="mt-1 hidden text-dm-pink" data-quota-blocked>
              Límite alcanzado. Las subidas están pausadas hasta liberar espacio o el próximo mes.
            </p>
          </div>
        </section>

        <section class="space-y-4" aria-labelledby="editor-gallery">
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <div>
              <h2 id="editor-gallery" class="text-lg tracking-wide">Galería</h2>
              <p class="mt-1 text-sm text-dm-offblack/60" data-gallery-hint>
                Free: 1 galería, hasta 12 imágenes (3 MB c/u). Pro: hasta 5 galerías, 24 imágenes c/u (5 MB).
              </p>
            </div>
            <button
              type="button"
              class="hidden rounded border border-dm-offblack/20 px-2.5 py-1 text-xs text-dm-offblack/80 disabled:opacity-50"
              data-action="gallery-create"
            >
              + Nueva galería
            </button>
          </div>
          <div class="space-y-4" data-gallery-root></div>
          <input
            type="file"
            class="sr-only"
            accept="image/jpeg,image/png,image/webp,image/gif"
            data-gallery-input
            tabindex="-1"
          />
        </section>

        <section class="space-y-4" aria-labelledby="editor-css" data-pro-theme-section>
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <div>
              <h2 id="editor-css" class="text-lg tracking-wide">Estilo Pro</h2>
              <p class="mt-1 text-sm text-dm-offblack/60">
                Fuentes (máx. 2) y CSS scoped a <code class="text-xs">.profile-card</code> y
                <code class="text-xs">.profile-detail</code>.
              </p>
            </div>
            <span class="rounded bg-dm-pink px-2 py-0.5 text-[10px] font-semibold tracking-wide text-dm-offblack uppercase">Pro</span>
          </div>
          <div class="space-y-3 rounded border border-dm-offblack/15 bg-white/80 p-3" data-font-panel>
            <p class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase">Fuentes</p>
            <p class="text-[11px] text-dm-offblack/55">WOFF2, WOFF, TTF u OTF · máx. 768 KB c/u · hasta 2 fuentes.</p>
            <ul class="space-y-1.5 text-sm" data-font-list></ul>
            <div class="flex flex-wrap items-end gap-2" data-font-upload-row>
              <label class="block min-w-[8rem] flex-1 space-y-1">
                <span class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase">Nombre CSS</span>
                <input
                  type="text"
                  data-font-family
                  placeholder="Mi Fuente"
                  class="w-full rounded border border-dm-offblack/20 bg-white px-2 py-1.5 text-sm outline-none focus:border-dm-offblack/50"
                />
              </label>
              <button
                type="button"
                data-action="font-upload"
                class="rounded border border-dm-offblack/20 px-2.5 py-1.5 text-xs hover:border-dm-offblack/40 disabled:opacity-50"
              >
                Subir fuente
              </button>
            </div>
            <input type="file" class="sr-only" accept=".woff2,.woff,.ttf,.otf,font/woff2,font/woff,font/ttf,font/otf" data-font-input tabindex="-1" />
          </div>
          <textarea
            name="customCss"
            data-field="customCss"
            rows="6"
            placeholder={`.profile-card {\n  font-family: "Mi Fuente", sans-serif;\n}\n.profile-detail h1 {\n  letter-spacing: 0.04em;\n}`}
            class="w-full rounded border border-dm-offblack/20 bg-dm-offblack px-3 py-3 font-mono text-xs leading-relaxed text-dm-offwhite outline-none placeholder:text-dm-offwhite/35 focus:border-dm-pink/50 disabled:opacity-50"
          ></textarea>
          <p class="text-[11px] text-dm-offblack/45" data-pro-theme-hint hidden>
            Actualiza a Pro para personalizar fuentes y CSS.
          </p>
        </section>

        <div class="flex flex-wrap gap-2 border-t border-dm-offblack/10 pt-6">
          <button
            type="submit"
            class="rounded border border-dm-offblack bg-dm-pink px-4 py-2 text-sm text-dm-offblack transition hover:bg-dm-offblack hover:text-white"
          >
            Guardar borrador
          </button>
          <button
            type="button"
            class="rounded border border-dm-offblack/25 px-4 py-2 text-sm text-dm-offblack/70"
            data-action="submit"
          >
            Enviar a revisión
          </button>
        </div>
      </form>
    </div>
  </div>
</BaseLayout>

<script>
  import { bindBioToolbar, mountBioEditor, type BioEditor } from "../../lib/bioEditor";
  import { openAvatarCropper } from "../../lib/imageCropper";
  import { requestMagicLink, renderDevMagicLink } from "../../lib/authClient";
  import { normalizeServicios, SERVICIOS } from "../../data/taxonomy";

  type GalleryImage = { id: string; url: string; caption?: string };
  type ProfileGallery = { id: string; title: string; images: GalleryImage[] };

  type ProfileFont = { id: string; family: string; url: string; format: string };

  /** Selected servicios in display order (drag order in the picker). */
  let serviciosOrder: string[] = [];
  let dragServicio: string | null = null;
  let didServicioDrag = false;

  type Profile = {
    slug: string;
    name: string;
    estado: string;
    servicios: string[];
    description: string;
    website?: string;
    tier: string;
    cover: string | null;
    avatar: string | null;
    customCss?: string;
    customFonts?: ProfileFont[];
    status: string;
    galleries?: ProfileGallery[];
    hasPublishedVersion?: boolean;
  };

  const FONT_LIMITS = { maxFonts: 2, maxKb: 768 };

  const GALLERY_LIMITS = {
    free: { maxGalleries: 1, maxImages: 12, maxMb: 3 },
    pro: { maxGalleries: 5, maxImages: 24, maxMb: 5 },
  };

  const STATUS_LABEL: Record<string, string> = {
    draft: "Borrador",
    pending_review: "En revisión",
    published: "Publicado",
    rejected: "Rechazado",
  };

  let bio: BioEditor | null = null;

  function toast(message: string) {
    const el = document.querySelector<HTMLElement>("[data-editor-toast]");
    if (!el) return;
    el.textContent = message;
    el.classList.remove("hidden");
    window.setTimeout(() => el.classList.add("hidden"), 2800);
  }

  type Claimable = { slug: string; name: string; estado: string; status: string };

  function setView(mode: "login" | "claim" | "editor") {
    const auth = document.querySelector<HTMLElement>("[data-auth-panel]");
    const claim = document.querySelector<HTMLElement>("[data-claim-panel]");
    const editor = document.querySelector<HTMLElement>("[data-editor-root]");
    if (auth) auth.hidden = mode !== "login";
    claim?.classList.toggle("hidden", mode !== "claim");
    if (editor) editor.hidden = mode !== "editor";
  }

  function showLogin(show: boolean) {
    setView(show ? "login" : "editor");
  }

  function renderClaimList(items: Claimable[]) {
    const list = document.querySelector<HTMLElement>("[data-claim-list]");
    if (!list) return;
    list.innerHTML = items
      .map(
        (p) => `<li>
          <button type="button" class="w-full rounded border border-dm-offblack/15 bg-white p-3 text-left hover:border-dm-offblack/35"
            data-claim-slug="${p.slug}">
            <span class="block font-medium">${p.name}</span>
            <span class="text-sm text-dm-offblack/60">${p.estado}</span>
          </button>
        </li>`,
      )
      .join("");
  }

  async function claimProfileSlug(slug: string) {
    const res = await fetch("/api/me/profile/claim", {
      method: "POST",
      credentials: "same-origin",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ slug }),
    });
    const data = await res.json();
    if (!res.ok || !data.ok) {
      toast(data.error || "No se pudo reclamar.");
      return;
    }
    toast("Perfil reclamado.");
    fillProfile(data.profile);
    setView("editor");
  }

  function fillProfile(profile: Profile | null) {
    const form = document.querySelector<HTMLFormElement>("[data-profile-editor]");
    if (!form) return;

    const name = profile?.name || "";
    const slug = profile?.slug || "";
    const estado = profile?.estado || "Ciudad de México";
    const website = profile?.website || "";
    const description = profile?.description || "";
    const customCss = profile?.customCss || "";
    serviciosOrder = normalizeServicios(profile?.servicios || []);
    const status = profile?.status || "draft";

    const set = (field: string, value: string) => {
      const el = form.querySelector<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(
        `[data-field="${field}"]`,
      );
      if (el) el.value = value;
    };
    set("name", name);
    set("estado", estado);
    set("website", website);
    set("customCss", customCss);

    const slugEl = document.querySelector<HTMLElement>("[data-profile-slug]");
    const slugVal = document.querySelector<HTMLElement>("[data-profile-slug-value]");
    if (slugEl && slugVal) {
      if (slug) {
        slugEl.hidden = false;
        slugVal.textContent = `/directorio/${slug}/`;
      } else {
        slugEl.hidden = true;
        slugVal.textContent = "";
      }
    }

    renderServiciosPicker();

    const badge = document.querySelector<HTMLElement>("[data-status-badge]");
    if (badge) {
      const label = STATUS_LABEL[status] || status;
      badge.textContent =
        profile?.hasPublishedVersion && status !== "published"
          ? `${label} · versión pública activa`
          : label;
    }

    const pub = document.querySelector<HTMLAnchorElement>("[data-public-link]");
    if (pub) {
      pub.href = slug ? `/directorio/${slug}/` : "/directorio/";
      pub.textContent = profile?.hasPublishedVersion ? "Vista pública" : "Vista previa";
    }

    const cover = document.querySelector<HTMLElement>("[data-cover-preview]");
    if (cover) {
      cover.querySelector("img[data-cover-img]")?.remove();
      if (profile?.cover) {
        const img = document.createElement("img");
        img.src = profile.cover;
        img.alt = "";
        img.dataset.coverImg = "1";
        img.className = "absolute inset-0 h-full w-full object-cover";
        cover.prepend(img);
      }
    }

    const avatarWrap = document.querySelector<HTMLElement>("[data-avatar-preview]");
    if (avatarWrap) {
      avatarWrap.querySelector("img[data-avatar-img]")?.remove();
      const fallback = avatarWrap.querySelector<HTMLElement>("[data-avatar-fallback]");
      if (profile?.avatar) {
        if (fallback) fallback.hidden = true;
        const img = document.createElement("img");
        img.src = profile.avatar;
        img.alt = "";
        img.dataset.avatarImg = "1";
        img.className = "h-20 w-20 rounded-full object-cover ring-2 ring-dm-offblack/10";
        avatarWrap.insertBefore(img, avatarWrap.firstChild);
      } else if (fallback) {
        fallback.hidden = false;
      }
    }

    currentTier = profile?.tier || "free";
    currentGalleries = profile?.galleries || [];
    renderFonts(profile?.customFonts || [], currentTier);
    applyProThemeGate(currentTier);
    renderGalleries(currentGalleries, currentTier);

    const hidden = form.querySelector<HTMLInputElement>("[data-bio-html]");
    const mount = form.querySelector<HTMLElement>("[data-bio-editor]");
    const toolbar = form.querySelector<HTMLElement>("[data-bio-toolbar]");
    if (hidden) hidden.value = description;
    if (mount) {
      bio?.destroy();
      mount.innerHTML = "";
      bio = mountBioEditor({
        element: mount,
        content: description,
        onUpdate: (html) => {
          if (hidden) hidden.value = html;
        },
      });
      if (toolbar) bindBioToolbar(toolbar, bio.editor);
    }
  }

  function escapeHtmlText(s: string) {
    return s
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function servicioChipHtml(servicio: string, selected: boolean) {
    const safe = escapeHtmlText(servicio);
    const chipClass = selected
      ? "inline-block rounded border border-dm-offblack bg-dm-offblack px-2.5 py-1 text-sm text-dm-offwhite"
      : "inline-block rounded border border-dm-offblack/25 bg-white px-2.5 py-1 text-sm text-dm-offblack";
    const labelClass = selected ? "cursor-grab active:cursor-grabbing" : "cursor-pointer";
    return `<label class="${labelClass}" data-servicio-chip="${safe}" ${selected ? 'draggable="true"' : ""}>
      <input type="checkbox" name="servicios" value="${safe}" class="sr-only" data-servicio="${safe}" ${selected ? "checked" : ""} />
      <span class="${chipClass}">${safe}</span>
    </label>`;
  }

  function renderServiciosPicker() {
    const host = document.querySelector<HTMLElement>("[data-servicios-host]");
    if (!host) return;
    const selected = new Set(serviciosOrder);
    const unselected = SERVICIOS.filter((s) => !selected.has(s));
    host.innerHTML = [
      ...serviciosOrder.map((s) => servicioChipHtml(s, true)),
      ...unselected.map((s) => servicioChipHtml(s, false)),
    ].join("");
  }

  function reorderServicio(from: string, to: string) {
    if (from === to) return;
    const fromIdx = serviciosOrder.indexOf(from);
    const toIdx = serviciosOrder.indexOf(to);
    if (fromIdx < 0 || toIdx < 0) return;
    const next = [...serviciosOrder];
    next.splice(fromIdx, 1);
    next.splice(toIdx, 0, from);
    serviciosOrder = next;
    renderServiciosPicker();
  }

  function bindServiciosPicker() {
    const host = document.querySelector<HTMLElement>("[data-servicios-host]");
    if (!host || host.dataset.ready) return;
    host.dataset.ready = "1";
    renderServiciosPicker();

    host.addEventListener("change", (e) => {
      const box = e.target as HTMLInputElement;
      if (!box.matches?.("[data-servicio]")) return;
      const value = box.value;
      if (box.checked) {
        if (!serviciosOrder.includes(value)) serviciosOrder = [...serviciosOrder, value];
      } else {
        serviciosOrder = serviciosOrder.filter((s) => s !== value);
      }
      renderServiciosPicker();
    });

    // After a drag, the browser may fire a click that would toggle the chip — block it.
    host.addEventListener(
      "click",
      (e) => {
        if (!didServicioDrag) return;
        e.preventDefault();
        e.stopPropagation();
        didServicioDrag = false;
      },
      true,
    );

    host.addEventListener("dragstart", (e) => {
      const chip = (e.target as HTMLElement).closest<HTMLElement>("[data-servicio-chip]");
      if (!chip?.draggable || !chip.dataset.servicioChip) {
        e.preventDefault();
        return;
      }
      dragServicio = chip.dataset.servicioChip;
      didServicioDrag = false;
      chip.classList.add("opacity-60");
      e.dataTransfer?.setData("text/plain", dragServicio);
      if (e.dataTransfer) e.dataTransfer.effectAllowed = "move";
    });

    host.addEventListener("drag", () => {
      if (dragServicio) didServicioDrag = true;
    });

    host.addEventListener("dragend", (e) => {
      const chip = (e.target as HTMLElement).closest<HTMLElement>("[data-servicio-chip]");
      chip?.classList.remove("opacity-60");
      host.querySelectorAll("[data-servicio-chip].ring-2").forEach((el) => {
        el.classList.remove("ring-2", "ring-dm-pink");
      });
      dragServicio = null;
    });

    host.addEventListener("dragover", (e) => {
      const chip = (e.target as HTMLElement).closest<HTMLElement>("[data-servicio-chip]");
      if (!dragServicio || !chip?.draggable) return;
      e.preventDefault();
      if (e.dataTransfer) e.dataTransfer.dropEffect = "move";
      host.querySelectorAll("[data-servicio-chip].ring-2").forEach((el) => {
        el.classList.remove("ring-2", "ring-dm-pink");
      });
      if (chip.dataset.servicioChip !== dragServicio) {
        chip.classList.add("ring-2", "ring-dm-pink");
      }
    });

    host.addEventListener("dragleave", (e) => {
      const chip = (e.target as HTMLElement).closest<HTMLElement>("[data-servicio-chip]");
      chip?.classList.remove("ring-2", "ring-dm-pink");
    });

    host.addEventListener("drop", (e) => {
      e.preventDefault();
      const chip = (e.target as HTMLElement).closest<HTMLElement>("[data-servicio-chip]");
      const to = chip?.dataset.servicioChip;
      const from = dragServicio || e.dataTransfer?.getData("text/plain") || "";
      host.querySelectorAll("[data-servicio-chip].ring-2").forEach((el) => {
        el.classList.remove("ring-2", "ring-dm-pink");
      });
      if (!from || !to || !chip?.draggable) return;
      didServicioDrag = true;
      reorderServicio(from, to);
    });
  }

  function readForm(): Partial<Profile> & { customCss?: string } {
    const form = document.querySelector<HTMLFormElement>("[data-profile-editor]")!;
    const servicios = normalizeServicios(serviciosOrder);
    const hidden = form.querySelector<HTMLInputElement>("[data-bio-html]");
    if (bio && hidden) hidden.value = bio.getHTML();
    return {
      name: form.querySelector<HTMLInputElement>('[data-field="name"]')?.value || "",
      estado: form.querySelector<HTMLSelectElement>('[data-field="estado"]')?.value || "",
      website: form.querySelector<HTMLInputElement>('[data-field="website"]')?.value || "",
      customCss: form.querySelector<HTMLTextAreaElement>('[data-field="customCss"]')?.value || "",
      description: hidden?.value || "",
      servicios,
    };
  }

