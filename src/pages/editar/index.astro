  async function loadSession() {
    try {
      const res = await fetch("/api/auth/me", { credentials: "same-origin" });
      if (res.status === 401) {
        setView("login");
        return;
      }
      if (!res.headers.get("content-type")?.includes("json")) {
        if (res.status >= 500) {
          toast("API con error. Usa npm run dev:all (Astro + wrangler).");
        }
        setView("login");
        return;
      }
      const data = await res.json();
      if (!data.ok) {
        if (data.error) toast(data.error);
        setView("login");
        return;
      }
      const emailEl = document.querySelector<HTMLElement>("[data-user-email]");
      if (emailEl) emailEl.textContent = data.user.email;

      if (data.profile) {
        setView("editor");
        fillProfile(data.profile);
        void loadMediaQuota();
        if (new URLSearchParams(location.search).has("claimed")) {
          toast("Perfil reclamado — ya puedes editarlo.");
        }
        return;
      }

      const claimable = (data.claimable || []) as Claimable[];
      if (claimable.length > 0) {
        renderClaimList(claimable);
        setView("claim");
        return;
      }

      setView("editor");
      fillProfile(null);
      void loadMediaQuota();
    } catch {
      setView("login");
    }
  }

  function init() {
    const authForm = document.querySelector<HTMLFormElement>("[data-auth-form]");
    const editorForm = document.querySelector<HTMLFormElement>("[data-profile-editor]");
    if (authForm && !authForm.dataset.ready) {
      authForm.dataset.ready = "1";
      authForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const email = new FormData(authForm).get("email") as string;
        const msg = document.querySelector<HTMLElement>("[data-auth-message]");
        const linkEl = document.querySelector<HTMLElement>("[data-auth-link]");
        if (msg) msg.textContent = "Enviando…";
        if (linkEl) {
          linkEl.classList.add("hidden");
          linkEl.textContent = "";
        }
        try {
          const result = await requestMagicLink(email, "/editar/");
          if (!result.ok) {
            if (msg) msg.textContent = result.error || "No se pudo enviar.";
            return;
          }
          if (msg) msg.textContent = result.message || "Listo.";
          renderDevMagicLink(result, linkEl);
        } catch {
          if (msg) {
            msg.textContent =
              "API no disponible. Usa `wrangler dev` o el Worker desplegado (proxy /api).";
          }
        }
      });
    }

    const claimList = document.querySelector<HTMLElement>("[data-claim-list]");
    if (claimList && !claimList.dataset.ready) {
      claimList.dataset.ready = "1";
      claimList.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-claim-slug]");
        if (!btn?.dataset.claimSlug) return;
        void claimProfileSlug(btn.dataset.claimSlug);
      });
    }

    if (editorForm && !editorForm.dataset.ready) {
      editorForm.dataset.ready = "1";
      bindServiciosPicker();
      editorForm.addEventListener("submit", (e) => {
        e.preventDefault();
        void saveDraft();
      });
      document.querySelectorAll<HTMLElement>("[data-action]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const action = btn.dataset.action;
          if (action === "save") void saveDraft();
          if (action === "submit") void submitReview();
          if (action === "logout") void logout();
          if (action === "upload-cover") pickUpload("cover");
          if (action === "upload-avatar") pickUpload("avatar");
          if (action === "font-upload") pickFontUpload();
          if (action === "gallery-create") void createGallery();
        });
      });

      const galleryRoot = document.querySelector<HTMLElement>("[data-gallery-root]");
      if (galleryRoot && !galleryRoot.dataset.ready) {
        galleryRoot.dataset.ready = "1";
        galleryRoot.addEventListener("click", (e) => {
          const t = e.target as HTMLElement;
          const btn = t.closest<HTMLElement>("[data-action]");
          if (!btn) return;
          const action = btn.dataset.action;
          const galleryId = btn.dataset.galleryId || "";
          const imageId = btn.dataset.imageId || "";
          if (action === "gallery-upload") pickGalleryUpload(galleryId);
          if (action === "gallery-delete") void deleteGallery(galleryId);
          if (action === "gallery-delete-image") void deleteGalleryImage(galleryId, imageId);
        });
        galleryRoot.addEventListener(
          "blur",
          (e) => {
            const input = e.target as HTMLInputElement;
            if (!input.matches("[data-gallery-title]")) return;
            const galleryId = input.dataset.galleryTitle || "";
            const title = input.value.trim();
            if (galleryId && title) void saveGalleryTitle(galleryId, title);
          },
          true,
        );
      }

      const fontList = document.querySelector<HTMLElement>("[data-font-list]");
      if (fontList && !fontList.dataset.ready) {
        fontList.dataset.ready = "1";
        fontList.addEventListener("click", (e) => {
          const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-action='font-delete']");
          if (!btn?.dataset.fontId) return;
          void deleteFont(btn.dataset.fontId);
        });
      }

      const fontInput = document.querySelector<HTMLInputElement>("[data-font-input]");
      if (fontInput && !fontInput.dataset.ready) {
        fontInput.dataset.ready = "1";
        fontInput.addEventListener("change", () => {
          const file = fontInput.files?.[0];
          if (file) void uploadFontFile(file);
        });
      }

      const uploadInput = document.querySelector<HTMLInputElement>("[data-upload-input]");
      if (uploadInput && !uploadInput.dataset.ready) {
        uploadInput.dataset.ready = "1";
        uploadInput.addEventListener("change", async () => {
          const file = uploadInput.files?.[0];
          const kind = pendingUploadKind;
          pendingUploadKind = null;
          if (!file || !kind) return;

          if (kind === "avatar") {
            const cropped = await openAvatarCropper(file);
            if (!cropped) return;
            await uploadProfileImage("avatar", cropped);
            return;
          }

          await uploadProfileImage(kind, file);
        });
      }
      const galleryInput = document.querySelector<HTMLInputElement>("[data-gallery-input]");
      if (galleryInput && !galleryInput.dataset.ready) {
        galleryInput.dataset.ready = "1";
        galleryInput.addEventListener("change", () => {
          const file = galleryInput.files?.[0];
          if (file) void uploadGalleryFile(file);
        });
      }
    }

    void loadSession();
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>

