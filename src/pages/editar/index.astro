  let pendingUploadKind: "cover" | "avatar" | null = null;
  let pendingGalleryId: string | null = null;
  let uploadsBlocked = false;
  let currentTier = "free";
  let currentGalleries: ProfileGallery[] = [];
  let currentFonts: ProfileFont[] = [];

  function applyProThemeGate(tier: string) {
    const isPro = tier === "pro";
    const css = document.querySelector<HTMLTextAreaElement>("[data-field='customCss']");
    const hint = document.querySelector<HTMLElement>("[data-pro-theme-hint]");
    const fontPanel = document.querySelector<HTMLElement>("[data-font-panel]");
    const fontUpload = document.querySelector<HTMLButtonElement>("[data-action='font-upload']");
    const fontFamily = document.querySelector<HTMLInputElement>("[data-font-family]");
    if (css) css.disabled = !isPro;
    if (hint) hint.hidden = isPro;
    if (fontPanel) fontPanel.classList.toggle("opacity-60", !isPro);
    if (fontUpload) fontUpload.disabled = !isPro || uploadsBlocked;
    if (fontFamily) fontFamily.disabled = !isPro;
  }

  function renderFonts(fonts: ProfileFont[], tier: string) {
    const list = document.querySelector<HTMLElement>("[data-font-list]");
    const uploadBtn = document.querySelector<HTMLButtonElement>("[data-action='font-upload']");
    if (!list) return;
    currentFonts = fonts;
    if (!fonts.length) {
      list.innerHTML = `<li class="text-xs text-dm-offblack/45">Sin fuentes subidas.</li>`;
    } else {
      list.innerHTML = fonts
        .map(
          (f) =>
            `<li class="flex flex-wrap items-center justify-between gap-2 rounded border border-dm-offblack/10 px-2 py-1.5">
              <span class="font-mono text-xs">${f.family}</span>
              <span class="text-[10px] text-dm-offblack/45 uppercase">${f.format}</span>
              <button type="button" class="text-xs text-dm-offblack/55 hover:text-dm-offblack" data-action="font-delete" data-font-id="${f.id}" ${tier !== "pro" ? "disabled" : ""}>Quitar</button>
            </li>`,
        )
        .join("");
    }
    if (uploadBtn) {
      uploadBtn.disabled = tier !== "pro" || uploadsBlocked || fonts.length >= FONT_LIMITS.maxFonts;
    }
  }

  async function uploadFontFile(file: File) {
    const familyInput = document.querySelector<HTMLInputElement>("[data-font-family]");
    const family = familyInput?.value.trim() || "";
    if (!family) {
      toast("Escribe el nombre CSS de la fuente.");
      return;
    }
    setUploadBusy(true);
    toast("Subiendo fuente…");
    try {
      const body = new FormData();
      body.set("family", family);
      body.set("file", file, file.name);
      const res = await fetch("/api/me/profile/font", { method: "POST", credentials: "same-origin", body });
      const data = await res.json();
      if (!res.ok || !data.ok) {
        toast(data.error || "No se pudo subir la fuente.");
        return;
      }
      fillProfile(data.profile);
      if (familyInput) familyInput.value = "";
      toast("Fuente subida.");
    } catch {
      toast("API no disponible.");
    } finally {
      setUploadBusy(false);
    }
  }

