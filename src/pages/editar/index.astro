  function formatBytes(bytes: number) {
    if (bytes < 1024 * 1024) return `${Math.round(bytes / 1024)} KB`;
    if (bytes < 1024 * 1024 * 1024) return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
    return `${(bytes / (1024 * 1024 * 1024)).toFixed(2)} GB`;
  }

  function applyMediaQuota(quota?: {
    storageBytes: number;
    storageLimitBytes: number;
    classAOpsThisMonth: number;
    classAOpsLimit: number;
    uploadsBlocked?: boolean;
  }) {
    const wrap = document.querySelector<HTMLElement>("[data-media-quota]");
    if (!wrap || !quota) {
      if (wrap) wrap.hidden = true;
      uploadsBlocked = false;
      return;
    }

    wrap.hidden = false;
    const storageEl = wrap.querySelector<HTMLElement>("[data-quota-storage]");
    const opsEl = wrap.querySelector<HTMLElement>("[data-quota-ops]");
    const blockedEl = wrap.querySelector<HTMLElement>("[data-quota-blocked]");
    if (storageEl) {
      storageEl.textContent = `Almacenamiento: ${formatBytes(quota.storageBytes)} / ${formatBytes(quota.storageLimitBytes)}`;
    }
    if (opsEl) {
      opsEl.textContent = `Subidas este mes: ${quota.classAOpsThisMonth.toLocaleString("es-MX")} / ${quota.classAOpsLimit.toLocaleString("es-MX")}`;
    }
    uploadsBlocked = Boolean(quota.uploadsBlocked);
    if (blockedEl) blockedEl.classList.toggle("hidden", !uploadsBlocked);
    document
      .querySelectorAll<HTMLButtonElement>(
        "[data-action='upload-cover'], [data-action='upload-avatar'], [data-action='gallery-upload'], [data-action='gallery-create'], [data-action='font-upload']",
      )
      .forEach((btn) => {
        btn.disabled = uploadsBlocked || btn.dataset.busy === "1";
      });
    renderGalleries(currentGalleries, currentTier);
    renderFonts(currentFonts, currentTier);
    applyProThemeGate(currentTier);
  }

  function galleryLimitsFor(tier: string) {
    return tier === "pro" ? GALLERY_LIMITS.pro : GALLERY_LIMITS.free;
  }

  function renderGalleries(galleries: ProfileGallery[], tier: string) {
    const root = document.querySelector<HTMLElement>("[data-gallery-root]");
    const createBtn = document.querySelector<HTMLButtonElement>("[data-action='gallery-create']");
    const limits = galleryLimitsFor(tier);
    if (!root) return;

    const list =
      galleries.length > 0
        ? galleries
        : [{ id: "", title: "Galería", images: [] as GalleryImage[] }];

    if (createBtn) {
      createBtn.classList.toggle("hidden", tier !== "pro");
      createBtn.disabled = uploadsBlocked || galleries.length >= limits.maxGalleries;
    }

    root.innerHTML = list
      .map((gallery) => {
        const gid = gallery.id || "pending";
        const count = gallery.images?.length || 0;
        const atLimit = count >= limits.maxImages;
        const titleEsc = gallery.title.replace(/"/g, "&quot;");
        const imgs = (gallery.images || [])
          .map(
            (img) =>
              `<div class="group relative aspect-square overflow-hidden rounded border border-dm-offblack/15 bg-dm-blue">
              <img src="${img.url}" alt="" class="h-full w-full object-cover" loading="lazy" />
              <button type="button" class="absolute top-1 right-1 rounded bg-dm-offblack/70 px-1.5 py-0.5 text-[10px] text-white opacity-0 transition group-hover:opacity-100" data-action="gallery-delete-image" data-gallery-id="${gid}" data-image-id="${img.id}">×</button>
            </div>`,
          )
          .join("");

        const canDeleteGallery = tier === "pro" && galleries.length > 1 && gallery.id;
        const titleReadonly = !(tier === "pro" && gallery.id);
        return `<div class="rounded border border-dm-offblack/15 bg-white/80 p-3" data-gallery-panel="${gid}">
          <div class="mb-2 flex flex-wrap items-center justify-between gap-2">
            <input type="text" value="${titleEsc}" class="min-w-[8rem] flex-1 rounded border border-dm-offblack/15 px-2 py-1 text-sm ${titleReadonly ? "pointer-events-none opacity-70" : ""}" data-gallery-title="${gid}" ${titleReadonly ? "readonly" : ""} />
            <span class="text-[11px] text-dm-offblack/50">${count}/${limits.maxImages}</span>
          </div>
          <div class="grid grid-cols-3 gap-2 sm:grid-cols-4">${imgs || `<p class="col-span-full text-xs text-dm-offblack/45">Sin imágenes aún.</p>`}</div>
          <div class="mt-2 flex flex-wrap gap-2">
            <button type="button" class="rounded border border-dm-offblack/20 px-2.5 py-1 text-xs disabled:opacity-50" data-action="gallery-upload" data-gallery-id="${gid}" ${atLimit || uploadsBlocked ? "disabled" : ""}>Subir imagen</button>
            ${canDeleteGallery ? `<button type="button" class="rounded border border-dm-offblack/15 px-2.5 py-1 text-xs text-dm-offblack/60" data-action="gallery-delete" data-gallery-id="${gid}">Eliminar galería</button>` : ""}
          </div>
        </div>`;
      })
      .join("");
  }

