---
/**
 * Member profile editor — magic-link auth + TipTap bio + D1 save.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import { MEXICO_ESTADOS, SERVICIOS } from "../../data/taxonomy";
---

<BaseLayout
  title="Editar perfil — DIMELA.mx"
  description="Editor de perfil para miembros DIMELA."
  headerVariant="simple"
  homeHref="/"
>
  <div class="mx-auto max-w-3xl pb-16">
    <!-- Login -->
    <section
      class="mb-10 space-y-4 rounded border border-dm-offblack/15 bg-white p-5"
      data-auth-panel
      hidden
    >
      <div>
        <p class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase">
          Cuenta
        </p>
        <h1 class="mt-1 text-2xl tracking-wide">Entrar con email</h1>
        <p class="mt-1 text-sm text-dm-offblack/65">
          Te enviamos un enlace mágico (sin contraseña). En desarrollo el enlace aparece aquí.
        </p>
      </div>
      <form class="flex flex-col gap-3 sm:flex-row sm:items-end" data-auth-form>
        <label class="block min-w-0 flex-1 space-y-1.5">
          <span class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase"
            >Email</span
          >
          <input
            type="email"
            name="email"
            required
            placeholder="tu@email.com"
            value="romina@tortilla.studio"
            class="w-full rounded border border-dm-offblack/20 bg-dm-offwhite px-3 py-2 text-sm outline-none focus:border-dm-offblack/50"
          />
        </label>
        <button
          type="submit"
          class="rounded border border-dm-offblack bg-dm-pink px-4 py-2 text-sm text-dm-offblack hover:bg-dm-offblack hover:text-white"
        >
          Enviar enlace
        </button>
      </form>
      <p class="text-sm text-dm-offblack/60" data-auth-message></p>
      <p class="hidden break-all text-sm" data-auth-link></p>
    </section>

    <!-- Editor (shown when logged in) -->
    <div data-editor-root hidden>
      <header class="mb-8 space-y-3">
        <p class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase">
          Cuenta · <span data-user-email></span>
        </p>
        <div class="flex flex-wrap items-end justify-between gap-3">
          <div>
            <h1 class="text-3xl tracking-wide">Editar perfil</h1>
            <p class="mt-1 text-sm text-dm-offblack/65">
              Guardado en D1. Publicado solo tras aprobación.
            </p>
          </div>
          <span
            class="rounded border border-dm-offblack/20 bg-dm-blue/60 px-2.5 py-1 text-[11px] font-semibold tracking-wide text-dm-offblack uppercase"
            data-status-badge
          >
            —
          </span>
        </div>

        <div class="flex flex-wrap gap-2 pt-1">
          <button
            type="button"
            class="rounded border border-dm-offblack bg-dm-pink px-3 py-1.5 text-sm text-dm-offblack transition hover:bg-dm-offblack hover:text-white"
            data-action="save"
          >
            Guardar borrador
          </button>
          <button
            type="button"
            class="rounded border border-dm-offblack/25 bg-dm-offblack px-3 py-1.5 text-sm text-dm-offwhite transition hover:opacity-90"
            data-action="submit"
          >
            Enviar a revisión
          </button>
          <a
            href="/directorio/"
            class="rounded border border-dm-offblack/20 bg-white px-3 py-1.5 text-sm text-dm-offblack/80 hover:border-dm-offblack/40"
            data-public-link
          >
            Vista pública
          </a>
          <button
            type="button"
            class="rounded border border-dm-offblack/15 px-3 py-1.5 text-sm text-dm-offblack/60 hover:border-dm-offblack/30"
            data-action="logout"
          >
            Salir
          </button>
        </div>
        <p class="hidden text-sm text-dm-offblack/55" data-editor-toast role="status"></p>
      </header>

      <form class="space-y-10" data-profile-editor novalidate>
        <section class="space-y-4" aria-labelledby="editor-identity">
          <div>
            <h2 id="editor-identity" class="text-lg tracking-wide">Identidad</h2>
            <p class="mt-1 text-sm text-dm-offblack/60">Nombre público y URL del perfil.</p>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block space-y-1.5 sm:col-span-2">
              <span class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase"
                >Nombre</span
              >
              <input
                type="text"
                name="name"
                data-field="name"
                class="w-full rounded border border-dm-offblack/20 bg-white px-3 py-2 text-sm outline-none focus:border-dm-offblack/50"
              />
            </label>
            <label class="block space-y-1.5">
              <span class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase"
                >Slug</span
              >
              <input
                type="text"
                name="slug"
                data-field="slug"
                class="w-full rounded border border-dm-offblack/20 bg-dm-offwhite px-3 py-2 font-mono text-sm outline-none focus:border-dm-offblack/50"
              />
            </label>
            <label class="block space-y-1.5">
              <span class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase"
                >Sitio web</span
              >
              <input
                type="url"
                name="website"
                data-field="website"
                placeholder="https://"
                class="w-full rounded border border-dm-offblack/20 bg-white px-3 py-2 text-sm outline-none focus:border-dm-offblack/50"
              />
            </label>
          </div>
        </section>

        <section class="space-y-4" aria-labelledby="editor-facets">
          <div>
            <h2 id="editor-facets" class="text-lg tracking-wide">Directorio</h2>
            <p class="mt-1 text-sm text-dm-offblack/60">Ubicación y servicios.</p>
          </div>
          <label class="block space-y-1.5">
            <span class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase"
              >Ubicación</span
            >
            <select
              name="estado"
              data-field="estado"
              class="w-full rounded border border-dm-offblack/20 bg-dm-blue/40 px-3 py-2 text-sm outline-none focus:border-dm-offblack/50"
            >
              {MEXICO_ESTADOS.map((estado) => <option value={estado}>{estado}</option>)}
            </select>
          </label>
          <fieldset>
            <legend
              class="mb-2 text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase"
            >
              Servicios
            </legend>
            <div class="flex flex-wrap gap-1.5" data-servicios-host>
              {
                SERVICIOS.map((servicio) => (
                  <label class="cursor-pointer">
                    <input
                      type="checkbox"
                      name="servicios"
                      value={servicio}
                      class="peer sr-only"
                      data-servicio={servicio}
                    />
                    <span class="inline-block rounded border border-dm-offblack/25 bg-white px-2.5 py-1 text-sm text-dm-offblack peer-checked:border-dm-offblack peer-checked:bg-dm-offblack peer-checked:text-dm-offwhite">
                      {servicio}
                    </span>
                  </label>
                ))
              }
            </div>
          </fieldset>
        </section>

        <section class="space-y-4" aria-labelledby="editor-media">
          <div>
            <h2 id="editor-media" class="text-lg tracking-wide">Medios</h2>
            <p class="mt-1 text-sm text-dm-offblack/60">
              Portada y avatar se guardan en R2. Guarda el borrador al menos una vez antes de subir.
            </p>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="space-y-2">
              <p class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase">
                Portada
              </p>
              <div
                class="relative flex aspect-[16/10] items-end overflow-hidden rounded-md border border-dashed border-dm-offblack/25 bg-dm-blue"
                data-cover-preview
              >
                <div class="relative z-10 w-full bg-gradient-to-t from-dm-offblack/50 to-transparent p-3">
                  <button
                    type="button"
                    class="rounded border border-white/40 bg-white/90 px-2.5 py-1 text-xs text-dm-offblack disabled:opacity-50"
                    data-action="upload-cover"
                  >
                    Subir portada
                  </button>
                </div>
              </div>
              <p class="text-[11px] text-dm-offblack/50">JPEG, PNG, WebP o GIF · máx. 5 MB</p>
            </div>
            <div class="space-y-2">
              <p class="text-[10px] font-semibold tracking-wide text-dm-offblack/45 uppercase">
                Avatar
              </p>
              <div
                class="flex aspect-square max-w-[12rem] flex-col items-center justify-center gap-3 rounded-md border border-dashed border-dm-offblack/25 bg-white p-4"
                data-avatar-preview
              >
                <div
                  class="flex h-20 w-20 items-center justify-center overflow-hidden rounded-full bg-dm-blue text-sm text-dm-offblack/40"
                  data-avatar-fallback
                >
                  Aa
                </div>
                <button
                  type="button"
                  class="rounded border border-dm-offblack/20 px-2.5 py-1 text-xs text-dm-offblack/80 disabled:opacity-50"
                  data-action="upload-avatar"
                >
                  Subir avatar
                </button>
              </div>
              <p class="text-[11px] text-dm-offblack/50">JPEG, PNG, WebP o GIF · máx. 2 MB</p>
            </div>
          </div>
          <input
            type="file"
            class="sr-only"
            accept="image/jpeg,image/png,image/webp,image/gif"
            data-upload-input
            tabindex="-1"
          />
          <div
            class="rounded border border-dm-offblack/15 bg-dm-offwhite/60 px-3 py-2.5 text-[11px] text-dm-offblack/65"
            data-media-quota
            hidden
          >
            <p class="font-medium text-dm-offblack/80">Uso de almacenamiento (directorio)</p>
            <p class="mt-1" data-quota-storage>—</p>
            <p class="mt-0.5" data-quota-ops>—</p>
            <p class="mt-1 hidden text-dm-pink" data-quota-blocked>
              Límite alcanzado. Las subidas están pausadas hasta liberar espacio o el próximo mes.
            </p>
          </div>
        </section>

        <section class="space-y-4" aria-labelledby="editor-bio">
          <div>
            <h2 id="editor-bio" class="text-lg tracking-wide">Bio</h2>
            <p class="mt-1 text-sm text-dm-offblack/60">TipTap · HTML sanitizado al guardar.</p>
          </div>
          <div class="overflow-hidden rounded border border-dm-offblack/20 bg-white" data-tiptap-shell>
            <div
              class="flex flex-wrap gap-1 border-b border-dm-offblack/10 bg-dm-offwhite px-2 py-1.5"
              data-bio-toolbar
            >
              <button type="button" data-bio-cmd="bold" class="rounded border border-dm-offblack/15 bg-white px-2 py-0.5 text-[11px] font-bold">B</button>
              <button type="button" data-bio-cmd="italic" class="rounded border border-dm-offblack/15 bg-white px-2 py-0.5 text-[11px] italic">I</button>
              <button type="button" data-bio-cmd="h2" class="rounded border border-dm-offblack/15 bg-white px-2 py-0.5 text-[11px]">H2</button>
              <button type="button" data-bio-cmd="bullet" class="rounded border border-dm-offblack/15 bg-white px-2 py-0.5 text-[11px]">Lista</button>
              <button type="button" data-bio-cmd="link" class="rounded border border-dm-offblack/15 bg-white px-2 py-0.5 text-[11px]">Enlace</button>
            </div>
            <div data-bio-editor></div>
            <input type="hidden" name="description" value="" data-bio-html />
          </div>
        </section>

        <section class="space-y-4" aria-labelledby="editor-css">
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <div>
              <h2 id="editor-css" class="text-lg tracking-wide">CSS personalizado</h2>
              <p class="mt-1 text-sm text-dm-offblack/60">Solo Pro — scoped a tarjeta + perfil.</p>
            </div>
            <span class="rounded bg-dm-pink px-2 py-0.5 text-[10px] font-semibold tracking-wide text-dm-offblack uppercase">Pro</span>
          </div>
          <textarea
            name="customCss"
            data-field="customCss"
            rows="5"
            placeholder={`.profile-card {\n  /* tu estilo */\n}`}
            class="w-full rounded border border-dm-offblack/20 bg-dm-offblack px-3 py-3 font-mono text-xs leading-relaxed text-dm-offwhite outline-none placeholder:text-dm-offwhite/35 focus:border-dm-pink/50"
          ></textarea>
        </section>

        <div class="flex flex-wrap gap-2 border-t border-dm-offblack/10 pt-6">
          <button
            type="submit"
            class="rounded border border-dm-offblack bg-dm-pink px-4 py-2 text-sm text-dm-offblack transition hover:bg-dm-offblack hover:text-white"
          >
            Guardar borrador
          </button>
          <button
            type="button"
            class="rounded border border-dm-offblack/25 px-4 py-2 text-sm text-dm-offblack/70"
            data-action="submit"
          >
            Enviar a revisión
          </button>
        </div>
      </form>
    </div>
  </div>
</BaseLayout>

<script>
  import { bindBioToolbar, mountBioEditor, type BioEditor } from "../../lib/bioEditor";

  type Profile = {
    slug: string;
    name: string;
    estado: string;
    servicios: string[];
    description: string;
    website?: string;
    tier: string;
    cover: string | null;
    avatar: string | null;
    customCss?: string;
    status: string;
  };

  const STATUS_LABEL: Record<string, string> = {
    draft: "Borrador",
    pending_review: "En revisión",
    published: "Publicado",
    rejected: "Rechazado",
  };

  let bio: BioEditor | null = null;

  function toast(message: string) {
    const el = document.querySelector<HTMLElement>("[data-editor-toast]");
    if (!el) return;
    el.textContent = message;
    el.classList.remove("hidden");
    window.setTimeout(() => el.classList.add("hidden"), 2800);
  }

  function showLogin(show: boolean) {
    const auth = document.querySelector<HTMLElement>("[data-auth-panel]");
    const editor = document.querySelector<HTMLElement>("[data-editor-root]");
    if (auth) auth.hidden = !show;
    if (editor) editor.hidden = show;
  }

  function fillProfile(profile: Profile | null) {
    const form = document.querySelector<HTMLFormElement>("[data-profile-editor]");
    if (!form) return;

    const name = profile?.name || "";
    const slug = profile?.slug || "";
    const estado = profile?.estado || "Ciudad de México";
    const website = profile?.website || "";
    const description = profile?.description || "";
    const customCss = profile?.customCss || "";
    const servicios = new Set(profile?.servicios || []);
    const status = profile?.status || "draft";

    const set = (field: string, value: string) => {
      const el = form.querySelector<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(
        `[data-field="${field}"]`,
      );
      if (el) el.value = value;
    };
    set("name", name);
    set("slug", slug);
    set("estado", estado);
    set("website", website);
    set("customCss", customCss);

    form.querySelectorAll<HTMLInputElement>("[data-servicio]").forEach((box) => {
      box.checked = servicios.has(box.value);
    });

    const badge = document.querySelector<HTMLElement>("[data-status-badge]");
    if (badge) badge.textContent = STATUS_LABEL[status] || status;

    const pub = document.querySelector<HTMLAnchorElement>("[data-public-link]");
    if (pub) {
      pub.href = slug ? `/directorio/${slug}/` : "/directorio/";
      pub.textContent = status === "published" ? "Vista pública" : "Vista previa";
    }

    const cover = document.querySelector<HTMLElement>("[data-cover-preview]");
    if (cover) {
      cover.querySelector("img[data-cover-img]")?.remove();
      if (profile?.cover) {
        const img = document.createElement("img");
        img.src = profile.cover;
        img.alt = "";
        img.dataset.coverImg = "1";
        img.className = "absolute inset-0 h-full w-full object-cover";
        cover.prepend(img);
      }
    }

    const avatarWrap = document.querySelector<HTMLElement>("[data-avatar-preview]");
    if (avatarWrap) {
      avatarWrap.querySelector("img[data-avatar-img]")?.remove();
      const fallback = avatarWrap.querySelector<HTMLElement>("[data-avatar-fallback]");
      if (profile?.avatar) {
        if (fallback) fallback.hidden = true;
        const img = document.createElement("img");
        img.src = profile.avatar;
        img.alt = "";
        img.dataset.avatarImg = "1";
        img.className = "h-20 w-20 rounded-full object-cover ring-2 ring-dm-offblack/10";
        avatarWrap.insertBefore(img, avatarWrap.firstChild);
      } else if (fallback) {
        fallback.hidden = false;
      }
    }

    const hidden = form.querySelector<HTMLInputElement>("[data-bio-html]");
    const mount = form.querySelector<HTMLElement>("[data-bio-editor]");
    const toolbar = form.querySelector<HTMLElement>("[data-bio-toolbar]");
    if (hidden) hidden.value = description;
    if (mount) {
      bio?.destroy();
      mount.innerHTML = "";
      bio = mountBioEditor({
        element: mount,
        content: description,
        onUpdate: (html) => {
          if (hidden) hidden.value = html;
        },
      });
      if (toolbar) bindBioToolbar(toolbar, bio.editor);
    }
  }

  function readForm(): Partial<Profile> & { customCss?: string } {
    const form = document.querySelector<HTMLFormElement>("[data-profile-editor]")!;
    const servicios = [...form.querySelectorAll<HTMLInputElement>("[data-servicio]:checked")].map(
      (el) => el.value,
    );
    const hidden = form.querySelector<HTMLInputElement>("[data-bio-html]");
    if (bio && hidden) hidden.value = bio.getHTML();
    return {
      name: form.querySelector<HTMLInputElement>('[data-field="name"]')?.value || "",
      slug: form.querySelector<HTMLInputElement>('[data-field="slug"]')?.value || "",
      estado: form.querySelector<HTMLSelectElement>('[data-field="estado"]')?.value || "",
      website: form.querySelector<HTMLInputElement>('[data-field="website"]')?.value || "",
      customCss: form.querySelector<HTMLTextAreaElement>('[data-field="customCss"]')?.value || "",
      description: hidden?.value || "",
      servicios,
    };
  }

  async function saveDraft() {
    const body = readForm();
    const res = await fetch("/api/me/profile", {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      credentials: "same-origin",
      body: JSON.stringify(body),
    });
    const data = await res.json();
    if (!res.ok || !data.ok) {
      toast(data.error || "No se pudo guardar.");
      return;
    }
    fillProfile(data.profile);
    toast("Guardado en D1.");
  }

  async function submitReview() {
    await saveDraft();
    const res = await fetch("/api/me/profile/submit", {
      method: "POST",
      credentials: "same-origin",
    });
    const data = await res.json();
    if (!res.ok || !data.ok) {
      toast(data.error || "No se pudo enviar.");
      return;
    }
    fillProfile(data.profile);
    toast("Enviado a revisión.");
  }

  async function logout() {
    await fetch("/api/auth/logout", { method: "POST", credentials: "same-origin" });
    showLogin(true);
    toast("Sesión cerrada.");
  }

  let pendingUploadKind: "cover" | "avatar" | null = null;
  let uploadsBlocked = false;

  function formatBytes(bytes: number) {
    if (bytes < 1024 * 1024) return `${Math.round(bytes / 1024)} KB`;
    if (bytes < 1024 * 1024 * 1024) return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
    return `${(bytes / (1024 * 1024 * 1024)).toFixed(2)} GB`;
  }

  function applyMediaQuota(quota?: {
    storageBytes: number;
    storageLimitBytes: number;
    classAOpsThisMonth: number;
    classAOpsLimit: number;
    uploadsBlocked?: boolean;
  }) {
    const wrap = document.querySelector<HTMLElement>("[data-media-quota]");
    if (!wrap || !quota) {
      if (wrap) wrap.hidden = true;
      uploadsBlocked = false;
      return;
    }

    wrap.hidden = false;
    const storageEl = wrap.querySelector<HTMLElement>("[data-quota-storage]");
    const opsEl = wrap.querySelector<HTMLElement>("[data-quota-ops]");
    const blockedEl = wrap.querySelector<HTMLElement>("[data-quota-blocked]");
    if (storageEl) {
      storageEl.textContent = `Almacenamiento: ${formatBytes(quota.storageBytes)} / ${formatBytes(quota.storageLimitBytes)}`;
    }
    if (opsEl) {
      opsEl.textContent = `Subidas este mes: ${quota.classAOpsThisMonth.toLocaleString("es-MX")} / ${quota.classAOpsLimit.toLocaleString("es-MX")}`;
    }
    uploadsBlocked = Boolean(quota.uploadsBlocked);
    if (blockedEl) blockedEl.classList.toggle("hidden", !uploadsBlocked);
    document.querySelectorAll<HTMLButtonElement>("[data-action='upload-cover'], [data-action='upload-avatar']").forEach(
      (btn) => {
        if (!btn.disabled) btn.disabled = uploadsBlocked;
      },
    );
  }

  async function loadMediaQuota() {
    try {
      const res = await fetch("/api/me/media/quota", { credentials: "same-origin" });
      if (!res.ok) return;
      const data = await res.json();
      if (data.ok && data.quota) applyMediaQuota(data.quota);
    } catch {
      /* quota optional when API unavailable */
    }
  }

  function setUploadBusy(busy: boolean) {
    document.querySelectorAll<HTMLButtonElement>("[data-action='upload-cover'], [data-action='upload-avatar']").forEach(
      (btn) => {
        btn.disabled = busy || uploadsBlocked;
      },
    );
  }

  function pickUpload(kind: "cover" | "avatar") {
    if (uploadsBlocked) {
      toast("Límite de almacenamiento alcanzado. Contacta al equipo DIMELA.");
      return;
    }
    const input = document.querySelector<HTMLInputElement>("[data-upload-input]");
    if (!input) return;
    pendingUploadKind = kind;
    input.value = "";
    input.click();
  }

  async function uploadSelectedFile(file: File) {
    const kind = pendingUploadKind;
    pendingUploadKind = null;
    if (!kind) return;

    setUploadBusy(true);
    toast(kind === "cover" ? "Subiendo portada…" : "Subiendo avatar…");
    try {
      const body = new FormData();
      body.set("kind", kind);
      body.set("file", file, file.name || `${kind}.jpg`);
      const res = await fetch("/api/me/profile/upload", {
        method: "POST",
        credentials: "same-origin",
        body,
      });
      const data = await res.json();
      if (!res.ok || !data.ok) {
        toast(data.error || "No se pudo subir la imagen.");
        return;
      }
      fillProfile(data.profile);
      if (data.quota) applyMediaQuota(data.quota);
      toast(kind === "cover" ? "Portada actualizada." : "Avatar actualizado.");
    } catch {
      toast("API no disponible. Usa `wrangler dev` (proxy /api).");
    } finally {
      setUploadBusy(false);
    }
  }

  async function loadSession() {
    try {
      const res = await fetch("/api/auth/me", { credentials: "same-origin" });
      if (res.status === 401 || !res.headers.get("content-type")?.includes("json")) {
        showLogin(true);
        return;
      }
      const data = await res.json();
      if (!data.ok) {
        showLogin(true);
        return;
      }
      showLogin(false);
      const emailEl = document.querySelector<HTMLElement>("[data-user-email]");
      if (emailEl) emailEl.textContent = data.user.email;
      fillProfile(data.profile);
      void loadMediaQuota();
    } catch {
      showLogin(true);
    }
  }

  function init() {
    const authForm = document.querySelector<HTMLFormElement>("[data-auth-form]");
    const editorForm = document.querySelector<HTMLFormElement>("[data-profile-editor]");
    if (authForm && !authForm.dataset.ready) {
      authForm.dataset.ready = "1";
      authForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const email = new FormData(authForm).get("email") as string;
        const msg = document.querySelector<HTMLElement>("[data-auth-message]");
        const linkEl = document.querySelector<HTMLElement>("[data-auth-link]");
        if (msg) msg.textContent = "Enviando…";
        if (linkEl) {
          linkEl.classList.add("hidden");
          linkEl.textContent = "";
        }
        try {
          const res = await fetch("/api/auth/request", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email }),
          });
          const data = await res.json();
          if (!res.ok || !data.ok) {
            if (msg) msg.textContent = data.error || "No se pudo enviar.";
            return;
          }
          if (msg) msg.textContent = data.message || "Enlace listo.";
          if (data.verifyUrl && linkEl) {
            linkEl.classList.remove("hidden");
            linkEl.innerHTML = `<a class="text-dm-offblack underline" href="${data.verifyUrl}">Abrir enlace mágico</a>`;
          }
        } catch {
          if (msg) {
            msg.textContent =
              "API no disponible. Usa `wrangler dev` o el Worker desplegado (proxy /api).";
          }
        }
      });
    }

    if (editorForm && !editorForm.dataset.ready) {
      editorForm.dataset.ready = "1";
      editorForm.addEventListener("submit", (e) => {
        e.preventDefault();
        void saveDraft();
      });
      document.querySelectorAll<HTMLElement>("[data-action]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const action = btn.dataset.action;
          if (action === "save") void saveDraft();
          if (action === "submit") void submitReview();
          if (action === "logout") void logout();
          if (action === "upload-cover") pickUpload("cover");
          if (action === "upload-avatar") pickUpload("avatar");
        });
      });
      const uploadInput = document.querySelector<HTMLInputElement>("[data-upload-input]");
      if (uploadInput && !uploadInput.dataset.ready) {
        uploadInput.dataset.ready = "1";
        uploadInput.addEventListener("change", () => {
          const file = uploadInput.files?.[0];
          if (file) void uploadSelectedFile(file);
        });
      }
    }

    void loadSession();
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>

