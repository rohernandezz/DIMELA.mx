---
/**
 * Profile detail — content from /api/profile (D1); paths from emitted profiles.json.
 * Unknown D1 slugs are served via Worker rewrite → /directorio/ver/ (same client shell).
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProfileDetailClient from "../../components/ProfileDetailClient.astro";
import { readEmittedProfiles } from "../../lib/emittedProfiles";

export function getStaticPaths() {
  return readEmittedProfiles().map((profile) => ({
    params: { slug: profile.slug },
  }));
}

const { slug } = Astro.params;
---

<BaseLayout title="Perfil — DIMELA.mx" headerVariant="simple" homeHref="/" showTagline>
  <ProfileDetailClient slug={slug} />
</BaseLayout>
