---
/**
 * Scaffold homepage — single card grid mockup (Free + Pro).
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import ProfileCard from "../components/ProfileCard.astro";
import { MOCK_PROFILES } from "../data/mockProfiles";
---

<BaseLayout title="DIMELA.mx — Directorio Mexicano de Letristas">
  <section class="mb-8 space-y-2">
    <p class="text-lg leading-relaxed">
      Descubre a letristas Mexicanxs: tipografía, lettering, caligrafía, rotulación y más.
    </p>
    <p class="text-xs tracking-wide text-dm-offblack/50 uppercase">
      Mockup visual · grid simple · Free / Pro
    </p>
  </section>

  <section aria-label="Directorio">
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {MOCK_PROFILES.map((profile) => <ProfileCard profile={profile} />)}
    </div>
  </section>
</BaseLayout>
