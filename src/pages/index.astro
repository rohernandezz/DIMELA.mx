---
/**
 * Homepage — Option B filter bar; grid filled from /api/search (D1).
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import DirectoryFilterBar from "../components/DirectoryFilterBar.astro";
---

<BaseLayout title="DIMELA.mx — Directorio Mexicano de Letristas" headerVariant="simple" homeHref="/">
  <DirectoryFilterBar />
  <section aria-label="Directorio">
    <div
      class="grid auto-rows-fr grid-cols-[repeat(auto-fill,minmax(min(100%,18.5rem),1fr))] gap-4 sm:gap-5"
      data-profile-grid
    ></div>
    <p class="mt-8 text-center text-sm text-dm-offblack/55" data-filter-empty>
      Cargando directorio…
    </p>
  </section>
</BaseLayout>
