---
/**
 * Scaffold homepage — FilterBar visual prototype comes next.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="DIMELA.mx — Directorio Mexicano de Letristas">
  <section class="space-y-4">
    <p class="text-lg leading-relaxed">
      Descubre a letristas Mexicanxs: tipografía, lettering, caligrafía, rotulación y más.
    </p>
    <p class="rounded border border-dashed border-black/30 bg-white/60 px-4 py-6 text-sm text-black/70">
      Scaffold Astro + Tailwind + Cloudflare Worker listo. Siguiente paso: prototipo visual del
      FilterBar (búsqueda + chips de servicio y ubicación).
    </p>
  </section>
</BaseLayout>
