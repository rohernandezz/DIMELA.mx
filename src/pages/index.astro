---
/**
 * Homepage — Option B filter bar (chosen discovery UI).
 * Mock profiles: src/data/mockProfiles.ts
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import ProfileCard from "../components/ProfileCard.astro";
import DirectoryFilterBar from "../components/DirectoryFilterBar.astro";
import { MOCK_PROFILES } from "../data/mockProfiles";
---

<BaseLayout title="DIMELA.mx — Directorio Mexicano de Letristas" headerVariant="simple" homeHref="/">
  <DirectoryFilterBar />
  <section aria-label="Directorio">
    <div
      class="grid auto-rows-fr grid-cols-[repeat(auto-fill,minmax(min(100%,18.5rem),1fr))] gap-4 sm:gap-5"
      data-profile-grid
    >
      {MOCK_PROFILES.map((profile) => <ProfileCard profile={profile} />)}
    </div>
    <p class="mt-8 hidden text-center text-sm text-dm-offblack/55" data-filter-empty>
      No hay perfiles con esos filtros.
    </p>
  </section>
</BaseLayout>
