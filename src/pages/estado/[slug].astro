---
/**
 * Profiles locked to one estado; FilterBar still filters by servicio + text.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProfileCard from "../../components/ProfileCard.astro";
import DirectoryFilterBar from "../../components/DirectoryFilterBar.astro";
import { MOCK_PROFILES } from "../../data/mockProfiles";
import { MEXICO_ESTADOS } from "../../data/taxonomy";
import { estadoFromSlug, estadoSlug } from "../../lib/slugs";

export function getStaticPaths() {
  return MEXICO_ESTADOS.map((estado) => ({
    params: { slug: estadoSlug(estado) },
  }));
}

const { slug } = Astro.params;
const estado = estadoFromSlug(slug!);
if (!estado) {
  return Astro.redirect("/404");
}

const profiles = MOCK_PROFILES.filter((p) => p.estado === estado);
---

<BaseLayout title={`${estado} — DIMELA.mx`} headerVariant="simple" homeHref="/">
  <header class="mb-4">
    <p class="mb-2 text-sm text-dm-offblack/50">
      <a href="/" class="hover:underline">Inicio</a>
      <span class="mx-1.5" aria-hidden="true">›</span>
      <a href="/estado/" class="hover:underline">Locación</a>
      <span class="mx-1.5" aria-hidden="true">›</span>
      <span class="text-dm-offblack/70">{estado}</span>
    </p>
    <h1 class="text-2xl tracking-wide">{estado}</h1>
    <p class="mt-1 text-sm text-dm-offblack/65">
      {profiles.length} {profiles.length === 1 ? "perfil" : "perfiles"}
    </p>
  </header>

  <DirectoryFilterBar hideEstado />
  <section aria-label={`Directorio en ${estado}`}>
    <div
      class="grid auto-rows-fr grid-cols-[repeat(auto-fill,minmax(min(100%,18.5rem),1fr))] gap-4 sm:gap-5"
      data-profile-grid
    >
      {profiles.map((profile) => <ProfileCard profile={profile} />)}
    </div>
    <p class="mt-8 hidden text-center text-sm text-dm-offblack/55" data-filter-empty>
      No hay perfiles con esos filtros.
    </p>
  </section>
</BaseLayout>
