---
/**
 * Homepage C — simple header + explicit light breadcrumb/filter strip.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import ProfileCard from "../components/ProfileCard.astro";
import DirectoryBreadcrumbStrip from "../components/DirectoryBreadcrumbStrip.astro";
import CompareHomes from "../components/CompareHomes.astro";
import { MOCK_PROFILES } from "../data/mockProfiles";
---

<BaseLayout
  title="DIMELA.mx — Hybrid breadcrumb UI"
  headerVariant="simple"
  homeHref="/v3/"
>
  <DirectoryBreadcrumbStrip />
  <section aria-label="Directorio">
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3" data-profile-grid>
      {MOCK_PROFILES.map((profile) => <ProfileCard profile={profile} />)}
    </div>
    <p class="mt-8 hidden text-center text-sm text-dm-offblack/55" data-filter-empty>
      No hay perfiles con esos filtros.
    </p>
  </section>
  <CompareHomes current="hybrid" />
</BaseLayout>
