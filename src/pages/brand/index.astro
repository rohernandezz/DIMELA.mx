---
/**
 * Brand / design playground — visual sandbox for tokens & UI patterns.
 * Tokens: src/styles/global.css · docs: docs/brand.md
 */
import BaseLayout from "../../layouts/BaseLayout.astro";

const colors = [
  {
    token: "dm-offwhite",
    hex: "#e9ebee",
    role: "Page background; soft surfaces",
    swatch: "bg-dm-offwhite",
    text: "text-dm-offblack",
    border: "border-dm-offblack/25",
  },
  {
    token: "dm-offblack",
    hex: "#383636",
    role: "Primary text; header/footer chrome",
    swatch: "bg-dm-offblack",
    text: "text-dm-offwhite",
    border: "border-dm-offblack",
  },
  {
    token: "dm-pink",
    hex: "#f5c1df",
    role: "Accent — Pro badge, Limpiar active",
    swatch: "bg-dm-pink",
    text: "text-dm-offblack",
    border: "border-dm-offblack/25",
  },
  {
    token: "dm-blue",
    hex: "#e8f2fb",
    role: "Soft fill — card cover, ubicación",
    swatch: "bg-dm-blue",
    text: "text-dm-offblack",
    border: "border-dm-offblack/20",
  },
  {
    token: "dm-blue-strong",
    hex: "#cde7fe",
    role: "Stronger blue in gradients / covers",
    swatch: "bg-dm-blue-strong",
    text: "text-dm-offblack",
    border: "border-dm-offblack/20",
  },
  {
    token: "dm-green",
    hex: "#d9f7d9",
    role: "Accent — use sparingly",
    swatch: "bg-dm-green",
    text: "text-dm-offblack",
    border: "border-dm-offblack/20",
  },
  {
    token: "dm-red",
    hex: "#e82525",
    role: "Errors — validation, required fields",
    swatch: "bg-dm-red",
    text: "text-dm-offwhite",
    border: "border-dm-red/40",
  },
] as const;
---

<BaseLayout
  title="Brand — DIMELA.mx"
  description="Design playground: brand colors, Outpact type, and UI samples."
>
  <div class="mx-auto max-w-3xl space-y-16 pb-16">
    <header class="space-y-2">
      <p class="dm-ui-facet-label">Design sandbox</p>
      <h1 class="dm-ui-page-title">Brand</h1>
      <p class="dm-ui-body max-w-xl">
        Tokens from <code class="text-dm-offblack">global.css</code> · OutpactVF · live UI
        patterns. Design here, then implement in the app.
      </p>
    </header>

    <!-- Colors -->
    <section class="space-y-4" aria-labelledby="brand-colors">
      <div>
        <h2 id="brand-colors" class="dm-ui-section-title">Colors</h2>
        <p class="dm-ui-body mt-1">
          @theme tokens — use Tailwind classes, not hardcoded hex in components.
        </p>
      </div>
      <ul class="grid gap-3 sm:grid-cols-2">
        {
          colors.map((c) => (
            <li
              class:list={[
                "overflow-hidden rounded-md border bg-white shadow-sm",
                c.border,
              ]}
            >
              <div class:list={["h-20", c.swatch]} aria-hidden="true" />
              <div class="space-y-1 border-t border-dm-offblack/10 px-3 py-2.5">
                <p class="font-semibold">{c.token}</p>
                <p class="font-mono text-xs text-dm-offblack/70">{c.hex}</p>
                <p class="font-mono text-[11px] text-dm-offblack/50">
                  bg-{c.token} · text-{c.token}
                </p>
                <p class="pt-1 text-xs text-dm-offblack/60">{c.role}</p>
              </div>
            </li>
          ))
        }
      </ul>
      <div class="rounded-md border border-dm-offblack/15 bg-white p-4">
        <p class="dm-ui-facet-label mb-3">Opacity hierarchy</p>
        <div class="flex flex-wrap gap-2">
          <span class="rounded border border-dm-offblack/15 bg-dm-offblack/15 px-2.5 py-1 text-xs"
            >offblack/15</span
          >
          <span class="rounded border border-dm-offblack/25 bg-dm-offblack/25 px-2.5 py-1 text-xs"
            >offblack/25</span
          >
          <span class="rounded border border-dm-offblack/35 bg-dm-offblack/35 px-2.5 py-1 text-xs"
            >offblack/35</span
          >
          <span class="rounded border border-dm-offblack/45 bg-dm-offblack/45 px-2.5 py-1 text-xs"
            >offblack/45</span
          >
          <span class="rounded border border-dm-offblack/60 bg-dm-offblack/60 px-2.5 py-1 text-xs"
            >offblack/60</span
          >
          <span class="rounded border border-dm-offblack/75 bg-dm-offblack/75 px-2.5 py-1 text-xs"
            >offblack/75</span
          >
        </div>
      </div>
    </section>

    <!-- Typography -->
    <section class="space-y-4" aria-labelledby="brand-type">
      <div>
        <h2 id="brand-type" class="dm-ui-section-title">Typography</h2>
        <p class="dm-ui-body mt-1">
          OutpactVF · weights 100–900 · stack via <code class="text-dm-offblack">font-sans</code>
        </p>
      </div>
      <div class="space-y-6 rounded-md border border-dm-offblack/15 bg-white p-5 shadow-sm">
        <div>
          <p class="dm-ui-facet-label mb-2">Brand lockup</p>
          <p class="dm-ui-lockup sm:text-2xl">DIMELA.mx</p>
        </div>
        <div>
          <p class="dm-ui-facet-label mb-2">Weights</p>
          <ul class="space-y-1.5">
            <li class="font-thin text-lg">100 Thin — letrista</li>
            <li class="font-light text-lg">300 Light — letrista</li>
            <li class="font-normal text-lg">400 Regular — letrista</li>
            <li class="font-medium text-lg">500 Medium — letrista</li>
            <li class="font-semibold text-lg">600 Semibold — letrista</li>
            <li class="font-bold text-lg">700 Bold — letrista</li>
            <li class="font-black text-lg">900 Black — letrista</li>
          </ul>
        </div>
        <div>
          <p class="dm-ui-facet-label mb-2">Sizes & tracking</p>
          <ul class="space-y-2">
            <li class="dm-ui-display">Display · .dm-ui-display</li>
            <li class="dm-ui-card-title">Card title · .dm-ui-card-title</li>
            <li class="dm-ui-body">Body · .dm-ui-body — Lettering, caligrafía y tipografía para marcas.</li>
            <li class="dm-ui-meta">Meta · .dm-ui-meta — Ciudad de México</li>
            <li class="dm-ui-facet-label">Facet label · .dm-ui-facet-label</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Content typography -->
    <section class="space-y-4" aria-labelledby="brand-content">
      <div>
        <h2 id="brand-content" class="dm-ui-section-title">Content typography</h2>
        <p class="dm-ui-body mt-1">
          <code class="text-dm-offblack">.dm-content</code> — user-authored text (bios, long-form).
          Defined here; used on profile pages and the bio editor.
        </p>
      </div>
      <article class="dm-content rounded-md border border-dm-offblack/15 bg-white p-6 shadow-sm">
        <h2>El oficio del trazo</h2>
        <p>
          Lettering, caligrafía y tipografía hechas en México. Cada trazo cuenta una historia —
          desde rótulos de mercado hasta familias tipográficas completas para
          <a href="#">marcas y editoriales</a>.
        </p>

        <h2>Proceso</h2>
        <p>
          Boceto, revisión, kerning y pruebas en contexto real. Un proceso que empieza con
          escucha y termina con archivos listos para producción.
        </p>

        <h3>Servicios frecuentes</h3>
        <ul>
          <li>Logotipos y lettering a la medida</li>
          <li>Familias tipográficas para texto y display</li>
          <li>Murales y rotulación en gran formato</li>
        </ul>

        <h3>Pasos</h3>
        <ol>
          <li>Brief y referencias</li>
          <li>Bocetos y dirección</li>
          <li>Digitalización y entrega</li>
        </ol>

        <blockquote>
          “La letra es dibujo antes que texto — primero se mira, después se lee.”
        </blockquote>

        <p class="dm-ui-meta">
          Meta line · Ciudad de México · <code>code sample</code>
        </p>
      </article>
    </section>

    <!-- UI typography -->
    <section class="space-y-4" aria-labelledby="brand-ui-type">
      <div>
        <h2 id="brand-ui-type" class="dm-ui-section-title">UI typography</h2>
        <p class="dm-ui-body mt-1">
          <code class="text-dm-offblack">.dm-ui-*</code> — app chrome: section titles, panel
          headings, labels, meta. Not for user-authored body copy.
        </p>
      </div>
      <p class="dm-ui-meta -mt-1">
        Live mock of <code>/editar/</code>. Green tags name the class on each element.
      </p>

      <!-- Mini editor mockup -->
      <div class="overflow-hidden rounded-md border border-dm-offblack/15 bg-white shadow-sm">
        <!-- Header chrome -->
        <div class="flex items-center gap-3 bg-dm-offblack px-4 py-3 text-dm-offwhite">
          <span class="dm-ui-lockup">DIMELA.mx</span>
          <span class="dm-brand-annotation ml-auto">.dm-ui-lockup</span>
        </div>

        <div class="space-y-8 p-5 sm:p-6">
          <!-- Page title -->
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <h1 class="dm-ui-page-title">Editar perfil</h1>
              <span class="dm-brand-annotation">.dm-ui-page-title</span>
            </div>
          </div>

          <!-- Section: Identidad -->
          <section class="space-y-4 border-t border-dm-offblack/10 pt-5">
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <h2 class="dm-ui-section-title">Identidad</h2>
                <span class="dm-brand-annotation">.dm-ui-section-title</span>
              </div>
              <div class="mt-1 flex flex-wrap items-center gap-2">
                <p class="dm-ui-body">Nombre público y sitio web.</p>
                <span class="dm-brand-annotation">.dm-ui-body</span>
              </div>
            </div>
            <label class="block space-y-1.5">
              <span class="flex flex-wrap items-center gap-2">
                <span class="dm-ui-facet-label">Nombre <span class="text-dm-red">*</span></span>
                <span class="dm-brand-annotation">.dm-ui-facet-label</span>
              </span>
              <input
                type="text"
                value="Romina Hernández"
                class="dm-ui-field"
              />
            </label>
          </section>

          <!-- Section: Galería (nested panel title) -->
          <section class="space-y-4 border-t border-dm-offblack/10 pt-5">
            <div class="flex flex-wrap items-center gap-2">
              <h2 class="dm-ui-section-title">Medios</h2>
              <span class="dm-brand-annotation">.dm-ui-section-title</span>
            </div>
            <div class="dm-ui-subsurface p-4">
              <div class="flex flex-wrap items-center gap-2">
                <h3 class="dm-ui-panel-title">Galería principal</h3>
                <span class="dm-brand-annotation">.dm-ui-panel-title</span>
              </div>
              <div class="mt-2 flex flex-wrap items-center gap-2">
                <p class="dm-ui-meta">3 imágenes · Ciudad de México</p>
                <span class="dm-brand-annotation">.dm-ui-meta</span>
              </div>
            </div>
          </section>
        </div>
      </div>

      <!-- Directory card + profile name mock -->
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="dm-ui-surface p-4">
          <p class="dm-ui-facet-label mb-3">Directory card</p>
          <div class="flex items-center gap-2">
            <p class="dm-ui-card-title">Cristóbal Henestrosa</p>
            <span class="dm-brand-annotation">.dm-ui-card-title</span>
          </div>
          <div class="mt-0.5 flex items-center gap-2">
            <p class="dm-ui-meta">Ciudad de México</p>
            <span class="dm-brand-annotation">.dm-ui-meta</span>
          </div>
        </div>
        <div class="dm-ui-surface p-4">
          <p class="dm-ui-facet-label mb-3">Profile detail header</p>
          <div class="flex flex-wrap items-center gap-2">
            <p class="dm-ui-display">Romina Hernández</p>
            <span class="dm-brand-annotation">.dm-ui-display</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Header / filters / cards / forms -->
    <section class="space-y-4" aria-labelledby="brand-ui-components">
      <div>
        <h2 id="brand-ui-components" class="dm-ui-section-title">UI components</h2>
        <p class="dm-ui-body mt-1">
          Real-ish app pieces. Green tags name the class; edit the class in
          <code>global.css</code> and the site follows.
        </p>
      </div>

      <!-- Header + filter bar -->
      <div class="dm-ui-surface overflow-hidden">
        <div class="flex items-center gap-3 bg-dm-offblack px-4 py-3 text-dm-offwhite">
          <span class="dm-ui-lockup">DIMELA.mx</span>
          <span class="dm-brand-annotation ml-auto">.dm-ui-lockup</span>
        </div>
        <div class="space-y-4 p-5">
          <div>
            <h3 class="dm-ui-section-title">Directorio</h3>
            <p class="dm-ui-body mt-1">Busca por nombre, ubicación o servicio.</p>
          </div>
          <div class="flex flex-wrap items-end gap-2">
            <label class="min-w-56 flex-1 space-y-1.5">
              <span class="dm-ui-facet-label">Buscar</span>
              <input class="dm-ui-field-soft" type="search" placeholder="Nombre o descripción..." />
            </label>
            <button type="button" class="dm-ui-select-button min-w-56 flex-1 gap-2 bg-dm-blue/50">
              <span class="dm-ui-facet-label shrink-0">Ubicación</span>
              <span class="min-w-0 flex-1 truncate">Sólo México</span>
              <span class="text-dm-offblack/40" aria-hidden="true">▾</span>
            </button>
            <button type="button" class="dm-ui-button-accent px-2 py-1 text-xs">Limpiar</button>
            <button type="button" class="dm-ui-filter-toggle">
              Filtros <span aria-hidden="true" class="ml-0.5 opacity-70">▾</span>
              <span class="dm-ui-count-badge">2</span>
            </button>
          </div>
          <div class="flex flex-wrap gap-2 border-t border-dm-offblack/10 pt-4">
            <button type="button" class="dm-ui-chip">Lettering</button>
            <button type="button" class="dm-ui-chip-active">Caligrafía</button>
            <button type="button" class="dm-ui-chip">Tipografía</button>
          </div>
          <div class="flex flex-wrap gap-1.5">
            <span class="dm-brand-annotation">.dm-ui-field-soft</span>
            <span class="dm-brand-annotation">.dm-ui-select-button</span>
            <span class="dm-brand-annotation">.dm-ui-button-accent</span>
            <span class="dm-brand-annotation">.dm-ui-filter-toggle</span>
            <span class="dm-brand-annotation">.dm-ui-count-badge</span>
            <span class="dm-brand-annotation">.dm-ui-chip / .dm-ui-chip-active</span>
          </div>
        </div>
      </div>

      <!-- Profile card -->
      <div class="grid gap-4 sm:grid-cols-2">
        <article class="group dm-ui-profile-card dm-ui-profile-card-free">
          <div class="relative aspect-[16/10] bg-gradient-to-br from-dm-blue-strong via-dm-blue to-dm-offwhite p-4">
            <span class="absolute bottom-4 left-4 text-3xl font-bold text-dm-offblack/25">Aa</span>
          </div>
          <div class="flex flex-1 flex-col gap-3 p-4">
            <header class="flex items-center gap-3">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-dm-offblack/10 text-dm-offblack/50 shadow-md ring-2 ring-white" aria-hidden="true">
                <svg class="h-7 w-7" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="8" r="4"></circle><path d="M4 22c0-5 4-8 8-8s8 3 8 8v2H4v-2z"></path></svg>
              </div>
              <div class="min-w-0">
                <p class="dm-ui-card-title truncate">Free Studio</p>
                <p class="dm-ui-meta">Jalisco</p>
              </div>
            </header>
            <p class="dm-ui-body line-clamp-2">Lettering y tipografía. Escala visual Free dentro de la celda.</p>
            <div class="mt-auto flex flex-wrap gap-1.5 pt-1">
              <span class="dm-ui-service-pill">Lettering</span>
            </div>
          </div>
        </article>

        <article class="group dm-ui-profile-card dm-ui-profile-card-pro">
          <span class="dm-ui-pro-badge absolute top-3 right-3 z-10">Pro</span>
          <div class="relative aspect-[16/10] bg-gradient-to-br from-dm-blue-strong via-dm-blue to-dm-pink/40 p-4">
            <span class="absolute bottom-4 left-4 text-3xl font-bold text-dm-offblack/25">Aa</span>
          </div>
          <div class="flex flex-1 flex-col gap-3 p-4">
            <header class="flex items-center gap-3">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-dm-offblack/10 text-dm-offblack/50 shadow-md ring-2 ring-white" aria-hidden="true">
                <svg class="h-7 w-7" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="8" r="4"></circle><path d="M4 22c0-5 4-8 8-8s8 3 8 8v2H4v-2z"></path></svg>
              </div>
              <div class="min-w-0">
                <p class="dm-ui-card-title truncate">Pro Atelier</p>
                <p class="dm-ui-meta">CDMX</p>
              </div>
            </header>
            <p class="dm-ui-body line-clamp-2">Identidad con trazo propio. Badge Pro + borde más fuerte.</p>
            <div class="mt-auto flex flex-wrap gap-1.5 pt-1">
              <span class="dm-ui-service-pill">Caligrafía</span>
              <span class="dm-ui-service-pill">Tipografía</span>
            </div>
          </div>
        </article>
        <div class="sm:col-span-2 flex flex-wrap gap-1.5">
          <span class="dm-brand-annotation">.dm-ui-profile-card-free</span>
          <span class="dm-brand-annotation">.dm-ui-profile-card-pro</span>
          <span class="dm-brand-annotation">.dm-ui-pro-badge</span>
          <span class="dm-brand-annotation">.dm-ui-service-pill</span>
        </div>
      </div>

      <!-- Forms + validation -->
      <div class="dm-ui-surface space-y-5 p-5">
        <div>
          <h3 class="dm-ui-section-title">Identidad</h3>
          <p class="dm-ui-body mt-1">Nombre público y sitio web.</p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block space-y-1.5">
            <span class="dm-ui-facet-label">Nombre <span class="text-dm-red">*</span></span>
            <input class="dm-ui-field" type="text" value="Romina Hernández" />
          </label>
          <label class="block space-y-1.5">
            <span class="dm-ui-facet-label">Ubicación <span class="text-dm-red">*</span></span>
            <select class="dm-ui-field-blue">
              <option>Ciudad de México</option>
              <option>Fuera de México</option>
            </select>
          </label>
          <label class="block space-y-1.5 sm:col-span-2">
            <span class="dm-ui-facet-label">Sitio web</span>
            <input class="dm-ui-field-error" type="url" value="romina" aria-invalid="true" />
            <p class="dm-ui-error-text">Ingresa una URL válida.</p>
          </label>
        </div>
        <p class="dm-ui-error-banner" role="alert">No se pudo guardar. Revisa los campos marcados.</p>
        <div class="flex flex-wrap gap-3 border-t border-dm-offblack/10 pt-4">
          <button type="button" class="dm-ui-button-primary">Guardar borrador</button>
          <button type="button" class="dm-ui-button-secondary">Cancelar</button>
          <button type="button" class="dm-ui-button-accent">Enviar a revisión</button>
        </div>
        <div class="flex flex-wrap gap-1.5">
          <span class="dm-brand-annotation">.dm-ui-field</span>
          <span class="dm-brand-annotation">.dm-ui-field-blue</span>
          <span class="dm-brand-annotation">.dm-ui-field-error</span>
          <span class="dm-brand-annotation">.dm-ui-error-text</span>
          <span class="dm-brand-annotation">.dm-ui-error-banner</span>
          <span class="dm-brand-annotation">.dm-ui-button-*</span>
        </div>
      </div>
    </section>

    <!-- Borders & shadows -->
    <section class="space-y-4" aria-labelledby="brand-surfaces">
      <div>
        <h2 id="brand-surfaces" class="dm-ui-section-title">Borders & shadows</h2>
        <p class="dm-ui-body mt-1">Surface treatments used by editor panels, cards, and shells.</p>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div
          class="dm-ui-surface p-4 text-center text-xs"
        >
          <p class="font-semibold">Soft</p>
          <p class="mt-1 text-dm-offblack/50">.dm-ui-surface</p>
        </div>
        <div
          class="group dm-ui-profile-card dm-ui-profile-card-free p-4 text-center text-xs"
        >
          <p class="font-semibold">Free card</p>
          <p class="mt-1 text-dm-offblack/50">.dm-ui-profile-card-free</p>
        </div>
        <div
          class="group dm-ui-profile-card dm-ui-profile-card-pro p-4 text-center text-xs"
        >
          <p class="font-semibold">Pro card</p>
          <p class="mt-1 text-dm-offblack/50">.dm-ui-profile-card-pro</p>
        </div>
      </div>
    </section>

    <p class="border-t border-dm-offblack/10 pt-6 text-xs text-dm-offblack/45">
      Source: <code>docs/brand.md</code> · <code>src/styles/global.css</code>
    </p>
  </div>
</BaseLayout>
