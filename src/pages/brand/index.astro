---
/**
 * Brand / design playground — visual sandbox for tokens & UI patterns.
 * Tokens: src/styles/global.css · docs: docs/brand.md
 */
import BaseLayout from "../../layouts/BaseLayout.astro";

const colors = [
  {
    token: "dm-offwhite",
    hex: "#e9ebee",
    role: "Page background; soft surfaces",
    swatch: "bg-dm-offwhite",
    text: "text-dm-offblack",
    border: "border-dm-offblack/25",
  },
  {
    token: "dm-offblack",
    hex: "#383636",
    role: "Primary text; header/footer chrome",
    swatch: "bg-dm-offblack",
    text: "text-dm-offwhite",
    border: "border-dm-offblack",
  },
  {
    token: "dm-pink",
    hex: "#f5c1df",
    role: "Accent — Pro badge, Limpiar active",
    swatch: "bg-dm-pink",
    text: "text-dm-offblack",
    border: "border-dm-offblack/25",
  },
  {
    token: "dm-blue",
    hex: "#e8f2fb",
    role: "Soft fill — card cover, ubicación",
    swatch: "bg-dm-blue",
    text: "text-dm-offblack",
    border: "border-dm-offblack/20",
  },
  {
    token: "dm-blue-strong",
    hex: "#cde7fe",
    role: "Stronger blue in gradients / covers",
    swatch: "bg-dm-blue-strong",
    text: "text-dm-offblack",
    border: "border-dm-offblack/20",
  },
  {
    token: "dm-green",
    hex: "#d9f7d9",
    role: "Accent — use sparingly",
    swatch: "bg-dm-green",
    text: "text-dm-offblack",
    border: "border-dm-offblack/20",
  },
  {
    token: "dm-red",
    hex: "#e82525",
    role: "Errors — validation, required fields",
    swatch: "bg-dm-red",
    text: "text-dm-offwhite",
    border: "border-dm-red/40",
  },
] as const;
---

<BaseLayout
  title="Brand — DIMELA.mx"
  description="Design playground: brand colors, Outpact type, and UI samples."
>
  <div class="mx-auto max-w-3xl space-y-16 pb-16">
    <header class="space-y-2">
      <p class="dm-ui-facet-label">Design sandbox</p>
      <h1 class="dm-ui-page-title">Brand</h1>
      <p class="dm-ui-body max-w-xl">
        Tokens from <code class="text-dm-offblack">global.css</code> · OutpactVF · live UI
        patterns. Design here, then implement in the app.
      </p>
    </header>

    <!-- Colors -->
    <section class="space-y-4" aria-labelledby="brand-colors">
      <div>
        <h2 id="brand-colors" class="dm-ui-section-title">Colors</h2>
        <p class="dm-ui-body mt-1">
          @theme tokens — use Tailwind classes, not hardcoded hex in components.
        </p>
      </div>
      <ul class="grid gap-3 sm:grid-cols-2">
        {
          colors.map((c) => (
            <li
              class:list={[
                "overflow-hidden rounded-md border bg-white shadow-sm",
                c.border,
              ]}
            >
              <div class:list={["h-20", c.swatch]} aria-hidden="true" />
              <div class="space-y-1 border-t border-dm-offblack/10 px-3 py-2.5">
                <p class="font-semibold">{c.token}</p>
                <p class="font-mono text-xs text-dm-offblack/70">{c.hex}</p>
                <p class="font-mono text-[11px] text-dm-offblack/50">
                  bg-{c.token} · text-{c.token}
                </p>
                <p class="pt-1 text-xs text-dm-offblack/60">{c.role}</p>
              </div>
            </li>
          ))
        }
      </ul>
      <div class="rounded-md border border-dm-offblack/15 bg-white p-4">
        <p class="dm-ui-facet-label mb-3">Opacity hierarchy</p>
        <div class="flex flex-wrap gap-2">
          <span class="rounded border border-dm-offblack/15 bg-dm-offblack/15 px-2.5 py-1 text-xs"
            >offblack/15</span
          >
          <span class="rounded border border-dm-offblack/25 bg-dm-offblack/25 px-2.5 py-1 text-xs"
            >offblack/25</span
          >
          <span class="rounded border border-dm-offblack/35 bg-dm-offblack/35 px-2.5 py-1 text-xs"
            >offblack/35</span
          >
          <span class="rounded border border-dm-offblack/45 bg-dm-offblack/45 px-2.5 py-1 text-xs"
            >offblack/45</span
          >
          <span class="rounded border border-dm-offblack/60 bg-dm-offblack/60 px-2.5 py-1 text-xs"
            >offblack/60</span
          >
          <span class="rounded border border-dm-offblack/75 bg-dm-offblack/75 px-2.5 py-1 text-xs"
            >offblack/75</span
          >
        </div>
      </div>
    </section>

    <!-- Typography -->
    <section class="space-y-4" aria-labelledby="brand-type">
      <div>
        <h2 id="brand-type" class="dm-ui-section-title">Typography</h2>
        <p class="dm-ui-body mt-1">
          OutpactVF · weights 100–900 · stack via <code class="text-dm-offblack">font-sans</code>
        </p>
      </div>
      <div class="space-y-6 rounded-md border border-dm-offblack/15 bg-white p-5 shadow-sm">
        <div>
          <p class="dm-ui-facet-label mb-2">Brand lockup</p>
          <p class="dm-ui-lockup sm:text-2xl">DIMELA.mx</p>
        </div>
        <div>
          <p class="dm-ui-facet-label mb-2">Weights</p>
          <ul class="space-y-1.5">
            <li class="font-thin text-lg">100 Thin — letrista</li>
            <li class="font-light text-lg">300 Light — letrista</li>
            <li class="font-normal text-lg">400 Regular — letrista</li>
            <li class="font-medium text-lg">500 Medium — letrista</li>
            <li class="font-semibold text-lg">600 Semibold — letrista</li>
            <li class="font-bold text-lg">700 Bold — letrista</li>
            <li class="font-black text-lg">900 Black — letrista</li>
          </ul>
        </div>
        <div>
          <p class="dm-ui-facet-label mb-2">Sizes & tracking</p>
          <ul class="space-y-2">
            <li class="dm-ui-display">Display · .dm-ui-display</li>
            <li class="dm-ui-card-title">Card title · .dm-ui-card-title</li>
            <li class="dm-ui-body">Body · .dm-ui-body — Lettering, caligrafía y tipografía para marcas.</li>
            <li class="dm-ui-meta">Meta · .dm-ui-meta — Ciudad de México</li>
            <li class="dm-ui-facet-label">Facet label · .dm-ui-facet-label</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Content typography -->
    <section class="space-y-4" aria-labelledby="brand-content">
      <div>
        <h2 id="brand-content" class="dm-ui-section-title">Content typography</h2>
        <p class="dm-ui-body mt-1">
          <code class="text-dm-offblack">.dm-content</code> — user-authored text (bios, long-form).
          Defined here; used on profile pages and the bio editor.
        </p>
      </div>
      <article class="dm-content rounded-md border border-dm-offblack/15 bg-white p-6 shadow-sm">
        <h2>El oficio del trazo</h2>
        <p>
          Lettering, caligrafía y tipografía hechas en México. Cada trazo cuenta una historia —
          desde rótulos de mercado hasta familias tipográficas completas para
          <a href="#">marcas y editoriales</a>.
        </p>

        <h2>Proceso</h2>
        <p>
          Boceto, revisión, kerning y pruebas en contexto real. Un proceso que empieza con
          escucha y termina con archivos listos para producción.
        </p>

        <h3>Servicios frecuentes</h3>
        <ul>
          <li>Logotipos y lettering a la medida</li>
          <li>Familias tipográficas para texto y display</li>
          <li>Murales y rotulación en gran formato</li>
        </ul>

        <h3>Pasos</h3>
        <ol>
          <li>Brief y referencias</li>
          <li>Bocetos y dirección</li>
          <li>Digitalización y entrega</li>
        </ol>

        <blockquote>
          “La letra es dibujo antes que texto — primero se mira, después se lee.”
        </blockquote>

        <p class="dm-ui-meta">
          Meta line · Ciudad de México · <code>code sample</code>
        </p>
      </article>
    </section>

    <!-- UI typography -->
    <section class="space-y-4" aria-labelledby="brand-ui-type">
      <div>
        <h2 id="brand-ui-type" class="dm-ui-section-title">UI typography</h2>
        <p class="dm-ui-body mt-1">
          <code class="text-dm-offblack">.dm-ui-*</code> — app chrome: section titles, panel
          headings, labels, meta. Not for user-authored body copy.
        </p>
      </div>
      <p class="dm-ui-meta -mt-1">
        Live mock of <code>/editar/</code>. Pink tags name the class on each element.
      </p>

      <!-- Mini editor mockup -->
      <div class="overflow-hidden rounded-md border border-dm-offblack/15 bg-white shadow-sm">
        <!-- Header chrome -->
        <div class="flex items-center gap-3 bg-dm-offblack px-4 py-3 text-dm-offwhite">
          <span class="dm-ui-lockup">DIMELA.mx</span>
          <span class="ml-auto rounded bg-dm-pink px-1.5 py-0.5 font-mono text-[10px] text-dm-offblack">.dm-ui-lockup</span>
        </div>

        <div class="space-y-8 p-5 sm:p-6">
          <!-- Page title -->
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <h1 class="dm-ui-page-title">Editar perfil</h1>
              <span class="rounded bg-dm-pink px-1.5 py-0.5 font-mono text-[10px] text-dm-offblack">.dm-ui-page-title</span>
            </div>
          </div>

          <!-- Section: Identidad -->
          <section class="space-y-4 border-t border-dm-offblack/10 pt-5">
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <h2 class="dm-ui-section-title">Identidad</h2>
                <span class="rounded bg-dm-pink px-1.5 py-0.5 font-mono text-[10px] text-dm-offblack">.dm-ui-section-title</span>
              </div>
              <div class="mt-1 flex flex-wrap items-center gap-2">
                <p class="dm-ui-body">Nombre público y sitio web.</p>
                <span class="rounded bg-dm-pink px-1.5 py-0.5 font-mono text-[10px] text-dm-offblack">.dm-ui-body</span>
              </div>
            </div>
            <label class="block space-y-1.5">
              <span class="flex flex-wrap items-center gap-2">
                <span class="dm-ui-facet-label">Nombre <span class="text-dm-red">*</span></span>
                <span class="rounded bg-dm-pink px-1.5 py-0.5 font-mono text-[10px] text-dm-offblack">.dm-ui-facet-label</span>
              </span>
              <input
                type="text"
                value="Romina Hernández"
                class="w-full rounded border border-dm-offblack/20 bg-white px-3 py-2 text-sm outline-none focus:border-dm-offblack/50"
              />
            </label>
          </section>

          <!-- Section: Galería (nested panel title) -->
          <section class="space-y-4 border-t border-dm-offblack/10 pt-5">
            <div class="flex flex-wrap items-center gap-2">
              <h2 class="dm-ui-section-title">Medios</h2>
              <span class="rounded bg-dm-pink px-1.5 py-0.5 font-mono text-[10px] text-dm-offblack">.dm-ui-section-title</span>
            </div>
            <div class="rounded border border-dm-offblack/10 bg-dm-offwhite/60 p-4">
              <div class="flex flex-wrap items-center gap-2">
                <h3 class="dm-ui-panel-title">Galería principal</h3>
                <span class="rounded bg-dm-pink px-1.5 py-0.5 font-mono text-[10px] text-dm-offblack">.dm-ui-panel-title</span>
              </div>
              <div class="mt-2 flex flex-wrap items-center gap-2">
                <p class="dm-ui-meta">3 imágenes · Ciudad de México</p>
                <span class="rounded bg-dm-pink px-1.5 py-0.5 font-mono text-[10px] text-dm-offblack">.dm-ui-meta</span>
              </div>
            </div>
          </section>
        </div>
      </div>

      <!-- Directory card + profile name mock -->
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-md border-2 border-dm-offblack/15 bg-white p-4 shadow-sm">
          <p class="dm-ui-facet-label mb-3">Directory card</p>
          <div class="flex items-center gap-2">
            <p class="dm-ui-card-title">Cristóbal Henestrosa</p>
            <span class="rounded bg-dm-pink px-1.5 py-0.5 font-mono text-[10px] text-dm-offblack">.dm-ui-card-title</span>
          </div>
          <div class="mt-0.5 flex items-center gap-2">
            <p class="dm-ui-meta">Ciudad de México</p>
            <span class="rounded bg-dm-pink px-1.5 py-0.5 font-mono text-[10px] text-dm-offblack">.dm-ui-meta</span>
          </div>
        </div>
        <div class="rounded-md border-2 border-dm-offblack/15 bg-white p-4 shadow-sm">
          <p class="dm-ui-facet-label mb-3">Profile detail header</p>
          <div class="flex flex-wrap items-center gap-2">
            <p class="dm-ui-display">Romina Hernández</p>
            <span class="rounded bg-dm-pink px-1.5 py-0.5 font-mono text-[10px] text-dm-offblack">.dm-ui-display</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Header strip -->
    <section class="space-y-4" aria-labelledby="brand-header">
      <div>
        <h2 id="brand-header" class="dm-ui-section-title">Header strip</h2>
        <p class="dm-ui-body mt-1">
          Off-black chrome · off-white type · hamburger panel
        </p>
      </div>
      <div
        class="overflow-hidden rounded-md border border-dm-offblack/20 shadow-md"
        aria-hidden="true"
      >
        <div
          class="flex items-center justify-between bg-dm-offblack px-4 py-3 text-dm-offwhite"
        >
          <span class="dm-ui-lockup">DIMELA.mx</span>
          <span
            class="flex h-9 w-9 items-center justify-center rounded text-dm-offwhite"
            aria-hidden="true"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none">
              <path
                d="M4 7h16M4 12h16M4 17h16"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"></path>
            </svg>
          </span>
        </div>
        <div class="border-t border-black/10 bg-white py-1 text-dm-offblack shadow-lg">
          <span class="block px-3 py-2 text-sm text-dm-offblack/50">Todo</span>
          <span class="block bg-dm-offwhite px-3 py-2 text-sm">Acerca de…</span>
          <span class="block border-t border-dm-offblack/10 px-3 py-2 text-sm">Brand</span>
        </div>
      </div>
    </section>

    <!-- Filter chips & Limpiar -->
    <section class="space-y-4" aria-labelledby="brand-filters">
      <div>
        <h2 id="brand-filters" class="dm-ui-section-title">Filters</h2>
        <p class="dm-ui-body mt-1">
          Chips idle / pressed · Limpiar idle / active pink
        </p>
      </div>
      <div class="space-y-5 rounded-md border border-dm-offblack/15 bg-white p-5 shadow-sm">
        <div>
          <p class="dm-ui-facet-label mb-2">Servicio</p>
          <div class="flex flex-wrap gap-2">
            <button
              type="button"
              class="rounded border border-dm-offblack/25 bg-white px-3 py-1.5 text-sm text-dm-offblack"
              aria-pressed="false"
            >
              Lettering
            </button>
            <button
              type="button"
              class="rounded border border-dm-offblack bg-dm-offblack px-3 py-1.5 text-sm text-dm-offwhite"
              aria-pressed="true"
            >
              Caligrafía
            </button>
            <button
              type="button"
              class="rounded border border-dm-offblack/25 bg-white px-3 py-1.5 text-sm text-dm-offblack hover:border-dm-offblack"
              aria-pressed="false"
            >
              Tipografía
            </button>
          </div>
          <p class="mt-2 text-[11px] text-dm-offblack/50">
            Idle: <code>border-dm-offblack/25 bg-white</code> · Pressed:
            <code>bg-dm-offblack text-dm-offwhite</code>
          </p>
        </div>

        <div class="flex flex-wrap items-end gap-4 border-t border-dm-offblack/10 pt-5">
          <div class="space-y-1.5">
            <p class="dm-ui-facet-label">Limpiar idle</p>
            <button
              type="button"
              class="cursor-not-allowed rounded border border-dm-offblack/20 bg-transparent px-2 py-1 text-xs text-dm-offblack/40 opacity-50"
              disabled
            >
              Limpiar
            </button>
          </div>
          <div class="space-y-1.5">
            <p class="dm-ui-facet-label">Limpiar active</p>
            <button
              type="button"
              class="rounded border border-dm-offblack bg-dm-pink px-2 py-1 text-xs text-dm-offblack transition hover:bg-dm-offblack hover:text-white"
            >
              Limpiar
            </button>
          </div>
          <div class="space-y-1.5">
            <p class="dm-ui-facet-label">Count badge</p>
            <span class="relative inline-flex">
              <span
                class="rounded border border-dm-offblack/25 bg-dm-offblack px-3 py-2 text-sm text-dm-offwhite"
              >
                Filtros ▾
              </span>
              <span
                class="absolute -top-1.5 -right-1.5 flex h-5 min-w-5 items-center justify-center rounded-full bg-dm-pink px-1 text-[10px] font-bold text-dm-offblack"
              >
                2
              </span>
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- Pro badge & profile cards -->
    <section class="space-y-4" aria-labelledby="brand-cards">
      <div>
        <h2 id="brand-cards" class="dm-ui-section-title">Profile cards</h2>
        <p class="dm-ui-body mt-1">
          Pro fills cell + pink badge · Free scaled 98%×96% · softer border
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        <!-- Free sketch -->
        <article
          class="profile-card relative flex flex-col overflow-hidden rounded-md border-2 border-dm-offblack/15 bg-white shadow-md origin-center scale-x-[0.98] scale-y-[0.96]"
        >
          <div
            class="relative aspect-[16/10] bg-gradient-to-br from-dm-blue-strong via-dm-blue to-dm-offwhite p-4"
          >
            <span class="absolute bottom-4 left-4 text-3xl font-bold text-dm-offblack/25"
              >Aa</span
            >
          </div>
          <div class="flex flex-1 flex-col gap-3 p-4">
            <header class="flex items-center gap-3">
              <div
                class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-dm-offblack/10 text-dm-offblack/50 shadow-md ring-2 ring-white"
                aria-hidden="true"
              >
                <svg class="h-7 w-7" viewBox="0 0 24 24" fill="currentColor">
                  <circle cx="12" cy="8" r="4"></circle>
                  <path d="M4 22c0-5 4-8 8-8s8 3 8 8v2H4v-2z"></path>
                </svg>
              </div>
              <div class="min-w-0">
                <p class="dm-ui-card-title truncate">Free Studio</p>
                <p class="dm-ui-meta">Jalisco</p>
              </div>
            </header>
            <p class="dm-ui-body line-clamp-2">
              Lettering y tipografía. Escala visual Free dentro de la celda.
            </p>
            <div class="mt-auto flex flex-wrap gap-1.5 pt-1">
              <span
                class="rounded border border-dm-offblack/20 bg-dm-offwhite px-2 py-0.5 text-[11px] text-dm-offblack/80"
                >Lettering</span
              >
            </div>
          </div>
          <p
            class="absolute bottom-2 left-2 rounded bg-dm-offblack/80 px-1.5 py-0.5 text-[9px] tracking-wide text-dm-offwhite uppercase"
          >
            Free
          </p>
        </article>

        <!-- Pro sketch -->
        <article
          class="profile-card relative flex flex-col overflow-hidden rounded-md border-2 border-dm-offblack/35 bg-white shadow-lg"
        >
          <span
            class="absolute top-3 right-3 z-10 rounded bg-dm-pink px-2 py-0.5 text-[10px] font-semibold tracking-wide text-dm-offblack uppercase"
          >
            Pro
          </span>
          <div
            class="relative aspect-[16/10] bg-gradient-to-br from-dm-blue-strong via-dm-blue to-dm-pink/40 p-4"
          >
            <span class="absolute bottom-4 left-4 text-3xl font-bold text-dm-offblack/25"
              >Aa</span
            >
          </div>
          <div class="flex flex-1 flex-col gap-3 p-4">
            <header class="flex items-center gap-3">
              <div
                class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-dm-offblack/10 text-dm-offblack/50 shadow-md ring-2 ring-white"
                aria-hidden="true"
              >
                <svg class="h-7 w-7" viewBox="0 0 24 24" fill="currentColor">
                  <circle cx="12" cy="8" r="4"></circle>
                  <path d="M4 22c0-5 4-8 8-8s8 3 8 8v2H4v-2z"></path>
                </svg>
              </div>
              <div class="min-w-0">
                <p class="dm-ui-card-title truncate">Pro Atelier</p>
                <p class="dm-ui-meta">CDMX</p>
              </div>
            </header>
            <p class="dm-ui-body line-clamp-2">
              Identidad con trazo propio. Badge Pro + borde más fuerte.
            </p>
            <div class="mt-auto flex flex-wrap gap-1.5 pt-1">
              <span
                class="rounded border border-dm-offblack/20 bg-dm-offwhite px-2 py-0.5 text-[11px] text-dm-offblack/80"
                >Caligrafía</span
              >
              <span
                class="rounded border border-dm-offblack/20 bg-dm-offwhite px-2 py-0.5 text-[11px] text-dm-offblack/80"
                >Tipografía</span
              >
            </div>
          </div>
        </article>
      </div>
    </section>

    <!-- Forms & controls -->
    <section class="space-y-4" aria-labelledby="brand-forms">
      <div>
        <h2 id="brand-forms" class="dm-ui-section-title">Forms & controls</h2>
        <p class="dm-ui-body mt-1">
          Search, ubicación, borders — matching filter bar patterns
        </p>
      </div>
      <div class="space-y-4 rounded-md border border-dm-offblack/15 bg-white p-5 shadow-sm">
        <div>
          <label
            for="brand-search"
            class="dm-ui-facet-label mb-1.5 block"
          >
            Buscar
          </label>
          <input
            id="brand-search"
            type="search"
            placeholder="Nombre o descripción…"
            class="w-full rounded border border-dm-offblack/20 bg-dm-offwhite px-3 py-2 text-sm outline-none focus:border-dm-offblack"
          />
        </div>
        <div>
          <p class="dm-ui-facet-label mb-1.5">Ubicación</p>
          <button
            type="button"
            class="flex w-full items-center justify-between rounded border border-dm-offblack/20 bg-dm-blue/40 px-3 py-2 text-left text-sm"
          >
            <span>Todo México</span>
            <span class="text-dm-offblack/40" aria-hidden="true">▾</span>
          </button>
        </div>
        <div class="flex flex-wrap gap-3 border-t border-dm-offblack/10 pt-4">
          <button
            type="button"
            class="rounded border border-dm-offblack bg-dm-offblack px-3 py-2 text-sm text-dm-offwhite transition hover:opacity-90"
          >
            Primario
          </button>
          <button
            type="button"
            class="rounded border border-dm-offblack/25 bg-white px-3 py-2 text-sm text-dm-offblack transition hover:border-dm-offblack"
          >
            Secundario
          </button>
          <button
            type="button"
            class="rounded border border-dm-offblack bg-dm-pink px-3 py-2 text-sm text-dm-offblack transition hover:bg-dm-offblack hover:text-white"
          >
            Acento
          </button>
        </div>
      </div>
    </section>

    <!-- Errors & validation -->
    <section class="space-y-4" aria-labelledby="brand-errors">
      <div>
        <h2 id="brand-errors" class="dm-ui-section-title">Errors & validation</h2>
        <p class="dm-ui-body mt-1">
          <code>dm-red</code> for validation — inline hints, required fields, invalid inputs
        </p>
      </div>
      <div class="space-y-5 rounded-md border border-dm-offblack/15 bg-white p-5 shadow-sm">
        <div>
          <p class="dm-ui-facet-label mb-2">Inline messages</p>
          <div class="space-y-1.5">
            <p class="text-sm text-dm-red">Campo obligatorio.</p>
            <p class="text-xs text-dm-red">Ingresa un correo válido.</p>
            <p class="text-sm font-medium text-dm-red">Máximo 8 etiquetas.</p>
          </div>
        </div>

        <div class="border-t border-dm-offblack/10 pt-5">
          <label
            for="brand-error-field"
            class="dm-ui-facet-label mb-1.5 block"
          >
            Nombre <span class="text-dm-red">*</span>
          </label>
          <input
            id="brand-error-field"
            type="text"
            value=""
            aria-invalid="true"
            aria-describedby="brand-error-msg"
            class="w-full rounded border border-dm-red bg-white px-3 py-2 text-sm text-dm-offblack outline-none focus:border-dm-red focus:ring-1 focus:ring-dm-red/40"
          />
          <p id="brand-error-msg" class="mt-1.5 text-xs text-dm-red">
            Campo obligatorio — escribe tu nombre.
          </p>
        </div>

        <div class="border-t border-dm-offblack/10 pt-5">
          <p class="dm-ui-facet-label mb-2">Error banner</p>
          <p
            class="rounded border border-dm-red/40 bg-dm-red/10 px-3 py-2 text-sm text-dm-red"
            role="alert"
          >
            No se pudo guardar. Revisa los campos marcados.
          </p>
        </div>
      </div>
    </section>

    <!-- Borders & shadows -->
    <section class="space-y-4" aria-labelledby="brand-surfaces">
      <div>
        <h2 id="brand-surfaces" class="dm-ui-section-title">Borders & shadows</h2>
        <p class="dm-ui-body mt-1">Surface treatments used on cards and shells</p>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        <div
          class="rounded-md border border-dm-offblack/15 bg-white p-4 text-center text-xs shadow-sm"
        >
          <p class="font-semibold">Soft</p>
          <p class="mt-1 text-dm-offblack/50">border /15 · shadow-sm</p>
        </div>
        <div
          class="rounded-md border-2 border-dm-offblack/15 bg-white p-4 text-center text-xs shadow-md"
        >
          <p class="font-semibold">Free card</p>
          <p class="mt-1 text-dm-offblack/50">border-2 /15 · shadow-md</p>
        </div>
        <div
          class="rounded-md border-2 border-dm-offblack/35 bg-white p-4 text-center text-xs shadow-lg"
        >
          <p class="font-semibold">Pro card</p>
          <p class="mt-1 text-dm-offblack/50">border-2 /35 · shadow-lg</p>
        </div>
      </div>
    </section>

    <p class="border-t border-dm-offblack/10 pt-6 text-xs text-dm-offblack/45">
      Source: <code>docs/brand.md</code> · <code>src/styles/global.css</code>
    </p>
  </div>
</BaseLayout>
